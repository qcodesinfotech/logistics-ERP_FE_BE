  async updateInventory(id: string, data: Partial<InsertInventory>): Promise<Inventory | undefined> {
    const [inv] = await db.update(inventory).set(data).where(eq(inventory.id, id)).returning();
    return inv || undefined;
  }

  async adjustInventory(data: { productId: string; warehouseId: string; quantityChange: number; costPrice: number; reason: string; adjustmentType: "add" | "remove" }): Promise<Inventory> {
    const adjustmentNumber = await this.getNextNumber("ADJ");

    return await db.transaction(async (tx) => {
      const [existingInv] = await tx.select().from(inventory)
        .where(and(
          eq(inventory.productId, data.productId),
          eq(inventory.warehouseId, data.warehouseId)
        ));

      let inv: Inventory;
      const totalValue = Math.abs(data.quantityChange) * data.costPrice;

      if (existingInv) {
        const newQty = data.adjustmentType === "add"
          ? existingInv.quantity + Math.abs(data.quantityChange)
          : existingInv.quantity - Math.abs(data.quantityChange);

        const [updated] = await tx.update(inventory)
          .set({ quantity: Math.max(0, newQty) })
          .where(eq(inventory.id, existingInv.id))
          .returning();
        inv = updated;
      } else {
        const [created] = await tx.insert(inventory).values({
          productId: data.productId,
          warehouseId: data.warehouseId,
          quantity: data.adjustmentType === "add" ? Math.abs(data.quantityChange) : 0,
          costPrice: data.costPrice.toFixed(3),
        }).returning();
        inv = created;
      }

      if (totalValue > 0) {
        // Fetch warehouse to get shopId and branchId for journal entry
        const [warehouse] = await tx.select().from(warehouses).where(eq(warehouses.id, data.warehouseId));
        if (!warehouse || !warehouse.shopId) {
          throw new Error("Warehouse must have a shopId for inventory adjustments");
        }

        const journalLines = [];

        if (data.adjustmentType === "add") {
          journalLines.push(
            { accountCode: "1200", debit: totalValue, description: `Inventory increase - ${data.reason}` },
            { accountCode: "5100", credit: totalValue, description: `Adjustment expense - ${data.reason}` }
          );
        } else {
          journalLines.push(
            { accountCode: "5100", debit: totalValue, description: `Inventory write-off - ${data.reason}` },
            { accountCode: "1200", credit: totalValue, description: `Inventory decrease - ${data.reason}` }
          );
        }

        // Get branchId from warehouse or fetch first branch for the shop
        let branchId = warehouse.branchId;
        if (!branchId) {
          const [branch] = await tx.select().from(branches).where(eq(branches.shopId, warehouse.shopId)).limit(1);
          branchId = branch?.id || warehouse.shopId;
        }

        await this.createJournalEntryInTx(tx, {
          sourceType: "inventory_adjustment",
          sourceId: inv.id,
          shopId: warehouse.shopId,
          branchId: branchId,
          reference: adjustmentNumber,
          description: `Stock adjustment - ${data.reason}`,
          lines: journalLines,
        });
      }

      return inv;
    });
  }

  // Customers
  async getCustomers(scope?: { companyId?: string | null; shopId?: string | null; branchId?: string | null } | null): Promise<Customer[]> {
    const conditions = [];

    // SECURITY: If scope is provided but has no valid company or shop, return empty to prevent data leakage
    if (scope && !scope.companyId && !scope.shopId) {
      return [];
    }

    // If companyId is provided but shopId is not, get shops for that company and filter by those
    if (scope?.companyId && !scope?.shopId) {
      const companyShops = await db.select({ id: shops.id }).from(shops).where(eq(shops.companyId, scope.companyId));
      const shopIds = companyShops.map(s => s.id);
      if (shopIds.length > 0) {
        conditions.push(inArray(customers.shopId, shopIds));
      } else {
        return [];
      }
    } else if (scope?.shopId) {
      // STRICT FILTERING: Only return customers assigned to this shop
      conditions.push(eq(customers.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      // STRICT FILTERING: Only return customers assigned to this branch
      conditions.push(eq(customers.branchId, scope.branchId));
    }
    if (conditions.length > 0) {
      return db.select().from(customers).where(and(...conditions));
    }
    return db.select().from(customers);
  }

  async getCustomer(id: string): Promise<Customer | undefined> {
    const [customer] = await db.select().from(customers).where(eq(customers.id, id));
    return customer || undefined;
  }

  async createCustomer(data: InsertCustomer): Promise<Customer> {
    // Check for duplicate customer by phone or email (contact details), not name
    if (data.phone) {
      const existingByPhone = await db.select().from(customers).where(eq(customers.phone, data.phone));
      if (existingByPhone.length > 0) {
        throw new Error(`A customer with phone "${data.phone}" already exists`);
      }
    }
    if (data.contactEmail) {
      const existingByEmail = await db.select().from(customers).where(sql`LOWER(contact_email) = LOWER(${data.contactEmail})`);
      if (existingByEmail.length > 0) {
        throw new Error(`A customer with email "${data.contactEmail}" already exists`);
      }
    }
    const customerData = {
      ...data,
      currentBalance: data.openingBalance || "0.000",
    };
    const [customer] = await db.insert(customers).values(customerData).returning();
    return customer;
  }

  async updateCustomer(id: string, data: Partial<InsertCustomer>): Promise<Customer | undefined> {
    const [customer] = await db.update(customers).set(data).where(eq(customers.id, id)).returning();
    return customer || undefined;
  }

  async deleteCustomer(id: string): Promise<void> {
    await db.delete(customers).where(eq(customers.id, id));
  }

  async clearCustomerCredit(id: string, amount: number, paymentMethod: string, bankAccountId: string, notes?: string, scope?: { shopId?: string; branchId?: string }): Promise<any> {
    return await db.transaction(async (tx) => {
      const [customer] = await tx.select().from(customers).where(eq(customers.id, id));
      if (!customer) throw new Error("Customer not found");

      const currentBalance = parseFloat(customer.currentBalance || "0");
      if (currentBalance <= 0) throw new Error("No credit balance to clear");

      const clearAmount = Math.min(amount, currentBalance);
      const newBalance = currentBalance - clearAmount;

      await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, id));

      // Get and update bank account
      const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, bankAccountId));
      if (!account) throw new Error("Bank account not found");

      const newAccountBalance = parseFloat(account.currentBalance || "0") + clearAmount;
      await tx.update(bankAccounts).set({ currentBalance: newAccountBalance.toFixed(3) }).where(eq(bankAccounts.id, bankAccountId));

      // Get shopId from bank account or customer, or fall back to scope provided by middleware
      let shopId = account.shopId || customer.shopId || scope?.shopId;
      if (!shopId) throw new Error("Shop scope is required for credit clearing. Please ensure a shop is selected.");

      let branchId = account.branchId || customer.branchId || scope?.branchId;
      if (!branchId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, shopId)).limit(1);
        branchId = branch?.id || shopId;
      }

      // Record bank transaction
      const receiptNumber = await this.getNextNumber("REC");
      await tx.insert(bankTransactions).values({
        bankAccountId: bankAccountId,
        shopId: shopId,
        branchId: branchId,
        type: "deposit",
        amount: clearAmount.toFixed(3),
        reference: receiptNumber,
        description: `Credit clearing from ${customer.name} (${paymentMethod})${notes ? ` - ${notes}` : ""}`,
        category: "customer_payment",
      });

      // Apply payment to outstanding sales (FIFO - oldest sales first)
      let remainingPayment = clearAmount;
      const unpaidSales = await tx.select().from(sales)
        .where(and(
          eq(sales.customerId, id),
          gt(sql`CAST(credit_amount AS DECIMAL)`, 0)
        ))
        .orderBy(sales.saleDate);

      const updatedSales: string[] = [];
      for (const sale of unpaidSales) {
        if (remainingPayment <= 0) break;

        const saleCreditAmount = parseFloat(sale.creditAmount || "0");
        if (saleCreditAmount <= 0) continue;

        const paymentForThisSale = Math.min(remainingPayment, saleCreditAmount);
        const newCreditAmount = saleCreditAmount - paymentForThisSale;
        const newCashAmount = parseFloat(sale.cashAmount || "0") + paymentForThisSale;
        const newPaymentStatus = newCreditAmount <= 0.001 ? "paid" : "partial";

        await tx.update(sales).set({
          creditAmount: newCreditAmount.toFixed(3),
          cashAmount: newCashAmount.toFixed(3),
          paymentStatus: newPaymentStatus,
        }).where(eq(sales.id, sale.id));

        // Record sale payment for payment history
        await tx.insert(salePayments).values({
          saleId: sale.id,
          customerId: id,
          paymentMethod: paymentMethod,
          bankAccountId: bankAccountId,
          amount: paymentForThisSale.toFixed(3),
          reference: receiptNumber,
          notes: notes || `Customer debt payment`,
        });

        updatedSales.push(sale.saleNumber || sale.id);
        remainingPayment -= paymentForThisSale;
      }

      // Create journal entry for payment received
      await this.createJournalEntryInTx(tx, {
        sourceType: "customer_payment",
        sourceId: id,
        shopId: shopId,
        branchId: branchId,
        reference: receiptNumber,
        description: `Credit clearing: ${clearAmount.toFixed(3)} RO received from ${customer.name} (${paymentMethod})${notes ? ` - ${notes}` : ""}`,
        lines: [
          { accountCode: "1000", debit: clearAmount, description: `Cash/card received (${paymentMethod})` },
          { accountCode: "1100", credit: clearAmount, description: "Accounts receivable reduction" },
        ],
      });

      return {
        customer: { ...customer, currentBalance: newBalance.toFixed(3) },
        clearedAmount: clearAmount,
        receiptNumber,
        bankAccountBalance: newAccountBalance.toFixed(3),
        updatedSales,
      };
    });
  }

  async refundCustomerCredit(id: string, amount: number, paymentMethod: string, bankAccountId: string, notes?: string): Promise<any> {
    // STRICT FINANCIAL CONTROL: Validate sufficient funds before customer refund
    await this.ensureSufficientFunds(amount, bankAccountId, "customer refund");

    return await db.transaction(async (tx) => {
      const [customer] = await tx.select().from(customers).where(eq(customers.id, id));
      if (!customer) throw new Error("Customer not found");

      const currentBalance = parseFloat(customer.currentBalance || "0");
      if (currentBalance >= 0) throw new Error("Customer has no store credit to refund");

      const availableCredit = Math.abs(currentBalance);
      if (amount > availableCredit) throw new Error(`Cannot refund more than ${availableCredit.toFixed(3)} RO`);

      // Bank account already validated by ensureSufficientFunds
      const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, bankAccountId));
      if (!account) throw new Error("Bank account not found");
      const accountBalance = parseFloat(account.currentBalance || "0");

      // Update customer balance (increase it, making it less negative or zero)
      const newBalance = currentBalance + amount;
      await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, id));

      // Deduct from bank account
      const newAccountBalance = accountBalance - amount;
      await tx.update(bankAccounts).set({ currentBalance: newAccountBalance.toFixed(3) }).where(eq(bankAccounts.id, bankAccountId));

      // Record bank transaction
      const refNumber = await this.getNextNumber("REF");
      await tx.insert(bankTransactions).values({
        bankAccountId: bankAccountId,
        shopId: account.shopId,
        branchId: account.branchId,
        type: "withdrawal",
        amount: amount.toFixed(3),
        reference: refNumber,
        description: `Store credit refund to ${customer.name}`,
        relatedType: "customer_refund",
        relatedId: id,
      });

      // Create journal entry for refund
      const receiptNumber = await this.getNextNumber("REF");
      await this.createJournalEntryInTx(tx, {
        sourceType: "customer_refund",
        sourceId: id,
        shopId: account.shopId,
        branchId: account.branchId,
        reference: receiptNumber,
        description: `Store credit refund: ${amount.toFixed(3)} RO to ${customer.name}${notes ? ` - ${notes}` : ""}`,
        lines: [
          { accountCode: "1100", debit: amount, description: "Accounts receivable increase (clear store credit)" },
          { accountCode: "1000", credit: amount, description: `Cash refunded (${paymentMethod})` },
        ],
      });

      return { customer: { ...customer, currentBalance: newBalance.toFixed(3) }, refundedAmount: amount, receiptNumber };
    });
  }

  // Clear customer opening balance (receive payment for initial receivable)
  async clearCustomerOpeningBalance(
    customerId: string,
    amount: number,
    paymentMethod: string,
    bankAccountId: string,
    notes?: string,
    scope?: { shopId?: string; branchId?: string }
  ): Promise<any> {
    if (amount <= 0) {
      throw new Error("Payment amount must be greater than zero.");
    }

    return await db.transaction(async (tx) => {
      const [customer] = await tx.select().from(customers).where(eq(customers.id, customerId));
      if (!customer) throw new Error("Customer not found");

      const openingBalance = parseFloat(customer.openingBalance || "0");
      if (openingBalance <= 0) {
        throw new Error("Customer has no opening balance to clear.");
      }

      if (amount > openingBalance + 0.001) {
        throw new Error(`Payment amount (${amount.toFixed(3)} RO) exceeds opening balance (${openingBalance.toFixed(3)} RO)`);
      }

      const clearAmount = Math.min(amount, openingBalance);
      const newOpeningBalance = openingBalance - clearAmount;
      const newCurrentBalance = parseFloat(customer.currentBalance || "0") - clearAmount;

      // Update customer opening balance and current balance
      await tx.update(customers).set({
        openingBalance: newOpeningBalance.toFixed(3),
        currentBalance: newCurrentBalance.toFixed(3)
      }).where(eq(customers.id, customerId));

      // Get and validate bank account
      const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, bankAccountId));
      if (!account) throw new Error("Bank account not found");

      // Validate bank account is within user's scope if scope is provided
      if (scope?.shopId && account.shopId && account.shopId !== scope.shopId) {
        throw new Error("Bank account is not within your permitted scope");
      }

      // Deposit to bank account (receiving payment)
      await tx.update(bankAccounts)
        .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${clearAmount}` })
        .where(eq(bankAccounts.id, bankAccountId));

      const receiptNumber = await this.getNextNumber("OB-RCV");

      // Record bank transaction
      await tx.insert(bankTransactions).values({
        bankAccountId: bankAccountId,
        shopId: account.shopId,
        branchId: account.branchId,
        type: "deposit",
        amount: clearAmount.toFixed(3),
        reference: receiptNumber,
        description: `Opening balance payment from customer: ${customer.name}`,
        relatedType: "opening_balance_receipt",
        relatedId: customerId,
      });

      // Determine shopId/branchId for journal entry
      const txShopId = scope?.shopId || account.shopId;
      const txBranchId = scope?.branchId || account.branchId;

      if (!txShopId) throw new Error("shopId is required for opening balance receipt journal entry");
      let journalBranchId = txBranchId;
      if (!journalBranchId && txShopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, txShopId)).limit(1);
        journalBranchId = branch?.id || txShopId;
      }

      // Create journal entry: Debit Bank (increase cash), Credit Accounts Receivable (reduce receivable)
      await this.createJournalEntryInTx(tx, {
        sourceType: "opening_balance_receipt",
        sourceId: customerId,
        shopId: txShopId,
        branchId: journalBranchId,
        reference: receiptNumber,
        description: `Opening balance receipt: ${clearAmount.toFixed(3)} RO from ${customer.name}${notes ? ` - ${notes}` : ""}`,
        lines: [
          { accountCode: "1010", debit: clearAmount, description: `Bank deposit (${paymentMethod})` },
          { accountCode: "1100", credit: clearAmount, description: `Opening balance reduction for ${customer.name}` },
        ],
      });

      return {
        customer: { ...customer, openingBalance: newOpeningBalance.toFixed(3), currentBalance: newCurrentBalance.toFixed(3) },
        clearedAmount: clearAmount,
        receiptNumber,
        newOpeningBalance: newOpeningBalance,
        bankAccount: account.accountName
      };
    });
  }

