  async updateSerialNumberStatus(id: string, status: string, additionalData?: { saleId?: string; saleItemId?: string; soldAt?: Date; returnedAt?: Date; replacedAt?: Date }): Promise<SerialNumber | undefined> {
    const updateData: any = { status, updatedAt: new Date() };
    if (additionalData?.saleId) updateData.saleId = additionalData.saleId;
    if (additionalData?.saleItemId) updateData.saleItemId = additionalData.saleItemId;
    if (additionalData?.soldAt) updateData.soldAt = additionalData.soldAt;
    if (additionalData?.returnedAt) updateData.returnedAt = additionalData.returnedAt;
    if (additionalData?.replacedAt) updateData.replacedAt = additionalData.replacedAt;

    const [serial] = await db.update(serialNumbers).set(updateData).where(eq(serialNumbers.id, id)).returning();
    return serial || undefined;
  }

  // Purchase Returns
  async getPurchaseReturns(supplierId?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<PurchaseReturn[]> {
    const conditions = [];
    if (supplierId) {
      conditions.push(eq(purchaseReturns.supplierId, supplierId));
    }
    if (scope?.shopId) {
      conditions.push(eq(purchaseReturns.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      conditions.push(eq(purchaseReturns.branchId, scope.branchId));
    }
    if (conditions.length > 0) {
      return db.select().from(purchaseReturns).where(and(...conditions)).orderBy(desc(purchaseReturns.createdAt));
    }
    return db.select().from(purchaseReturns).orderBy(desc(purchaseReturns.createdAt));
  }

  async getPurchaseReturnsByPurchase(purchaseId: string): Promise<PurchaseReturn[]> {
    return db.select().from(purchaseReturns).where(eq(purchaseReturns.purchaseId, purchaseId)).orderBy(desc(purchaseReturns.returnDate));
  }

  async getPurchaseReturn(id: string): Promise<PurchaseReturn | undefined> {
    const [result] = await db.select().from(purchaseReturns).where(eq(purchaseReturns.id, id));
    return result || undefined;
  }

  async getPurchaseReturnItems(returnId: string): Promise<(PurchaseReturnItem & { productName?: string })[]> {
    const items = await db.select().from(purchaseReturnItems).where(eq(purchaseReturnItems.returnId, returnId));
    const itemsWithProducts = await Promise.all(
      items.map(async (item) => {
        const [product] = await db.select().from(products).where(eq(products.id, item.productId));
        return { ...item, productName: product?.name || item.productId };
      })
    );
    return itemsWithProducts;
  }

  async createPurchaseReturn(data: InsertPurchaseReturn & { items: InsertPurchaseReturnItem[] }): Promise<PurchaseReturn> {
    const { items, ...returnData } = data;
    const returnNumber = await this.getNextNumber("PR");

    return await db.transaction(async (tx) => {
      // VALIDATION: Prevent over-returning - check already returned quantities per purchase/product
      // First, get the original purchase items with their quantities
      const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, returnData.purchaseId));
      if (!purchase) {
        throw new Error("Purchase not found");
      }

      const originalPurchaseItems = await tx.select().from(purchaseItems)
        .where(eq(purchaseItems.purchaseId, returnData.purchaseId));

      // Get all prior returns for this purchase with their items
      const priorReturnsForPurchase = await tx.select().from(purchaseReturns)
        .where(eq(purchaseReturns.purchaseId, returnData.purchaseId));

      const priorReturnIds = priorReturnsForPurchase.map(r => r.id);
      let priorReturnedItems: { productId: string; quantity: number | null; serialNumber: string | null }[] = [];

      if (priorReturnIds.length > 0) {
        priorReturnedItems = await tx.select({
          productId: purchaseReturnItems.productId,
          quantity: purchaseReturnItems.quantity,
          serialNumber: purchaseReturnItems.serialNumber,
        }).from(purchaseReturnItems)
          .where(sql`${purchaseReturnItems.returnId} IN (${sql.join(priorReturnIds.map(id => sql`${id}`), sql`, `)})`);
      }

      // Calculate already returned quantities per product
      const alreadyReturnedQtyByProduct = new Map<string, number>();
      const alreadyReturnedSerials = new Set<string>();

      for (const item of priorReturnedItems) {
        const currentQty = alreadyReturnedQtyByProduct.get(item.productId) || 0;
        alreadyReturnedQtyByProduct.set(item.productId, currentQty + (item.quantity || 1));
        if (item.serialNumber) {
          alreadyReturnedSerials.add(item.serialNumber);
        }
      }

      // Calculate original purchased quantities per product
      const purchasedQtyByProduct = new Map<string, number>();
      for (const pItem of originalPurchaseItems) {
        purchasedQtyByProduct.set(pItem.productId, pItem.quantity);
      }

      // Validate each item being returned
      for (const returnItem of items) {
        const purchasedQty = purchasedQtyByProduct.get(returnItem.productId) || 0;
        const alreadyReturnedQty = alreadyReturnedQtyByProduct.get(returnItem.productId) || 0;
        const remainingQty = purchasedQty - alreadyReturnedQty;
        const requestedQty = returnItem.quantity || 1;

        if (requestedQty > remainingQty) {
          const [product] = await tx.select().from(products).where(eq(products.id, returnItem.productId));
          const productName = product?.name || returnItem.productId;
          throw new Error(`Cannot return ${requestedQty} of "${productName}" - only ${remainingQty} remaining (purchased: ${purchasedQty}, already returned: ${alreadyReturnedQty})`);
        }

        // Check if serial number has already been returned
        if (returnItem.serialNumber && alreadyReturnedSerials.has(returnItem.serialNumber)) {
          throw new Error(`Serial number "${returnItem.serialNumber}" has already been returned`);
        }
      }

      // Check if purchase is already fully returned
      let totalPurchasedQty = 0;
      let totalAlreadyReturnedQty = 0;
      for (const [productId, qty] of purchasedQtyByProduct) {
        totalPurchasedQty += qty;
        totalAlreadyReturnedQty += alreadyReturnedQtyByProduct.get(productId) || 0;
      }

      if (totalPurchasedQty > 0 && totalAlreadyReturnedQty >= totalPurchasedQty) {
        throw new Error("This purchase has already been fully returned. No more items can be returned.");
      }

      // Validate liability_reduction is only allowed for unpaid purchases
      if (returnData.returnType === "liability_reduction") {
        // Multi-layer validation for maximum safety:
        // 1. Check paidAmount on purchase record (authoritative field)
        const recordedPaidAmount = parseFloat(purchase.paidAmount || "0");

        // 2. Calculate from purchase payments table for accuracy
        const payments = await tx.select({ amount: purchasePayments.amount })
          .from(purchasePayments)
          .where(eq(purchasePayments.purchaseId, returnData.purchaseId));
        const summedPaidAmount = payments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);

        // 3. Check for supplier credits applied to this purchase
        const creditsApplied = await tx.select({ amount: supplierCreditTransactions.amount })
          .from(supplierCreditTransactions)
          .where(and(
            eq(supplierCreditTransactions.purchaseId, returnData.purchaseId),
            eq(supplierCreditTransactions.transactionType, "credit_applied")
          ));
        const totalCreditsApplied = creditsApplied.reduce((sum, c) => sum + parseFloat(c.amount || "0"), 0);

        // Take the maximum of all settlement sources to catch any partial payment
        const maxSettled = Math.max(recordedPaidAmount, summedPaidAmount + totalCreditsApplied);

        if (maxSettled > 0) {
          throw new Error("Liability reduction is only allowed for fully unpaid purchases. Use 'credit' or 'refund' instead.");
        }
      }

      // CRITICAL: Calculate VAT server-side per-item from original purchase data FIRST
      // Note: Serial number costPrice stores the BASE price (without VAT)
      let vatAmount = 0;
      let subtotal = 0;

      // Handle multi-purchase returns: extract unique purchase IDs from composite IDs
      const allPurchaseIds: string[] = [];
      if ((returnData as any).purchaseIds && Array.isArray((returnData as any).purchaseIds)) {
        // purchaseIds are in format "purchaseId_productId", extract the purchaseId part
        for (const compositeId of (returnData as any).purchaseIds) {
          const purchaseId = compositeId.split('_')[0];
          if (!allPurchaseIds.includes(purchaseId)) {
            allPurchaseIds.push(purchaseId);
          }
        }
      } else if (returnData.purchaseId) {
        allPurchaseIds.push(returnData.purchaseId);
      }

      // Get original purchase data for charges (discount, freight, otherCharges)
      const purchaseCharges = new Map<string, { discount: number; freight: number; otherCharges: number; subtotal: number }>();
      for (const pId of allPurchaseIds) {
        const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, pId));
        if (purchase) {
          // Parse other charges JSON
          let otherChargesTotal = 0;
          if (purchase.otherCharges) {
            try {
              const charges = JSON.parse(purchase.otherCharges as string);
              if (Array.isArray(charges)) {
                otherChargesTotal = charges.reduce((sum: number, c: any) => sum + parseFloat(c.amount || "0"), 0);
              }
            } catch (e) {
              otherChargesTotal = 0;
            }
          }
          purchaseCharges.set(pId, {
            discount: parseFloat(purchase.discount || "0"),
            freight: parseFloat(purchase.freight || "0"),
            otherCharges: otherChargesTotal,
            subtotal: parseFloat(purchase.subtotal || "0"),
          });
        }
      }

      // Get original purchase items from ALL selected purchases to calculate per-item VAT
      const productVatRates = new Map<string, number>();
      const productToPurchaseId = new Map<string, string>();
      for (const pId of allPurchaseIds) {
        const purchaseItemsList = await tx.select().from(purchaseItems)
          .where(eq(purchaseItems.purchaseId, pId));
        for (const pItem of purchaseItemsList) {
          productVatRates.set(pItem.productId, parseFloat(pItem.vatRate || "0"));
          productToPurchaseId.set(pItem.productId, pId);
        }
      }

      // Calculate subtotal and VAT for each returned item using its original VAT rate
      // Also track return amounts per purchase for proportional charge calculation
      const returnAmountsByPurchase = new Map<string, number>();
      for (const returnItem of items) {
        // unitPrice is the BASE price (from serial costPrice), not VAT-inclusive
        const itemBasePrice = parseFloat(returnItem.unitPrice || "0");
        const itemVatRate = productVatRates.get(returnItem.productId) ?? 0;
        const itemVat = itemBasePrice * (itemVatRate / 100);

        subtotal += itemBasePrice;
        vatAmount += itemVat;

        // STRICT ACCOUNTING: Get purchase ID from the serial number record for accurate mapping
        // This ensures multi-purchase scenarios with same product are correctly handled
        let itemPurchaseId = returnData.purchaseId;
        if (returnItem.serialNumber) {
          const [serial] = await tx.select({ purchaseId: serialNumbers.purchaseId })
            .from(serialNumbers)
            .where(eq(serialNumbers.serialNumber, returnItem.serialNumber));
          if (serial?.purchaseId) {
            itemPurchaseId = serial.purchaseId;
          }
        }
        // Fallback to productId mapping if serial not found
        if (!itemPurchaseId || !allPurchaseIds.includes(itemPurchaseId)) {
          itemPurchaseId = productToPurchaseId.get(returnItem.productId) || returnData.purchaseId;
        }

        const existing = returnAmountsByPurchase.get(itemPurchaseId) || 0;
        returnAmountsByPurchase.set(itemPurchaseId, existing + itemBasePrice);
      }

      // STRICT ACCOUNTING: Calculate proportional discount, freight, and other charges
      // Discount REDUCES return amount (we paid less for items due to discount)
      // Freight and other charges ADD to return amount (we paid extra for delivery/handling)
      let proportionalDiscount = 0;
      let proportionalFreight = 0;
      let proportionalOtherCharges = 0;

      for (const [purchaseId, returnAmount] of returnAmountsByPurchase) {
        const charges = purchaseCharges.get(purchaseId);
        if (charges && charges.subtotal > 0) {
          // Calculate the proportion of items being returned from this purchase
          const returnProportion = returnAmount / charges.subtotal;

          // Apply proportional charges
          proportionalDiscount += charges.discount * returnProportion;
          proportionalFreight += charges.freight * returnProportion;
          proportionalOtherCharges += charges.otherCharges * returnProportion;
        }
      }

      // Server-calculated total:
      // Base = subtotal + VAT
      // Adjustments: - discount (reduces return) + freight + otherCharges (increase return)
      const totalAmount = subtotal + vatAmount - proportionalDiscount + proportionalFreight + proportionalOtherCharges;
      // liability_reduction: No credit or refund - just reduces what we owe
      const creditApplied = returnData.returnType === "credit" ? totalAmount : 0;
      const refundAmount = returnData.returnType === "refund" ? totalAmount : 0;

      // Create purchase return record with server-calculated values
      const [purchaseReturn] = await tx.insert(purchaseReturns).values({
        ...returnData,
        returnNumber,
        totalAmount: totalAmount.toFixed(3),
        creditApplied: creditApplied.toFixed(3),
        refundAmount: refundAmount.toFixed(3),
      }).returning();

      if (items.length > 0) {
        await tx.insert(purchaseReturnItems).values(
          items.map(item => ({ ...item, returnId: purchaseReturn.id }))
        );

        for (const item of items) {
          if (item.serialNumber) {
            await tx.update(serialNumbers)
              .set({ status: "returned", returnedAt: new Date(), updatedAt: new Date() })
              .where(eq(serialNumbers.serialNumber, item.serialNumber));
          }
        }
      }

      if (totalAmount > 0) {
        const journalLines = [];

        // CRITICAL FIX: Reduce supplier balance (what we owe them) for all return types
        const [supplier] = await tx.select().from(suppliers).where(eq(suppliers.id, returnData.supplierId));
        if (supplier) {
          const currentBalance = parseFloat(supplier.currentBalance || "0");
          const newSupplierBalance = Math.max(0, currentBalance - totalAmount);
          await tx.update(suppliers)
            .set({ currentBalance: newSupplierBalance.toFixed(3) })
            .where(eq(suppliers.id, returnData.supplierId));
        }

        if (returnData.returnType === "liability_reduction") {
          // Liability reduction type: Purchase was never paid, just reduce what we owe
          // Debit Accounts Payable (2000) for the total amount (reduce liability)
          // Credit Inventory (1200) for subtotal (reduce inventory value)
          // Credit VAT Payable (2150) to reverse input VAT claim
          // Debit Purchase Discount (5200) to reverse discount received
          // Credit Freight Expense (5100) to reverse freight cost
          // NO supplier credit created - we never paid so there's nothing to credit
          journalLines.push(
            { accountCode: "2000", debit: totalAmount, description: "Reduce payable for unpaid purchase return" },
            { accountCode: "1200", credit: subtotal, description: "Reduce inventory for return" }
          );
          if (vatAmount > 0) {
            journalLines.push({ accountCode: "2150", credit: vatAmount, description: "Reverse input VAT for purchase return" });
          }
          // Account for proportional adjustments to balance the entry
          if (proportionalDiscount > 0.001) {
            journalLines.push({ accountCode: "5200", debit: proportionalDiscount, description: "Reverse purchase discount for return" });
          }
          if (proportionalFreight > 0.001) {
            journalLines.push({ accountCode: "5100", credit: proportionalFreight, description: "Reverse freight expense for return" });
          }
          if (proportionalOtherCharges > 0.001) {
            journalLines.push({ accountCode: "5150", credit: proportionalOtherCharges, description: "Reverse other charges for return" });
          }
          // No supplier credit operations - just reducing outstanding payable
        } else if (returnData.returnType === "credit") {
          // STRICT ACCOUNTING: Credit type handling
          // Calculate BEFORE and AFTER balances to determine incremental credit

          // Get all purchases, payments, and returns EXCLUDING this one (before state)
          const supplierPurchases = await tx.select().from(purchases).where(eq(purchases.supplierId, returnData.supplierId));
          const supplierPayments = await tx.select().from(purchasePayments).where(eq(purchasePayments.supplierId, returnData.supplierId));
          const priorReturns = await tx.select().from(purchaseReturns)
            .where(and(
              eq(purchaseReturns.supplierId, returnData.supplierId),
              sql`${purchaseReturns.id} != ${purchaseReturn.id}`
            ));

          const totalPurchases = supplierPurchases.reduce((sum, p) => sum + parseFloat(p.total || "0"), 0);
          const totalPayments = supplierPayments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);
          const priorReturnsValue = priorReturns.reduce((sum, r) => sum + parseFloat(r.totalAmount || "0"), 0);

          // Balance BEFORE this return
          const balanceBefore = totalPurchases - totalPayments - priorReturnsValue;
          // Balance AFTER this return
          const balanceAfter = balanceBefore - totalAmount;

          // Determine how much of this return reduces AP vs creates new credit
          // Case 1: balanceBefore > 0 (we owe supplier)
          //   - If balanceAfter >= 0: entire return reduces AP
          //   - If balanceAfter < 0: part reduces AP, part creates credit
          // Case 2: balanceBefore <= 0 (supplier already owes us)
          //   - Entire return creates new credit

          let apReductionAmount = 0;
          let newCreditAmount = 0;

          if (balanceBefore > 0) {
            // We owed supplier before this return
            if (balanceAfter >= 0) {
              // Return fully absorbed by AP reduction
              apReductionAmount = totalAmount;
              newCreditAmount = 0;
            } else {
              // Return partially absorbed by AP, rest creates credit
              apReductionAmount = balanceBefore; // only reduce what we owed
              newCreditAmount = Math.abs(balanceAfter); // the overpayment portion
            }
          } else {
            // Supplier already owed us (prior overpayment)
            apReductionAmount = 0;
            newCreditAmount = totalAmount; // entire return adds to credit
          }

          // Journal entries
          if (apReductionAmount > 0.001) {
            journalLines.push(
              { accountCode: "2000", debit: apReductionAmount, description: "Reduce payable for purchase return" }
            );
          }

          if (newCreditAmount > 0.001) {
            journalLines.push(
              { accountCode: "1110", debit: newCreditAmount, description: "Supplier receivable from overpayment" }
            );
          }

          // Always credit inventory and VAT for the return
          journalLines.push(
            { accountCode: "1200", credit: subtotal, description: "Reduce inventory for return" }
          );
          if (vatAmount > 0) {
            journalLines.push({ accountCode: "2150", credit: vatAmount, description: "Reverse input VAT for purchase return" });
          }
          // Account for proportional adjustments to balance the entry
          if (proportionalDiscount > 0.001) {
            journalLines.push({ accountCode: "5200", debit: proportionalDiscount, description: "Reverse purchase discount for return" });
          }
          if (proportionalFreight > 0.001) {
            journalLines.push({ accountCode: "5100", credit: proportionalFreight, description: "Reverse freight expense for return" });
          }
          if (proportionalOtherCharges > 0.001) {
            journalLines.push({ accountCode: "5150", credit: proportionalOtherCharges, description: "Reverse other charges for return" });
          }

          // Only create/update supplier credit if there's INCREMENTAL credit from this return
          if (newCreditAmount > 0.001) {
            const existing = await tx.select().from(supplierCredits)
              .where(eq(supplierCredits.supplierId, returnData.supplierId));

            if (existing.length > 0) {
              const newBalance = (parseFloat(existing[0].creditBalance || "0") + newCreditAmount).toFixed(3);
              await tx.update(supplierCredits)
                .set({ creditBalance: newBalance, lastUpdated: new Date() })
                .where(eq(supplierCredits.id, existing[0].id));

              await tx.insert(supplierCreditTransactions).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                purchaseReturnId: purchaseReturn.id,
                transactionType: "credit_added",
                amount: newCreditAmount.toFixed(3),
                balanceAfter: newBalance,
                description: `Overpayment credit from return ${returnNumber}`,
              });
            } else {
              await tx.insert(supplierCredits).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                creditBalance: newCreditAmount.toFixed(3),
              });

              await tx.insert(supplierCreditTransactions).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                purchaseReturnId: purchaseReturn.id,
                transactionType: "credit_added",
                amount: newCreditAmount.toFixed(3),
                balanceAfter: newCreditAmount.toFixed(3),
                description: `Overpayment credit from return ${returnNumber}`,
              });
            }
          }
          // If no new credit, don't touch supplierCredits table
        } else {
          // Cash refund type: STRICT ACCOUNTING - Cap refund at actual payments made
          // Cannot refund more cash than was actually paid to the supplier

          // Calculate total payments made and prior refunds received for this supplier
          // Use shop AND branch scoping for proper data isolation
          const supplierPaymentConditions: any[] = [eq(purchasePayments.supplierId, returnData.supplierId)];
          if (returnData.shopId) {
            supplierPaymentConditions.push(eq(purchasePayments.shopId, returnData.shopId));
          }
          if (returnData.branchId) {
            supplierPaymentConditions.push(eq(purchasePayments.branchId, returnData.branchId));
          }
          const supplierPayments = supplierPaymentConditions.length > 1
            ? await tx.select().from(purchasePayments).where(and(...supplierPaymentConditions))
            : await tx.select().from(purchasePayments).where(supplierPaymentConditions[0]);

          const priorRefundConditions: any[] = [
            eq(purchaseReturns.supplierId, returnData.supplierId),
            sql`${purchaseReturns.id} != ${purchaseReturn.id}`,
            eq(purchaseReturns.returnType, "refund")
          ];
          if (returnData.shopId) {
            priorRefundConditions.push(eq(purchaseReturns.shopId, returnData.shopId));
          }
          if (returnData.branchId) {
            priorRefundConditions.push(eq(purchaseReturns.branchId, returnData.branchId));
          }
          const priorRefunds = await tx.select().from(purchaseReturns).where(and(...priorRefundConditions));

          const totalPaid = supplierPayments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);
          const priorRefundsValue = priorRefunds.reduce((sum, r) => sum + parseFloat(r.refundAmount || "0"), 0);

          // Maximum refundable = what was paid minus prior refunds
          const maxRefundable = Math.max(0, totalPaid - priorRefundsValue);

          // Cap cash refund at maximum refundable
          const actualCashRefund = Math.min(totalAmount, maxRefundable);
          const excessAsCredit = totalAmount - actualCashRefund;

          // Entry 1: Reverse original purchase entry (always full amount)
          journalLines.push(
            { accountCode: "2000", debit: totalAmount, description: "Reverse payable for purchase return" },
            { accountCode: "1200", credit: subtotal, description: "Reduce inventory for return" }
          );
          if (vatAmount > 0) {
            journalLines.push({ accountCode: "2150", credit: vatAmount, description: "Reverse input VAT for purchase return" });
          }
          // Account for proportional adjustments to balance the entry
          if (proportionalDiscount > 0.001) {
            journalLines.push({ accountCode: "5200", debit: proportionalDiscount, description: "Reverse purchase discount for return" });
          }
          if (proportionalFreight > 0.001) {
            journalLines.push({ accountCode: "5100", credit: proportionalFreight, description: "Reverse freight expense for return" });
          }
          if (proportionalOtherCharges > 0.001) {
            journalLines.push({ accountCode: "5150", credit: proportionalOtherCharges, description: "Reverse other charges for return" });
          }

          // Entry 2: Record cash refund received from supplier (only actual cash portion)
          if (actualCashRefund > 0.001) {
            journalLines.push(
              { accountCode: "1000", debit: actualCashRefund, description: "Cash refund received from supplier" },
              { accountCode: "2000", credit: actualCashRefund, description: "Supplier payable settled by refund" }
            );

            // CRITICAL: Credit the refund to the bank account (only actual cash)
            const refundBankAccountId = (returnData as any).bankAccountId;
            if (refundBankAccountId) {
              // Update bank account balance
              await tx.update(bankAccounts).set({
                currentBalance: sql`CAST(current_balance AS NUMERIC) + ${actualCashRefund}`
              }).where(eq(bankAccounts.id, refundBankAccountId));

              // Create bank transaction record
              await tx.insert(bankTransactions).values({
                bankAccountId: refundBankAccountId,
                shopId: returnData.shopId || null,
                branchId: returnData.branchId || null,
                type: "deposit",
                amount: actualCashRefund.toFixed(3),
                reference: returnNumber,
                description: `Supplier refund - ${returnNumber}`,
                relatedType: "purchase_return",
                relatedId: purchaseReturn.id,
              });
            }
          }

          // Entry 3: Excess becomes supplier credit (if we're owed more than we paid)
          // NOTE: No journal entry needed here - the AP debit in Entry 1 already reflects the full return
          // The net effect (Entry 1 debit - Entry 2 credit) = excessAsCredit portion of AP reduction
          // We just need to track this in supplierCredits table for future application
          if (excessAsCredit > 0.001) {
            // Add to supplier credit balance with proper shop scoping
            const creditConditions: any[] = [eq(supplierCredits.supplierId, returnData.supplierId)];
            if (returnData.shopId) {
              creditConditions.push(eq(supplierCredits.shopId, returnData.shopId));
            }
            const existing = creditConditions.length > 1
              ? await tx.select().from(supplierCredits).where(and(...creditConditions))
              : await tx.select().from(supplierCredits).where(creditConditions[0]);

            if (existing.length > 0) {
              const newBalance = (parseFloat(existing[0].creditBalance || "0") + excessAsCredit).toFixed(3);
              await tx.update(supplierCredits)
                .set({ creditBalance: newBalance, lastUpdated: new Date() })
                .where(eq(supplierCredits.id, existing[0].id));

              await tx.insert(supplierCreditTransactions).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                purchaseReturnId: purchaseReturn.id,
                transactionType: "credit_added",
                amount: excessAsCredit.toFixed(3),
                balanceAfter: newBalance,
                description: `Excess return credit (capped refund) - ${returnNumber}`,
              });
            } else {
              await tx.insert(supplierCredits).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                creditBalance: excessAsCredit.toFixed(3),
              });

              await tx.insert(supplierCreditTransactions).values({
                supplierId: returnData.supplierId,
                shopId: returnData.shopId || null,
                purchaseReturnId: purchaseReturn.id,
                transactionType: "credit_added",
                amount: excessAsCredit.toFixed(3),
                balanceAfter: excessAsCredit.toFixed(3),
                description: `Excess return credit (capped refund) - ${returnNumber}`,
              });
            }
          }

          // Update the purchase return record with actual refund amount
          await tx.update(purchaseReturns)
            .set({
              refundAmount: actualCashRefund.toFixed(3),
              creditApplied: excessAsCredit.toFixed(3)
            })
            .where(eq(purchaseReturns.id, purchaseReturn.id));
        }

        // Get shopId and branchId from purchase return
        const returnShopId = purchaseReturn.shopId || returnData.shopId;
        let returnBranchId = purchaseReturn.branchId || returnData.branchId;
        if (!returnShopId) throw new Error("shopId is required for purchase return journal entry");
        if (!returnBranchId && returnShopId) {
          const [branch] = await tx.select().from(branches).where(eq(branches.shopId, returnShopId)).limit(1);
          returnBranchId = branch?.id || returnShopId;
        }

        await this.createJournalEntryInTx(tx, {
          sourceType: "purchase_return",
          sourceId: purchaseReturn.id,
          shopId: returnShopId,
          branchId: returnBranchId,
          reference: returnNumber,
          description: `Purchase return - ${returnNumber}`,
          lines: journalLines,
        });
      }

      // SYNC PARENT PURCHASE: Update creditApplied and paymentStatus on original purchase(s)
      // This ensures the "Net Payable" in the Purchase List view is accurate.
      // We use returnAmountsByPurchase (calculated earlier) to handle multi-purchase returns correctly.
      if (returnAmountsByPurchase.size > 0) {
        for (const [pId, amount] of returnAmountsByPurchase.entries()) {
          // Skip if amount is negligible
          if (amount <= 0.001) continue;

          const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, pId));
          if (purchase) {
            const currentCredit = parseFloat(purchase.creditApplied || "0");
            const newCredit = currentCredit + amount;

            const total = parseFloat(purchase.total || "0");
            const paid = parseFloat(purchase.paidAmount || "0");
            // Balance calculation: Net Payable = Total - Paid - Credit
            const balance = total - paid - newCredit;

            // Determine status
            // Use 'paid' if fully offset. 'returned' is not standard but understandable if defined in enum.
            const newStatus = balance <= 0.001 ? "paid" : "partial";

            await tx.update(purchases)
              .set({
                creditApplied: newCredit.toFixed(3),
                paymentStatus: newStatus
              })
              .where(eq(purchases.id, pId));
          }
        }
      }
      // Redundant block removed (fixed multi-purchase bug)
      if (false) {
        const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, purchaseReturn.purchaseId));
        if (purchase) {
          // If return type is NOT cash refund, it reduces the payable amount via credit/offset
          // Cash refund means we got money back, so the payable was effectively paid earlier or settled
          // But to keep "Net Payable" calculation (Total - Paid - Credit) correct, we track returns in creditApplied
          // Logic: Net Payable = Total - Paid - CreditApplied

          const currentCredit = parseFloat(purchase.creditApplied || "0");
          const newCredit = currentCredit + totalAmount;

          const total = parseFloat(purchase.total || "0");
          const paid = parseFloat(purchase.paidAmount || "0");
          const balance = total - paid - newCredit;

          const newStatus = balance <= 0.001 ? (paid > 0 ? "paid" : "returned") : "partial"; // Use 'returned' if fully returned without payment, else 'paid' or 'partial'
          // Note: "returned" isn't a standard status in all parts of the app, so fallback to 'paid' if simple closure is needed.
          // Let's use 'paid' if fully offset to ensure it shows as closed, unless 'returned' is explicitly supported. 
          // Schema default is 'pending'. 'paid', 'partial' are standard. Let's use 'paid' if balance is 0.
          const finalStatus = balance <= 0.001 ? "paid" : "partial";

          await tx.update(purchases)
            .set({
              creditApplied: newCredit.toFixed(3),
              paymentStatus: finalStatus
            })
            .where(eq(purchases.id, purchase.id));
        }
      }

      return purchaseReturn;
    });
  }

  // Supplier Credits
  async getSupplierCredit(supplierId: string, shopId?: string): Promise<SupplierCredit | undefined> {
    const conditions = [eq(supplierCredits.supplierId, supplierId)];
    if (shopId) conditions.push(eq(supplierCredits.shopId, shopId));
    const [result] = await db.select().from(supplierCredits).where(and(...conditions));
    return result || undefined;
  }

  async getAllSupplierCredits(shopId?: string): Promise<Array<{ supplierId: string; supplierName: string; creditBalance: string }>> {
    // Filter by shop_id for data isolation
    const conditions = [];
    if (shopId) {
      conditions.push(eq(supplierCredits.shopId, shopId));
    }

    const credits = conditions.length > 0
      ? await db.select().from(supplierCredits).where(and(...conditions))
      : await db.select().from(supplierCredits);

    const result = [];
    for (const credit of credits) {
      const [supplier] = await db.select().from(suppliers).where(eq(suppliers.id, credit.supplierId));
      if (supplier && parseFloat(credit.creditBalance || "0") > 0) {
        result.push({
          supplierId: credit.supplierId,
          supplierName: supplier.name,
          creditBalance: credit.creditBalance || "0.000",
        });
      }
    }
    return result;
  }

  async updateSupplierCredit(supplierId: string, amount: string, shopId?: string): Promise<SupplierCredit> {
    const existing = await this.getSupplierCredit(supplierId, shopId);

    if (existing) {
      const newBalance = (parseFloat(existing.creditBalance || "0") + parseFloat(amount)).toFixed(3);
      const [updated] = await db.update(supplierCredits)
        .set({ creditBalance: newBalance, lastUpdated: new Date() })
        .where(eq(supplierCredits.id, existing.id))
        .returning();
      return updated;
    } else {
      const [created] = await db.insert(supplierCredits).values({
        supplierId,
        shopId: shopId || null,
        creditBalance: amount,
      }).returning();
      return created;
    }
  }

  async getSupplierCreditTransactions(supplierId: string, shopId?: string): Promise<SupplierCreditTransaction[]> {
    const conditions = [eq(supplierCreditTransactions.supplierId, supplierId)];
    if (shopId) {
      conditions.push(eq(supplierCreditTransactions.shopId, shopId));
    }
    return db.select().from(supplierCreditTransactions)
      .where(and(...conditions))
      .orderBy(desc(supplierCreditTransactions.createdAt));
  }

  async createSupplierCreditTransaction(data: InsertSupplierCreditTransaction): Promise<SupplierCreditTransaction> {
    const [created] = await db.insert(supplierCreditTransactions).values(data).returning();
    return created;
  }

  async getSupplierCreditRefunds(supplierId: string): Promise<any[]> {
    const refunds = await db.select().from(supplierRefunds)
      .where(eq(supplierRefunds.supplierId, supplierId))
      .orderBy(desc(supplierRefunds.createdAt));
    return refunds;
  }

  async receiveSupplierRefund(supplierId: string, amount: number, bankAccountId: string, notes?: string, scope?: { shopId?: string; branchId?: string }): Promise<any> {
    if (amount <= 0) {
      throw new Error("Refund amount must be greater than zero.");
    }

    return await db.transaction(async (tx) => {
      const [supplier] = await tx.select().from(suppliers).where(eq(suppliers.id, supplierId));
      if (!supplier) throw new Error("Supplier not found");

      // Get supplier credit balance
      const [existingCredit] = await tx.select().from(supplierCredits).where(eq(supplierCredits.supplierId, supplierId));
      const creditBalance = parseFloat(existingCredit?.creditBalance || "0");

      if (creditBalance <= 0) {
        throw new Error("Supplier has no credit balance to refund.");
      }

      if (amount > creditBalance + 0.001) {
        throw new Error(`Refund amount (${amount.toFixed(3)} RO) exceeds supplier credit balance (${creditBalance.toFixed(3)} RO)`);
      }

      const refundAmount = Math.min(amount, creditBalance);
      const newCreditBalance = creditBalance - refundAmount;

      // Update supplier credit balance
      if (existingCredit) {
        await tx.update(supplierCredits)
          .set({ creditBalance: newCreditBalance.toFixed(3) })
          .where(eq(supplierCredits.id, existingCredit.id));
      }

      // Get bank account and validate scope
      const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, bankAccountId));
      if (!account) throw new Error("Bank account not found");

      // Validate bank account is within user's scope if scope is provided
      if (scope?.shopId && account.shopId && account.shopId !== scope.shopId) {
        throw new Error("Bank account is not within your permitted scope");
      }

      // Credit the bank account (deposit)
      await tx.update(bankAccounts)
        .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${refundAmount}` })
        .where(eq(bankAccounts.id, bankAccountId));

      // Create bank transaction (deposit)
      const refundRef = `SUP-REF-${Date.now()}`;
      await tx.insert(bankTransactions).values({
        bankAccountId: bankAccountId,
        shopId: account.shopId,
        branchId: account.branchId,
        type: "deposit",
        amount: refundAmount.toFixed(3),
        reference: refundRef,
        description: `Refund received from supplier: ${supplier.name}`,
        relatedType: "supplier_refund",
        relatedId: supplierId,
      });

      // Determine shopId/branchId from scope, credit record, or account
      const txShopId = scope?.shopId || existingCredit?.shopId || account.shopId;
      const txBranchId = scope?.branchId || existingCredit?.branchId || account.branchId;

      // Create supplier credit transaction record
      await tx.insert(supplierCreditTransactions).values({
        supplierId: supplierId,
        shopId: txShopId,
        branchId: txBranchId,
        transactionType: "refund_received",
        amount: (-refundAmount).toFixed(3),
        balanceAfter: newCreditBalance.toFixed(3),
        reference: refundRef,
        notes: notes || `Cash refund received - deposited to ${account.accountName}`,
      });

      // Create supplier refund record
      const refundNumber = await this.getNextNumber("SR");
      await tx.insert(supplierRefunds).values({
        refundNumber: refundNumber,
        supplierId: supplierId,
        shopId: txShopId,
        branchId: txBranchId,
        amount: refundAmount.toFixed(3),
        refundMethod: "bank",
        bankAccountId: bankAccountId,
        notes: notes,
        status: "completed",
      });

      // Validate shopId for journal entry
      if (!txShopId) throw new Error("shopId is required for supplier refund journal entry");
      let journalBranchId = txBranchId;
      if (!journalBranchId && txShopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, txShopId)).limit(1);
        journalBranchId = branch?.id || txShopId;
      }

      // Create journal entry: Debit Bank (increase asset), Credit Supplier Receivable (clear supplier credit receivable)
      await this.createJournalEntryInTx(tx, {
        sourceType: "supplier_refund",
        sourceId: supplierId,
        shopId: txShopId,
        branchId: journalBranchId,
        reference: refundNumber,
        description: `Supplier refund: ${refundAmount.toFixed(3)} RO received from ${supplier.name}${notes ? ` - ${notes}` : ""}`,
        lines: [
          { accountCode: "1010", debit: refundAmount, description: `Bank deposit - refund from ${supplier.name}` },
          { accountCode: "1110", credit: refundAmount, description: "Clear supplier receivable" },
        ],
      });

      return {
        supplier: supplier,
        refundAmount: refundAmount,
        newCreditBalance: newCreditBalance,
        refundNumber: refundNumber,
        bankAccount: account.accountName,
      };
    });
  }

  // Purchase Returns Helpers
  async getPurchasesForReturn(supplierId: string): Promise<any[]> {
    const purchaseList = await db.select()
      .from(purchases)
      .where(eq(purchases.supplierId, supplierId))
      .orderBy(desc(purchases.purchaseDate));

    const purchaseData = [];
    for (const purchase of purchaseList) {
      const availableSerials = await db.select({
        serial: serialNumbers,
        product: products,
        purchaseItem: purchaseItems,
      })
        .from(serialNumbers)
        .leftJoin(products, eq(serialNumbers.productId, products.id))
        .leftJoin(purchaseItems, eq(serialNumbers.purchaseItemId, purchaseItems.id))
        .where(and(
          eq(serialNumbers.purchaseId, purchase.id),
          eq(serialNumbers.status, "available")
        ));

      const supplierCredit = await this.getSupplierCredit(supplierId);

      // Calculate actual paid amount from payments table + paidAmount field for accurate "isFullyUnpaid" check
      const payments = await db.select({ amount: purchasePayments.amount })
        .from(purchasePayments)
        .where(eq(purchasePayments.purchaseId, purchase.id));
      const paymentsSum = payments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);

      // Also check supplier credits applied to this purchase
      const creditsApplied = await db.select({ amount: supplierCreditTransactions.amount })
        .from(supplierCreditTransactions)
        .where(and(
          eq(supplierCreditTransactions.purchaseId, purchase.id),
          eq(supplierCreditTransactions.transactionType, "credit_applied")
        ));
      const creditsSum = creditsApplied.reduce((sum, c) => sum + parseFloat(c.amount || "0"), 0);

      // Total settled = paidAmount (field) + payments table + credits applied
      const paidAmountField = parseFloat(purchase.paidAmount || "0");
      const totalSettled = Math.max(paidAmountField, paymentsSum + creditsSum);
      const isActuallyUnpaid = totalSettled === 0;

      // Group serials by product to show each product separately
      const productGroups = new Map<string, {
        product: any;
        purchaseItem: any;
        serials: any[];
      }>();

      for (const row of availableSerials) {
        const productId = row.product?.id || 'unknown';
        if (!productGroups.has(productId)) {
          productGroups.set(productId, {
            product: row.product,
            purchaseItem: row.purchaseItem,
            serials: [],
          });
        }
        productGroups.get(productId)!.serials.push({
          ...row.serial,
          productName: row.product?.name || "Unknown Product",
          unitPrice: row.purchaseItem?.unitPrice || "0.000",
        });
      }

      // Create an entry for each product in this purchase
      Array.from(productGroups.entries()).forEach(([productId, group]) => {
        purchaseData.push({
          ...purchase,
          // Use a composite ID to uniquely identify this purchase+product combo
          id: `${purchase.id}_${productId}`,
          originalPurchaseId: purchase.id,
          product: group.product,
          unitPrice: group.purchaseItem?.unitPrice || "0.000",
          availableQty: group.serials.length,
          creditBalance: supplierCredit?.creditBalance || "0.000",
          serials: group.serials,
          paidAmount: totalSettled.toFixed(3),
          isFullyUnpaid: isActuallyUnpaid,
          // Include discount, freight, and other charges for accurate return calculations
          discount: purchase.discount || "0.000",
          freight: purchase.freight || "0.000",
          freightCharges: purchase.freightCharges || "0.000",
          otherCharges: purchase.otherCharges || "0.000",
          subtotal: purchase.subtotal || "0.000",
          vatAmount: purchase.vatAmount || "0.000",
          purchaseTotal: purchase.total || "0.000",
        });
      });
    }

    return purchaseData;
  }

  async getAvailableSerialsForPurchase(purchaseId: string): Promise<SerialNumber[]> {
    return db.select().from(serialNumbers)
      .where(and(
        eq(serialNumbers.purchaseId, purchaseId),
        eq(serialNumbers.status, "available")
      ))
      .orderBy(asc(serialNumbers.serialNumber));
  }

  // Chart of Accounts helpers - Shop-scoped (must filter by shopId)
  private async getAccountByCode(code: string, shopId: string): Promise<ChartOfAccount | undefined> {
    const [account] = await db.select().from(chartOfAccounts).where(
      and(
        eq(chartOfAccounts.accountCode, code),
        eq(chartOfAccounts.shopId, shopId)
      )
    );
    return account || undefined;
  }

  // Create journal entry with balanced lines (double-entry accounting) - for use within transactions
  // shopId and branchId are mandatory for all journal entries per accounting scope rules
  private async createJournalEntryInTx(
    tx: any,
    data: {
      sourceType: string;
      sourceId: string;
      reference: string;
      description: string;
      shopId: string;
      branchId: string;
      projectId?: string;
      clientId?: string;
      taskId?: string;
      lines: Array<{ accountCode: string; debit?: number; credit?: number; description?: string; projectId?: string; clientId?: string; taskId?: string }>;
    }
  ): Promise<JournalEntry> {
    if (!data.shopId || !data.branchId) {
      throw new Error("shopId and branchId are required for all journal entries (accounting scope enforcement)");
    }

    const entryNumber = await this.getNextNumber("JE");

    const [entry] = await tx.insert(journalEntries).values({
      entryNumber,
      entryDate: new Date(),
      sourceType: data.sourceType,
      sourceId: data.sourceId,
      reference: data.reference,
      description: data.description,
      shopId: data.shopId,
      branchId: data.branchId,
      status: "posted",
    }).returning();

    // Insert journal lines and update account balances - MUST filter by shopId for data isolation
    for (const line of data.lines) {
      const [account] = await tx.select().from(chartOfAccounts).where(
        and(
          eq(chartOfAccounts.accountCode, line.accountCode),
          eq(chartOfAccounts.shopId, data.shopId)
        )
      );
      if (!account) {
        throw new Error(`Account code ${line.accountCode} not found in Chart of Accounts for shop ${data.shopId}. Please seed default accounts first.`);
      }

      const debitAmount = line.debit || 0;
      const creditAmount = line.credit || 0;

      await tx.insert(journalLines).values({
        journalEntryId: entry.id,
        accountId: account.id,
        debit: debitAmount.toFixed(3),
        credit: creditAmount.toFixed(3),
        description: line.description || null,
        projectId: line.projectId || data.projectId || null,
        clientId: line.clientId || data.clientId || null,
        taskId: line.taskId || data.taskId || null,
      });

      // Update account balance (assets/expenses: debit increases, liabilities/equity/revenue: credit increases)
      const currentBalance = parseFloat(account.balance || "0");
      let newBalance: number;
      if (account.accountType === "asset" || account.accountType === "expense") {
        newBalance = currentBalance + debitAmount - creditAmount;
      } else {
        newBalance = currentBalance + creditAmount - debitAmount;
      }
      await tx.update(chartOfAccounts).set({ balance: newBalance.toFixed(3) }).where(eq(chartOfAccounts.id, account.id));
    }

    return entry;
  }

  // Service Tickets
  async getServiceTickets(shopId?: string, filters?: { technicianId?: string; startDate?: Date; endDate?: Date; paymentStatus?: "paid" | "outstanding" }): Promise<ServiceTicket[]> {
    const conditions = [];
    if (shopId) conditions.push(eq(serviceTickets.shopId, shopId));
    if (filters?.technicianId) conditions.push(eq(serviceTickets.technicianId, filters.technicianId));
    if (filters?.startDate) conditions.push(sql`${serviceTickets.receivedDate} >= ${filters.startDate}`);
    if (filters?.endDate) conditions.push(sql`${serviceTickets.receivedDate} <= ${filters.endDate}`);
    if (filters?.paymentStatus === "paid") {
      conditions.push(sql`CAST(${serviceTickets.creditAmount} AS NUMERIC) <= 0`);
    } else if (filters?.paymentStatus === "outstanding") {
      conditions.push(sql`CAST(${serviceTickets.creditAmount} AS NUMERIC) > 0`);
    }

    if (conditions.length > 0) {
      return db.select().from(serviceTickets).where(and(...conditions)).orderBy(desc(serviceTickets.createdAt));
    }
    return db.select().from(serviceTickets).orderBy(desc(serviceTickets.createdAt));
  }

  async getServiceTicketsReport(filters: { 
    technicianId?: string; 
    startDate?: Date; 
    endDate?: Date; 
    paymentStatus?: "paid" | "outstanding";
    shopId?: string;
    branchId?: string
  }): Promise<ServiceTicket[]> {
    const conditions = [];
    if (filters.shopId) conditions.push(eq(serviceTickets.shopId, filters.shopId));
    if (filters.branchId) conditions.push(eq(serviceTickets.branchId, filters.branchId));
    if (filters.technicianId) conditions.push(eq(serviceTickets.technicianId, filters.technicianId));
    if (filters.startDate) conditions.push(sql`${serviceTickets.receivedDate} >= ${filters.startDate}`);
    if (filters.endDate) conditions.push(sql`${serviceTickets.receivedDate} <= ${filters.endDate}`);
    
    if (filters.paymentStatus === "paid") {
      conditions.push(sql`CAST(${serviceTickets.creditAmount} AS NUMERIC) <= 0`);
    } else if (filters.paymentStatus === "outstanding") {
      conditions.push(sql`CAST(${serviceTickets.creditAmount} AS NUMERIC) > 0`);
    }

    if (conditions.length > 0) {
      return db.select().from(serviceTickets).where(and(...conditions)).orderBy(desc(serviceTickets.receivedDate));
    }
    return db.select().from(serviceTickets).orderBy(desc(serviceTickets.receivedDate));
  }

  async getServiceTicket(id: string): Promise<ServiceTicket | undefined> {
    const [ticket] = await db.select().from(serviceTickets).where(eq(serviceTickets.id, id));
    return ticket || undefined;
  }

  async createServiceTicket(data: InsertServiceTicket): Promise<ServiceTicket> {
    const ticketNumber = await this.getNextTicketNumber("SV");

    // Calculate totals
    const serviceAmount = parseFloat(data.serviceAmount?.toString() || "0");
    const partsAmount = parseFloat(data.partsAmount?.toString() || "0");
    const vatAmount = parseFloat(data.vatAmount?.toString() || "0");
    const totalAmount = serviceAmount + partsAmount + vatAmount;
    const paidAmount = parseFloat(data.paidAmount?.toString() || "0");
    const creditAmount = parseFloat(data.creditAmount?.toString() || "0");

    // OVERPAYMENT VALIDATION: Block payment if it exceeds service amount
    if (paidAmount + creditAmount > totalAmount) {
      throw new Error(`Payment cannot exceed service amount. Total: ${totalAmount.toFixed(3)} RO, Attempted payment: ${(paidAmount + creditAmount).toFixed(3)} RO`);
    }

    // Determine payment status
    let paymentStatus = "pending";
    if (paidAmount >= totalAmount - 0.001 && totalAmount > 0) {
      paymentStatus = "paid";
    } else if (paidAmount > 0) {
      paymentStatus = "partial";
    }

    return await db.transaction(async (tx) => {
      const [ticket] = await tx.insert(serviceTickets).values({
        ...data,
        ticketNumber,
        totalAmount: totalAmount.toFixed(3),
        paidAmount: paidAmount.toFixed(3),
        creditAmount: creditAmount.toFixed(3),
        paymentStatus,
      }).returning();

      // If there's an initial payment, record it in serviceTicketPayments
      if (paidAmount > 0) {
        await tx.insert(serviceTicketPayments).values({
          serviceTicketId: ticket.id,
          customerId: ticket.customerId,
          shopId: ticket.shopId,
          branchId: ticket.branchId,
          paymentMethod: data.paymentMethod || "cash",
          bankAccountId: data.bankAccountId || null,
          amount: paidAmount.toFixed(3),
          notes: "Initial payment during ticket creation",
          reference: ticketNumber,
        });
      }

      await this.createServiceAccountingInTx(tx, ticket);
      return ticket;
    });
  }

  async getServiceTicketPayments(ticketId: string): Promise<ServiceTicketPayment[]> {
    return await db.select().from(serviceTicketPayments)
      .where(eq(serviceTicketPayments.serviceTicketId, ticketId))
      .orderBy(asc(serviceTicketPayments.paymentDate));
  }

  async addServiceTicketPayment(ticketId: string, paymentData: {
    amount: number;
    paymentMethod: string;
    bankAccountId?: string;
    notes?: string;
    processedBy?: string;
  }): Promise<{ payment: ServiceTicketPayment; ticket: ServiceTicket; receiptNumber: string }> {
    const ticket = await this.getServiceTicket(ticketId);
    if (!ticket) throw new Error("Service ticket not found");

    const totalAmount = parseFloat(ticket.totalAmount?.toString() || "0");
    const alreadyPaid = parseFloat(ticket.paidAmount?.toString() || "0");
    const remainingBalance = Math.max(0, totalAmount - alreadyPaid);

    if (paymentData.amount <= 0) throw new Error("Payment amount must be greater than 0");
    if (paymentData.amount > remainingBalance + 0.001) {
      throw new Error(`Payment (${paymentData.amount.toFixed(3)} RO) exceeds remaining balance (${remainingBalance.toFixed(3)} RO)`);
    }

    // Generate receipt ref
    const receiptNumber = `SV-RCP-${Date.now()}`;

    return await db.transaction(async (tx) => {
      // 1. Insert payment record
      const [payment] = await tx.insert(serviceTicketPayments).values({
        serviceTicketId: ticketId,
        customerId: ticket.customerId,
        shopId: ticket.shopId,
        branchId: ticket.branchId,
        paymentMethod: paymentData.paymentMethod,
        bankAccountId: paymentData.bankAccountId || null,
        amount: paymentData.amount.toFixed(3),
        notes: paymentData.notes || null,
        reference: receiptNumber,
        processedBy: paymentData.processedBy || null,
      }).returning();

      // 2. Recalculate total paid and update ticket
      const newPaidAmount = alreadyPaid + paymentData.amount;
      const newPaymentStatus = newPaidAmount >= totalAmount - 0.001 ? "paid" : "partial";
      const newCreditAmount = Math.max(0, totalAmount - newPaidAmount);

      const [updatedTicket] = await tx.update(serviceTickets)
        .set({
          paidAmount: newPaidAmount.toFixed(3),
          creditAmount: newCreditAmount.toFixed(3),
          paymentStatus: newPaymentStatus,
          paymentMethod: paymentData.paymentMethod,
          bankAccountId: paymentData.bankAccountId || ticket.bankAccountId,
          updatedAt: new Date(),
        })
        .where(eq(serviceTickets.id, ticketId))
        .returning();

      // 3. Bank account entry (if not credit)
      if (paymentData.bankAccountId && paymentData.paymentMethod !== "credit") {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, paymentData.bankAccountId));
        if (account) {
          await tx.insert(bankTransactions).values({
            bankAccountId: paymentData.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "deposit",
            amount: paymentData.amount.toFixed(3),
            reference: receiptNumber,
            description: `Service payment - ${ticket.ticketNumber}`,
            relatedType: "service_payment",
            relatedId: payment.id,
          });
          await tx.update(bankAccounts)
            .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${paymentData.amount}` })
            .where(eq(bankAccounts.id, paymentData.bankAccountId));
        }
      }

      // 4. Journal entries — proportional revenue & VAT split
      const serviceAmount = parseFloat(ticket.serviceAmount?.toString() || "0");
      const partsAmount = parseFloat(ticket.partsAmount?.toString() || "0");
      const vatAmount = parseFloat(ticket.vatAmount?.toString() || "0");
      const netRevenue = serviceAmount + partsAmount;
      const totalTicket = netRevenue + vatAmount;
      const vatRatio = totalTicket > 0 ? vatAmount / totalTicket : 0;
      const paymentForVat = paymentData.amount * vatRatio;
      const paymentForRevenue = paymentData.amount - paymentForVat;

      const debitAccount = paymentData.paymentMethod === "credit" ? "1100" : "1000";
      const debitDesc = paymentData.paymentMethod === "credit" ? "Accounts receivable for service" : "Cash/Bank received for service";

      const jLines: any[] = [
        { accountCode: debitAccount, debit: paymentData.amount, description: debitDesc },
      ];
      if (paymentForRevenue > 0) jLines.push({ accountCode: "4100", credit: paymentForRevenue, description: "Service revenue" });
      if (paymentForVat > 0) jLines.push({ accountCode: "2150", credit: paymentForVat, description: "VAT payable" });

      await this.createJournalEntryInTx(tx, {
        sourceType: "service_payment",
        sourceId: payment.id,
        shopId: ticket.shopId,
        branchId: ticket.branchId || ticket.shopId,
        reference: receiptNumber,
        description: `Service payment - ${ticket.ticketNumber}`,
        lines: jLines,
      });

      // 5. Update customer AR balance
      if (ticket.customerId) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, ticket.customerId));
        if (customer) {
          // If credit payment: increase AR. If cash/card clearing previous credit: decrease AR.
          if (paymentData.paymentMethod === "credit") {
            const newBal = parseFloat(customer.currentBalance || "0") + paymentData.amount;
            await tx.update(customers).set({ currentBalance: newBal.toFixed(3) }).where(eq(customers.id, ticket.customerId));
          } else if (parseFloat(customer.currentBalance || "0") > 0) {
            // Customer had outstanding balance, this cash pay reduces it
            const newBal = Math.max(0, parseFloat(customer.currentBalance || "0") - paymentData.amount);
            await tx.update(customers).set({ currentBalance: newBal.toFixed(3) }).where(eq(customers.id, ticket.customerId));
          }
        }
      }

      return { payment, ticket: updatedTicket, receiptNumber };
    });
  }

  private async getNextTicketNumber(prefix: string): Promise<string> {
    const result = await db.select({ count: sql<number>`count(*)` }).from(serviceTickets);
    const count = Number(result[0]?.count || 0);
    const num = (count + 1).toString().padStart(6, "0");
    return `${prefix}-${num}`;
  }

  async updateServiceTicket(id: string, data: Partial<InsertServiceTicket>): Promise<ServiceTicket | undefined> {
    const existingTicket = await this.getServiceTicket(id);
    if (!existingTicket) return undefined;

    const financialFields = ["serviceAmount", "partsAmount", "vatAmount", "paidAmount", "creditAmount", "bankAccountId"];
    const isFinancialUpdate = financialFields.some(field => field in data);

    return await db.transaction(async (tx) => {
      if (isFinancialUpdate) {
        // Reverse old accounting before applying updates
        await this.reverseServiceAccountingInTx(tx, id, existingTicket);
      }

      const updateData: any = { ...data, updatedAt: new Date() };
      
      // Automatically set actualReturnDate when status is changed to returned
      if (data.status === 'returned') {
        updateData.actualReturnDate = new Date();
      }

      // If we reversed accounting, we need to recalculate totals and re-create accounting
      // But first perform the update to get the new ticket state
      const [updated] = await tx.update(serviceTickets)
        .set(updateData)
        .where(eq(serviceTickets.id, id))
        .returning();

      if (updated) {
        const serviceAmount = parseFloat(updated.serviceAmount?.toString() || "0");
        const partsAmount = parseFloat(updated.partsAmount?.toString() || "0");
        const vatAmount = parseFloat(updated.vatAmount?.toString() || "0");
        const totalAmount = serviceAmount + partsAmount + vatAmount;
        const paidAmount = parseFloat(updated.paidAmount?.toString() || "0");

        let paymentStatus = "pending";
        if (paidAmount >= totalAmount - 0.001 && totalAmount > 0) {
          paymentStatus = "paid";
        } else if (paidAmount > 0) {
          paymentStatus = "partial";
        }

        const newCreditAmount = Math.max(0, totalAmount - paidAmount);

        const [finalTicket] = await tx.update(serviceTickets)
          .set({
            totalAmount: totalAmount.toFixed(3),
            creditAmount: newCreditAmount.toFixed(3),
            paymentStatus,
          })
          .where(eq(serviceTickets.id, id))
          .returning();

        if (isFinancialUpdate) {
          // Create new accounting entries based on updated ticket
          await this.createServiceAccountingInTx(tx, finalTicket);
        }
        return finalTicket;
      }

      return updated || undefined;
    });
  }

  // Refactor accounting creation logic to be reusable
  private async createServiceAccountingInTx(tx: any, ticket: ServiceTicket) {
    const serviceAmount = parseFloat(ticket.serviceAmount?.toString() || "0");
    const partsAmount = parseFloat(ticket.partsAmount?.toString() || "0");
    const vatAmount = parseFloat(ticket.vatAmount?.toString() || "0");
    const paidAmount = parseFloat(ticket.paidAmount?.toString() || "0");
    const creditAmount = parseFloat(ticket.creditAmount?.toString() || "0");

    if (paidAmount > 0) {
      // Re-insert a serviceTicketPayments record so customer statement can find it.
      // This is critical when called after an update (reversal wipes all payment records).
      await tx.insert(serviceTicketPayments).values({
        serviceTicketId: ticket.id,
        customerId: ticket.customerId || undefined,
        shopId: ticket.shopId || undefined,
        branchId: ticket.branchId || undefined,
        amount: paidAmount.toFixed(3),
        paymentMethod: ticket.paymentMethod || "cash",
        bankAccountId: ticket.bankAccountId || undefined,
        reference: ticket.ticketNumber,
        notes: `Payment re-recorded after ticket update`,
        paymentDate: new Date(),
      });

      if (ticket.bankAccountId) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, ticket.bankAccountId));
        if (account) {
          await tx.insert(bankTransactions).values({
            bankAccountId: ticket.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "deposit",
            amount: paidAmount.toFixed(3),
            reference: ticket.ticketNumber,
            description: `Service payment received - ${ticket.ticketNumber}`,
            relatedType: "service",
            relatedId: ticket.id,
          });

          await tx.update(bankAccounts)
            .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${paidAmount}` })
            .where(eq(bankAccounts.id, ticket.bankAccountId));
        }
      }

      const lines: any[] = [{ accountCode: "1000", debit: paidAmount, description: "Cash/Card received for service" }];
      const netServicePart = serviceAmount + partsAmount;
      const paidForService = Math.min(paidAmount, netServicePart);
      const paidForVat = paidAmount - paidForService;

      if (paidForService > 0) lines.push({ accountCode: "4100", credit: paidForService, description: "Service revenue" });
      if (paidForVat > 0) lines.push({ accountCode: "2150", credit: paidForVat, description: "VAT payable on service" });

      await this.createJournalEntryInTx(tx, {
        sourceType: "service",
        sourceId: ticket.id,
        shopId: ticket.shopId,
        branchId: ticket.branchId || ticket.shopId,
        reference: ticket.ticketNumber,
        description: `Service payment - ${ticket.ticketNumber}`,
        lines,
      });
    }

    if (creditAmount > 0 && ticket.customerId) {
      const [customer] = await tx.select().from(customers).where(eq(customers.id, ticket.customerId));
      if (customer) {
        const newBalance = parseFloat(customer.currentBalance || "0") + creditAmount;
        await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, ticket.customerId));
      }

      const creditLines: any[] = [{ accountCode: "1100", debit: creditAmount, description: "Accounts receivable for service" }];
      const netServicePart = serviceAmount + partsAmount;
      const creditForService = Math.min(creditAmount, netServicePart);
      const creditForVat = creditAmount - creditForService;

      if (creditForService > 0) creditLines.push({ accountCode: "4100", credit: creditForService, description: "Service revenue on credit" });
      if (creditForVat > 0) creditLines.push({ accountCode: "2150", credit: creditForVat, description: "VAT payable on service credit" });

      await this.createJournalEntryInTx(tx, {
        sourceType: "service",
        sourceId: ticket.id,
        shopId: ticket.shopId,
        branchId: ticket.branchId || ticket.shopId,
        reference: ticket.ticketNumber,
        description: `Service credit - ${ticket.ticketNumber}`,
        lines: creditLines,
      });
    }
  }

  private async reverseServiceAccountingInTx(tx: any, id: string, ticket: ServiceTicket) {
    // 1. Get all payment IDs for this ticket (for journal entry lookup)
    const ticketPayments = await tx.select().from(serviceTicketPayments)
      .where(eq(serviceTicketPayments.serviceTicketId, id));

    // 2. Reverse bank transactions linked to each payment
    for (const pmt of ticketPayments) {
      const bankTxns = await tx.select().from(bankTransactions)
        .where(and(eq(bankTransactions.relatedType, "service_payment"), eq(bankTransactions.relatedId, pmt.id)));
      for (const txn of bankTxns) {
        await tx.update(bankAccounts)
          .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) - ${parseFloat(txn.amount)}` })
          .where(eq(bankAccounts.id, txn.bankAccountId));
      }
      await tx.delete(bankTransactions)
        .where(and(eq(bankTransactions.relatedType, "service_payment"), eq(bankTransactions.relatedId, pmt.id)));

      // Reverse journal entries for each payment
      const pmtJournalEntries = await tx.select().from(journalEntries)
        .where(and(eq(journalEntries.sourceType, "service_payment"), eq(journalEntries.sourceId, pmt.id)));
      for (const entry of pmtJournalEntries) {
        const lines = await tx.select().from(journalLines).where(eq(journalLines.journalEntryId, entry.id));
        for (const line of lines) {
          const [account] = await tx.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, line.accountId));
          if (account) {
            const debit = parseFloat(line.debit || "0");
            const credit = parseFloat(line.credit || "0");
            const currentBalance = parseFloat(account.balance || "0");
            let newBalance: number;
            if (account.accountType === "asset" || account.accountType === "expense") {
              newBalance = currentBalance - debit + credit;
            } else {
              newBalance = currentBalance - credit + debit;
            }
            await tx.update(chartOfAccounts).set({ balance: newBalance.toFixed(3) }).where(eq(chartOfAccounts.id, account.id));
          }
        }
        await tx.delete(journalLines).where(eq(journalLines.journalEntryId, entry.id));
        await tx.delete(journalEntries).where(eq(journalEntries.id, entry.id));
      }
    }

    // 3. Delete all payment records for this ticket
    await tx.delete(serviceTicketPayments).where(eq(serviceTicketPayments.serviceTicketId, id));

    // 4. Also reverse any legacy bank transactions directly linked to the ticket (old relatedType: "service")
    const legacyBankTxns = await tx.select().from(bankTransactions)
      .where(and(eq(bankTransactions.relatedType, "service"), eq(bankTransactions.relatedId, id)));
    for (const txn of legacyBankTxns) {
      await tx.update(bankAccounts)
        .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) - ${parseFloat(txn.amount)}` })
        .where(eq(bankAccounts.id, txn.bankAccountId));
    }
    await tx.delete(bankTransactions).where(and(eq(bankTransactions.relatedType, "service"), eq(bankTransactions.relatedId, id)));

    // 5. Reverse Customer AR balance (full paid amount)
    const paidAmount = parseFloat(ticket.paidAmount?.toString() || "0");
    if (paidAmount > 0 && ticket.customerId) {
      const [customer] = await tx.select().from(customers).where(eq(customers.id, ticket.customerId));
      if (customer) {
        const newBalance = Math.max(0, parseFloat(customer.currentBalance || "0") - paidAmount);
        await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, ticket.customerId));
      }
    }

    // 6. Reverse any legacy journal entries directly linked to ticket (sourceId = ticket id)
    const legacyJournalEntries = await tx.select().from(journalEntries)
      .where(and(
        or(eq(journalEntries.sourceType, "service"), eq(journalEntries.sourceType, "service_payment")),
        eq(journalEntries.sourceId, id)
      ));
    for (const entry of legacyJournalEntries) {
      const lines = await tx.select().from(journalLines).where(eq(journalLines.journalEntryId, entry.id));
      for (const line of lines) {
        const [account] = await tx.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, line.accountId));
        if (account) {
          const debit = parseFloat(line.debit || "0");
          const credit = parseFloat(line.credit || "0");
          const currentBalance = parseFloat(account.balance || "0");
          let newBalance: number;
          if (account.accountType === "asset" || account.accountType === "expense") {
            newBalance = currentBalance - debit + credit;
          } else {
            newBalance = currentBalance - credit + debit;
          }
          await tx.update(chartOfAccounts).set({ balance: newBalance.toFixed(3) }).where(eq(chartOfAccounts.id, account.id));
        }
      }
      await tx.delete(journalLines).where(eq(journalLines.journalEntryId, entry.id));
      await tx.delete(journalEntries).where(eq(journalEntries.id, entry.id));
    }
  }

  async deleteServiceTicket(id: string): Promise<void> {
    const ticket = await this.getServiceTicket(id);
    if (!ticket) return;

    await db.transaction(async (tx) => {
      await this.reverseServiceAccountingInTx(tx, id, ticket);
      await tx.delete(serviceTickets).where(eq(serviceTickets.id, id));
    });
  }

  async repairServiceTicketPaymentRecord(ticketId: string): Promise<any> {
    const ticket = await this.getServiceTicket(ticketId);
    if (!ticket) throw new Error("Service ticket not found");

    const paidAmount = parseFloat(ticket.paidAmount?.toString() || "0");
    if (paidAmount <= 0) return { message: "No paid amount to repair", paidAmount: 0 };

    // Check if a payment record already exists
    const existing = await db.select().from(serviceTicketPayments)
      .where(eq(serviceTicketPayments.serviceTicketId, ticketId));
    if (existing.length > 0) {
      return { message: "Payment records already exist", count: existing.length, records: existing };
    }

    // Re-insert the missing payment record from the ticket's paidAmount field
    const [inserted] = await db.insert(serviceTicketPayments).values({
      serviceTicketId: ticketId,
      customerId: ticket.customerId || undefined,
      shopId: ticket.shopId || undefined,
      branchId: ticket.branchId || undefined,
      amount: paidAmount.toFixed(3),
      paymentMethod: ticket.paymentMethod || "cash",
      bankAccountId: ticket.bankAccountId || undefined,
      reference: ticket.ticketNumber,
      notes: "Payment record restored after ticket update",
      paymentDate: new Date(),
    }).returning();

    return { message: "Payment record restored", payment: inserted, ticketNumber: ticket.ticketNumber, amount: paidAmount };
  }

  // Seed default Chart of Accounts if not present
  async seedDefaultChartOfAccounts(shopId?: string, branchId?: string): Promise<{
    return { created: 0, existing: 0 };
  }

  // Seed missing account codes to ALL existing shops/branches (idempotent)
  async seedMissingAccountsToAllShops(): Promise<{
    return { totalCreated: 0, shopsProcessed: 0 };
  }

  // Record project expense with accounting entries
  async recordProjectExpense(projectId: string, data: {
    description: string;
    amount: number;
    category: string;
    paymentMethod: string;
    bankAccountId?: string | null;
    expenseDate?: Date;
  }): Promise<any> {
    return await db.transaction(async (tx) => {
      const [project] = await tx.select().from(projects).where(eq(projects.id, projectId));
      if (!project) throw new Error("Project not found");

      const expenseNumber = `EXP-${Date.now()}`;

      // Deduct from bank account only for bank/card payments (not cash)
      let bankAccount: { shopId: string; branchId: string } | null = null;
      const requiresBankDeduction = data.paymentMethod === "bank" || data.paymentMethod === "card" || data.paymentMethod === "transfer";
      if (requiresBankDeduction && data.bankAccountId && data.amount > 0) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          bankAccount = { shopId: account.shopId, branchId: account.branchId };
          const currentBalance = parseFloat(account.currentBalance || "0");
          const newBalance = currentBalance - data.amount;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "withdrawal",
            amount: data.amount.toFixed(3),
            reference: expenseNumber,
            description: `Project expense: ${data.description}`,
            relatedType: "project_expense",
            relatedId: projectId,
          });
        }
      }

      // Create accounting journal entry for project expense
      // Get shopId and branchId from project or bank account
      let projectShopId = project.shopId;
      let projectBranchId = project.branchId;

      if (!projectShopId && bankAccount) {
        projectShopId = bankAccount.shopId;
        projectBranchId = bankAccount.branchId;
      }
      if (!projectShopId) throw new Error("shopId is required for project expense journal entry");
      if (!projectBranchId && projectShopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, projectShopId)).limit(1);
        projectBranchId = branch?.id || projectShopId;
      }

      await this.createJournalEntryInTx(tx, {
        sourceType: "project_expense",
        sourceId: projectId,
        shopId: projectShopId,
        branchId: projectBranchId,
        reference: expenseNumber,
        description: `${data.category}: ${data.description} - Project: ${project.name}`,
        lines: [
          { accountCode: "6500", debit: data.amount, description: `Project expense - ${data.category}` },
          { accountCode: "1000", credit: data.amount, description: `Cash payment (${data.paymentMethod})` },
        ],
      });

      // Return project expense info
      const currentBudget = parseFloat(project.budget || "0");

      return {
        project: project.name,
        expenseNumber,
        amount: data.amount,
        budget: currentBudget
      };
    });
  }

  // Record general expense with accounting entries
  async recordGeneralExpense(data: {
    description: string;
    amount: number;
    category: string;
    paymentMethod: string;
    bankAccountId?: string | null;
    expenseDate?: Date;
  }): Promise<any> {
    return await db.transaction(async (tx) => {
      const expenseNumber = `GE-${Date.now()}`;

      // Deduct from bank account only for bank/card payments (not cash)
      const requiresBankDeduction = data.paymentMethod === "bank" || data.paymentMethod === "card" || data.paymentMethod === "transfer";
      if (requiresBankDeduction && data.bankAccountId && data.amount > 0) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          const currentBalance = parseFloat(account.currentBalance || "0");
          const newBalance = currentBalance - data.amount;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "withdrawal",
            amount: data.amount.toFixed(3),
            reference: expenseNumber,
            description: `Expense: ${data.description}`,
            relatedType: "general_expense",
            relatedId: expenseNumber,
          });
        }
      }

      // Map category to specific expense account
      let expenseAccountCode = "6000"; // Default to general expense
      if (data.category === "salary") expenseAccountCode = "6100";
      else if (data.category === "rent") expenseAccountCode = "6200";
      else if (data.category === "utilities") expenseAccountCode = "6300";
      else if (data.category === "supplies") expenseAccountCode = "6400";
      else if (data.category === "repairs") expenseAccountCode = "6600";
      else if (data.category === "marketing") expenseAccountCode = "6700";

      // Get shopId and branchId from bank account if provided
      let generalExpenseShopId: string | null = null;
      let generalExpenseBranchId: string | null = null;

      if (data.bankAccountId) {
        const [bankAccount] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (bankAccount) {
          generalExpenseShopId = bankAccount.shopId;
          generalExpenseBranchId = bankAccount.branchId;
        }
      }

      if (!generalExpenseShopId) {
        // Try to get from any bank account as fallback
        const [anyAccount] = await tx.select().from(bankAccounts).limit(1);
        if (anyAccount) {
          generalExpenseShopId = anyAccount.shopId;
          generalExpenseBranchId = anyAccount.branchId;
        }
      }
      if (!generalExpenseShopId) throw new Error("shopId is required for general expense journal entry. Please ensure a bank account with shopId exists.");
      if (!generalExpenseBranchId && generalExpenseShopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, generalExpenseShopId)).limit(1);
        generalExpenseBranchId = branch?.id || generalExpenseShopId;
      }

      await this.createJournalEntryInTx(tx, {
        sourceType: "general_expense",
        sourceId: expenseNumber,
        shopId: generalExpenseShopId,
        branchId: generalExpenseBranchId,
        reference: expenseNumber,
        description: `${data.category}: ${data.description}`,
        lines: [
          { accountCode: expenseAccountCode, debit: data.amount, description: data.description },
          { accountCode: "1000", credit: data.amount, description: `Cash payment (${data.paymentMethod})` },
        ],
      });

      return { expenseNumber, amount: data.amount, category: data.category };
    });
  }

  // CRM Leads
  async getCrmLeads(): Promise<CrmLead[]> {
    return db.select().from(crmLeads).orderBy(desc(crmLeads.createdAt));
  }

  async getCrmLead(id: string): Promise<CrmLead | undefined> {
    const [lead] = await db.select().from(crmLeads).where(eq(crmLeads.id, id));
    return lead || undefined;
  }

  async createCrmLead(data: InsertCrmLead): Promise<CrmLead> {
    const [lead] = await db.insert(crmLeads).values(data).returning();
    return lead;
  }

  async updateCrmLead(id: string, data: Partial<InsertCrmLead>): Promise<CrmLead | undefined> {
    const [updated] = await db.update(crmLeads)
      .set({ ...data, updatedAt: new Date() })
      .where(eq(crmLeads.id, id))
      .returning();
    return updated || undefined;
  }

  async deleteCrmLead(id: string): Promise<void> {
    await db.delete(crmLeads).where(eq(crmLeads.id, id));
  }

  async convertLeadToCustomer(leadId: string): Promise<{ lead: CrmLead; customerId: string }> {
    return await db.transaction(async (tx) => {
      const [lead] = await tx.select().from(crmLeads).where(eq(crmLeads.id, leadId));
      if (!lead) throw new Error("Lead not found");
      if (lead.convertedToCustomerId) throw new Error("Lead already converted to customer");

      const [customer] = await tx.insert(customers).values({
        name: lead.companyName || lead.name,
        contactEmail: lead.email,
        phone: lead.phone,
        status: "active",
        additionalDetails: lead.companyName ? `Contact: ${lead.name}` : undefined,
      }).returning();

      const [updatedLead] = await tx.update(crmLeads)
        .set({
          status: "qualified",
          convertedToCustomerId: customer.id,
          convertedAt: new Date(),
          updatedAt: new Date(),
        })
        .where(eq(crmLeads.id, leadId))
        .returning();

      return { lead: updatedLead, customerId: customer.id };
    });
  }

  // CRM Deals
  async getCrmDeals(): Promise<CrmDeal[]> {
    return db.select().from(crmDeals).orderBy(desc(crmDeals.createdAt));
  }

  async getCrmDeal(id: string): Promise<CrmDeal | undefined> {
