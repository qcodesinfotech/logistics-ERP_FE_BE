    }
    if (scope?.branchId) {
      conditions.push(eq(pettyCash.branchId, scope.branchId));
    }
    if (conditions.length > 0) {
      return db.select().from(pettyCash).where(and(...conditions));
    }
    return db.select().from(pettyCash);
