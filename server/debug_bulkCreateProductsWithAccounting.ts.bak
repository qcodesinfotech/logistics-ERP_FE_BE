  // Purchase Orders
  async getPurchaseOrders(): Promise<PurchaseOrder[]> {
    return db.select().from(purchaseOrders).orderBy(desc(purchaseOrders.orderDate));
  }

  async getPurchaseOrder(id: string): Promise<PurchaseOrder | undefined> {
    const [order] = await db.select().from(purchaseOrders).where(eq(purchaseOrders.id, id));
    return order || undefined;
  }

  async getPurchaseOrderWithItems(id: string): Promise<{ order: PurchaseOrder; items: PurchaseOrderItem[] } | undefined> {
    const [order] = await db.select().from(purchaseOrders).where(eq(purchaseOrders.id, id));
    if (!order) return undefined;

    const items = await db.select().from(purchaseOrderItems).where(eq(purchaseOrderItems.purchaseOrderId, id));
    return { order, items };
  }

  async createPurchaseOrder(data: any, items: any[]): Promise<PurchaseOrder> {
    const orderNumber = await this.getNextNumber("PO");

    return await db.transaction(async (tx) => {
      const orderData = {
        orderNumber,
        supplierId: data.supplierId,
        shopId: data.shopId || null,
        branchId: data.branchId || null,
        warehouseId: data.warehouseId || null,
        status: data.status || "pending",
        subtotal: data.subtotal?.toString() || "0.000",
        vatAmount: data.vatAmount?.toString() || "0.000",
        discount: data.discount?.toString() || "0.000",
        freight: data.freight?.toString() || "0.000",
        total: data.total?.toString() || "0.000",
        notes: data.notes || null,
      };

      const [order] = await tx.insert(purchaseOrders).values(orderData).returning();

      for (const item of items) {
        await tx.insert(purchaseOrderItems).values({
          purchaseOrderId: order.id,
          productId: item.productId,
          quantity: item.quantity,
          unitPrice: item.unitPrice?.toString() || "0.000",
          vatRate: item.vatRate?.toString() || "5.00",
          discount: item.discount?.toString() || "0.000",
          total: item.total?.toString() || "0.000",
          warehouseId: item.warehouseId || null,
          salesRate: item.salesRate?.toString() || null,
          boxSalesRate: item.boxSalesRate?.toString() || null,
          manufacturingDate: item.manufacturingDate || null,
          expiryDate: item.expiryDate || null,
          warrantyMonths: item.warrantyMonths || null,
          storageType: item.storageType || null,
        });
      }

      return order;
    });
  }

  async updatePurchaseOrderStatus(id: string, status: string): Promise<PurchaseOrder | undefined> {
    const [order] = await db.update(purchaseOrders).set({ status }).where(eq(purchaseOrders.id, id)).returning();
    return order || undefined;
  }

  // Purchases
  async getPurchases(scope?: { companyId?: string | null; shopId?: string | null; branchId?: string | null } | null): Promise<Purchase[]> {
    const conditions = [];

    // SECURITY: If scope is provided but has no valid company or shop, return empty to prevent data leakage
    if (scope && !scope.companyId && !scope.shopId) {
      return [];
    }

    // If companyId is provided but shopId is not, get shops for that company and filter by those
    if (scope?.companyId && !scope?.shopId) {
      const companyShops = await db.select({ id: shops.id }).from(shops).where(eq(shops.companyId, scope.companyId));
      const shopIds = companyShops.map(s => s.id);
      if (shopIds.length > 0) {
        conditions.push(or(inArray(purchases.shopId, shopIds), sql`${purchases.shopId} IS NULL`));
      } else {
        return [];
      }
    } else if (scope?.shopId) {
      conditions.push(or(eq(purchases.shopId, scope.shopId), sql`${purchases.shopId} IS NULL`));
    }
    if (scope?.branchId) {
      conditions.push(or(eq(purchases.branchId, scope.branchId), sql`${purchases.branchId} IS NULL`));
    }
    if (conditions.length > 0) {
      return db.select().from(purchases).where(and(...conditions)).orderBy(desc(purchases.purchaseDate));
    }
    return db.select().from(purchases).orderBy(desc(purchases.purchaseDate));
  }

  async getPurchase(id: string): Promise<Purchase | undefined> {
    const [purchase] = await db.select().from(purchases).where(eq(purchases.id, id));
    return purchase || undefined;
  }

  async getPurchaseWithItems(id: string): Promise<{ purchase: Purchase; items: any[] } | undefined> {
    const [purchase] = await db.select().from(purchases).where(eq(purchases.id, id));
    if (!purchase) return undefined;

    // Join with products to get product name and SKU
    const items = await db.select({
      id: purchaseItems.id,
      purchaseId: purchaseItems.purchaseId,
      productId: purchaseItems.productId,
      quantity: purchaseItems.quantity,
      unitPrice: purchaseItems.unitPrice,
      vatRate: purchaseItems.vatRate,
      discount: purchaseItems.discount,
      total: purchaseItems.total,
      warrantyMonths: purchaseItems.warrantyMonths,
      serialNumbers: purchaseItems.serialNumbers,
      productName: products.name,
      productSku: products.sku,
    }).from(purchaseItems)
      .leftJoin(products, eq(purchaseItems.productId, products.id))
      .where(eq(purchaseItems.purchaseId, id));
    return { purchase, items };
  }

  
  async deletePurchase(id: string): Promise<void> {
    await db.transaction(async (tx) => {
      // 1. Get the purchase and items
      const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, id));
      if (!purchase) return;

      const items = await tx.select().from(purchaseItems).where(eq(purchaseItems.purchaseId, id));

      // 2. ─── ACCOUNTING REVERSALS ─────────────────────────────────────────
      const totalAmount  = parseFloat(purchase.total     || "0");
      const vatAmount    = parseFloat(purchase.vatAmount  || "0");
      const paidAmount   = parseFloat(purchase.paidAmount || "0");
      const netCost      = totalAmount - vatAmount;

      // 2a. Reverse bank account balance (return what was paid out)
      if (paidAmount > 0 && purchase.bankAccountId) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, purchase.bankAccountId));
        if (account) {
          const newBalance = parseFloat(account.currentBalance || "0") + paidAmount;
          await tx.update(bankAccounts)
            .set({ currentBalance: newBalance.toFixed(3) })
            .where(eq(bankAccounts.id, purchase.bankAccountId));

          await tx.insert(bankTransactions).values({
            bankAccountId: purchase.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId || account.shopId,
            type: "deposit",
            amount: paidAmount.toFixed(3),
            reference: purchase.purchaseNumber,
            description: `Reversal: Purchase deleted ${purchase.purchaseNumber}`,
            relatedType: "purchase_deletion",
            relatedId: purchase.id,
          });
        }
      }

      // 2b. Reverse supplier balance if on credit
      const creditAmount = totalAmount - paidAmount;
      if (purchase.supplierId && creditAmount > 0) {
        const [supplier] = await tx.select().from(suppliers).where(eq(suppliers.id, purchase.supplierId));
        if (supplier) {
          const newBalance = parseFloat(String(supplier.currentBalance || "0")) - creditAmount;
          await tx.update(suppliers)
            .set({ currentBalance: newBalance.toFixed(3) })
            .where(eq(suppliers.id, purchase.supplierId));
        }
      }

      // 2c. Create reversal journal entry (opposite of original purchase entry)
      const reversalLines: Array<{ accountCode: string; debit?: number; credit?: number; description?: string }> = [];

      if (paidAmount > 0) {
        reversalLines.push({ accountCode: "1000", debit: paidAmount, description: "Reverse: Cash paid on deleted purchase" });
      }
      if (creditAmount > 0) {
        reversalLines.push({ accountCode: "2100", debit: creditAmount, description: "Reverse: Accounts payable on deleted purchase" });
      }
      if (netCost > 0) {
        reversalLines.push({ accountCode: "1200", credit: netCost, description: "Reverse: Inventory asset on deleted purchase" });
      }
      if (vatAmount > 0) {
        reversalLines.push({ accountCode: "2160", credit: vatAmount, description: "Reverse: VAT input on deleted purchase" });
      }

      if (reversalLines.length > 0) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "purchase_deletion",
          sourceId: purchase.id,
          shopId: purchase.shopId,
          branchId: purchase.branchId || purchase.shopId,
          reference: purchase.purchaseNumber,
          description: `Reversal: Purchase deleted ${purchase.purchaseNumber}`,
          lines: reversalLines,
        });
      }

      // 3. Reduce inventory for each item
      for (const item of items) {
        const [inv] = await tx.select().from(inventory).where(
          and(
            eq(inventory.productId, item.productId),
            eq(inventory.warehouseId, purchase.warehouseId)
          )
        );

        if (inv) {
          await tx.update(inventory)
            .set({ quantity: Math.max(0, inv.quantity - item.quantity) })
            .where(eq(inventory.id, inv.id));
        }

        // Remove serial numbers related to this purchase item
        const itemSerials = await tx.select().from(serialNumbers).where(eq(serialNumbers.purchaseItemId, item.id));
        for (const serial of itemSerials) {
          await tx.delete(serialNumbers).where(eq(serialNumbers.id, serial.id));
        }
      }

      // 4. Delete supporting records
      await tx.delete(purchaseItems).where(eq(purchaseItems.purchaseId, id));
      await tx.delete(purchasePayments).where(eq(purchasePayments.purchaseId, id));

      // 5. Delete original journal entries for this purchase
      await tx.delete(journalEntries).where(and(eq(journalEntries.sourceType, "purchase"), eq(journalEntries.sourceId, id)));

      // 6. Delete purchase
      await tx.delete(purchases).where(eq(purchases.id, id));
    });
  }


  async createPurchase(data: any, items: any[]): Promise<Purchase> {
    const purchaseNumber = await this.getNextNumber("PU");
    const paidAmount = parseFloat(data.paidAmount || "0");
    const appliedCredit = parseFloat(data.appliedCredit || "0");

    // STRICT ERP VALIDATION: Prevent bank transactions when only credit is applied
    // Credit application is an internal ledger offset, NOT a bank withdrawal
    if (appliedCredit > 0 && paidAmount === 0 && data.bankAccountId) {
      throw new Error("VALIDATION ERROR: Bank account should not be provided when only credit is applied. Credit application is not a cash payment.");
    }

    // Enforce bankAccountId when making payment
    if (paidAmount > 0 && !data.bankAccountId) {
      throw new Error("Bank account is required when making payment. Please select a bank account.");
    }

    // STRICT FINANCIAL CONTROL: Validate sufficient funds before purchase payment
    if (paidAmount > 0) {
      await this.ensureSufficientFunds(paidAmount, data.bankAccountId, "purchase payment");
    }

    return await db.transaction(async (tx) => {
      // Pre-calculate applied credit to store in purchase record
      let appliedCreditToStore = parseFloat(data.appliedCredit || "0");
      if (appliedCreditToStore > 0) {
        const [existingCredit] = await tx.select().from(supplierCredits).where(eq(supplierCredits.supplierId, data.supplierId));
        if (existingCredit) {
          const currentCredit = parseFloat(existingCredit.creditBalance || "0");
          if (appliedCreditToStore > currentCredit) {
            appliedCreditToStore = currentCredit;
          }
        } else {
          appliedCreditToStore = 0;
        }
      }

      // STRICT ERP PAYMENT STATUS CALCULATION
      // Based on actual amounts, not frontend-passed status
      const totalAmount = parseFloat(data.total || "0");
      const totalSettled = paidAmount + appliedCreditToStore;
      let computedPaymentStatus: string;
      if (totalSettled >= totalAmount - 0.001) {
        computedPaymentStatus = "paid"; // Fully settled (by payment, credit, or both)
      } else if (paidAmount === 0 && appliedCreditToStore > 0) {
        computedPaymentStatus = "credit_adjusted"; // Only credit applied, no cash
      } else if (paidAmount > 0 && totalSettled < totalAmount) {
        computedPaymentStatus = "partial"; // Partial cash payment
      } else {
        computedPaymentStatus = "pending"; // No payment or credit
      }

      const purchaseData = {
        purchaseNumber,
        supplierId: data.supplierId,
        shopId: data.shopId,
        branchId: data.branchId || null,
        warehouseId: data.warehouseId || null,
        paymentStatus: computedPaymentStatus,
        paymentMethod: data.paymentMethod || null,
        bankAccountId: paidAmount > 0 ? (data.bankAccountId || null) : null, // Only set if actual payment
        paidAmount: data.paidAmount?.toString() || "0.000",
        creditApplied: appliedCreditToStore.toFixed(3),
        subtotal: data.subtotal?.toString() || "0.000",
        vatAmount: data.vatAmount?.toString() || "0.000",
        discount: data.discount?.toString() || "0.000",
        freight: data.freight?.toString() || "0.000",
        total: data.total?.toString() || "0.000",
        invoiceNo: data.invoiceNo || null,
        invoiceDate: data.invoiceDate || null,
        otherCharges: data.otherCharges?.toString() || "0.000",
        previousDue: data.previousDue?.toString() || "0.000",
        purchaseOrderId: data.purchaseOrderId || null,
        file: data.file || null,
      };

      const [purchase] = await tx.insert(purchases).values(purchaseData).returning();

      // Update bank account balance when paying for purchase
      if (paidAmount > 0 && data.bankAccountId) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          const currentBalance = parseFloat(account.currentBalance || "0");
          const newBalance = currentBalance - paidAmount;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

          // Record bank transaction
          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "withdrawal",
            amount: paidAmount.toFixed(3),
            reference: purchaseNumber,
            description: `Payment for purchase ${purchaseNumber}`,
            relatedType: "purchase",
            relatedId: purchase.id,
          });

          // Record initial payment in purchasePayments table for payment history
          const paymentRef = await this.getNextNumber("PAY");
          await tx.insert(purchasePayments).values({
            purchaseId: purchase.id,
            supplierId: data.supplierId,
            amount: paidAmount.toFixed(3),
            paymentMethod: data.paymentMethod || "cash",
            bankAccountId: data.bankAccountId,
            reference: paymentRef,
            notes: `Initial payment at purchase time`,
            shopId: data.shopId,
            branchId: data.branchId,
          });
        }
      }

      // Insert purchase items and update inventory (FIFO - each batch is separate)
      for (const item of items) {
        console.log(`[DEBUG] Purchase item for product ${item.productId}:`, {
          quantity: item.quantity,
          serialNumbers: item.serialNumbers,
          serialNumbersLength: item.serialNumbers?.length || 0
        });

        const [purchaseItem] = await tx.insert(purchaseItems).values({
          purchaseId: purchase.id,
          productId: item.productId,
          quantity: item.quantity,
          unitPrice: item.unitPrice?.toString() || "0.000",
          vatRate: item.vatRate?.toString() || "5.00",
          discount: item.discount?.toString() || "0.000",
          total: item.total?.toString() || "0.000",
          serialNumber: item.serialNumbers?.join(", ") || null,
          salesRate: item.salesRate?.toString() || null,
          boxSalesRate: item.boxSalesRate?.toString() || null,
          warrantyMonths: item.warrantyMonths || null,
          storageType: item.storageType || null,
          manufacturingDate: item.manufacturingDate || null,
          expiryDate: item.expiryDate || null,
        }).returning();

        // Create serial numbers in database with cost and selling prices
        if (item.serialNumbers && item.serialNumbers.length > 0) {
          const serialsToCreate = item.serialNumbers.map((serialNum: string) => ({
            serialNumber: serialNum,
            productId: item.productId,
            warehouseId: data.warehouseId || null,
            shopId: data.shopId || null,
            purchaseId: purchase.id,
            purchaseItemId: purchaseItem.id,
            costPrice: item.unitPrice?.toString() || null,
            sellingPrice: item.salesRate?.toString() || null,
            status: "available",
          }));
          await tx.insert(serialNumbers).values(serialsToCreate);
        }

        // Add to inventory (FIFO - each purchase creates a new batch)
        if (data.warehouseId) {
          await tx.insert(inventory).values({
            productId: item.productId,
            warehouseId: data.warehouseId,
            branchId: data.branchId || null,
            quantity: item.quantity,
            costPrice: item.unitPrice?.toString() || "0.000",
          });
        }
      }

      // Handle applied credit (tally) from supplier credit balance
      // CRITICAL: appliedCreditToStore was already validated above and stored in purchase record
      let appliedCredit = appliedCreditToStore;
      if (appliedCredit > 0) {
        const [existingCredit] = await tx.select().from(supplierCredits).where(eq(supplierCredits.supplierId, data.supplierId));
        if (existingCredit) {
          const currentCredit = parseFloat(existingCredit.creditBalance || "0");
          const newCreditBalance = (currentCredit - appliedCredit).toFixed(3);

          await tx.update(supplierCredits)
            .set({ creditBalance: newCreditBalance, lastUpdated: new Date() })
            .where(eq(supplierCredits.id, existingCredit.id));

          // Record credit APPLIED to purchase (NOT a payment - internal ledger offset only)
          // This creates an immutable transaction row for supplier transactions report
          await tx.insert(supplierCreditTransactions).values({
            supplierId: data.supplierId,
            shopId: data.shopId || null,
            purchaseReturnId: null,
            purchaseId: purchase.id,
            transactionType: "credit_applied",
            amount: appliedCredit.toFixed(3),
            balanceAfter: newCreditBalance,
            description: `Credit applied to purchase ${purchaseNumber}`,
          });
        }
      }

      // Update supplier balance (what we owe them)
      const [supplier] = await tx.select().from(suppliers).where(eq(suppliers.id, data.supplierId));
      if (supplier) {
        // Net amount we owe = total - paidAmount - appliedCredit
        const netOwed = parseFloat(data.total || "0") - parseFloat(data.paidAmount || "0") - appliedCredit;
        const newBalance = parseFloat(supplier.currentBalance || "0") + netOwed;
        await tx.update(suppliers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(suppliers.id, data.supplierId));
      }

      // Update purchase order status if linked
      if (data.purchaseOrderId) {
        await tx.update(purchaseOrders).set({ status: "converted" }).where(eq(purchaseOrders.id, data.purchaseOrderId));
      }

      // Create accounting journal entries for purchase
      // STRICT DOUBLE-ENTRY ACCOUNTING:
      // A. Purchase Entry (ALWAYS full amount):
      //    DR Inventory/Expense   [total]
      //    CR Supplier Payable    [total]
      // B. Credit Adjustment (if credit applied - NOT a payment):
      //    DR Supplier Payable    [credit]
      //    CR Supplier Credit     [credit]
      // C. Payment Entry (ONLY if actual cash/bank paid):
      //    DR Supplier Payable    [paid]
      //    CR Cash/Bank           [paid]

      const subtotal = parseFloat(data.subtotal || "0");
      const vatAmount = parseFloat(data.vatAmount || "0");
      const discount = parseFloat(data.discount || "0");
      const freight = parseFloat(data.freight || "0");
      const otherCharges = parseFloat(data.otherCharges || "0");
      const journalTotalAmount = parseFloat(data.total || "0");

      // Net inventory cost = subtotal - discount + freight + other charges
      const inventoryCost = Math.max(0, subtotal - discount + freight + otherCharges);

      const journalLines: Array<{ accountCode: string; debit?: number; credit?: number; description?: string }> = [];

      // A. PURCHASE ENTRY - Debit Inventory (1200) for net cost
      if (inventoryCost > 0) {
        journalLines.push({ accountCode: "1200", debit: inventoryCost, description: "Inventory purchase" });
      }

      // Debit VAT Input (2150)
      if (vatAmount > 0) {
        journalLines.push({ accountCode: "2150", debit: vatAmount, description: "VAT on purchase (input)" });
      }

      // A. PURCHASE ENTRY - Credit Supplier Payable (2000) for FULL purchase amount
      // This is the FULL liability - always record full purchase amount
      if (journalTotalAmount > 0) {
        journalLines.push({ accountCode: "2000", credit: journalTotalAmount, description: "Supplier payable - full purchase amount" });
      }

      // B. CREDIT ADJUSTMENT - If supplier credit is applied (NOT a payment, internal offset only)
      // DR Supplier Payable (2000) - reduces what we owe
      // CR Supplier Receivable (1110) - reduces the receivable (credit) the supplier owed us
      // CRITICAL: NO Bank/Cash entry for credit application
      if (appliedCredit > 0) {
        journalLines.push({ accountCode: "2000", debit: appliedCredit, description: "Credit adjustment - reduces supplier payable" });
        journalLines.push({ accountCode: "1110", credit: appliedCredit, description: "Supplier credit applied to purchase" });
      }

      // C. PAYMENT ENTRY - ONLY if actual cash/bank is paid
      // DR Supplier Payable (2000) - reduces what we owe
      // CR Cash/Bank (1000) - actual money paid
      if (paidAmount > 0) {
        journalLines.push({ accountCode: "2000", debit: paidAmount, description: "Payment to supplier" });
        journalLines.push({ accountCode: "1000", credit: paidAmount, description: "Cash/Bank payment to supplier" });
      }

      if (journalLines.length > 0) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "purchase",
          sourceId: purchase.id,
          shopId: purchase.shopId,
          branchId: purchase.branchId || purchase.shopId,
          reference: purchaseNumber,
          description: `Purchase from supplier - ${purchaseNumber}`,
          lines: journalLines,
        });
      }

      return purchase;
    });
  }

  async getPurchasePayments(purchaseId: string): Promise<any[]> {
    return db.select().from(purchasePayments).where(eq(purchasePayments.purchaseId, purchaseId)).orderBy(desc(purchasePayments.paidAt));
  }

  async createPurchasePayment(data: { purchaseId: string; amount: number; paymentMethod: string; bankAccountId: string; notes?: string }): Promise<any> {
    const paymentAmount = data.amount;

    if (!data.bankAccountId) {
      throw new Error("Bank account is required for purchase payment.");
    }

    if (paymentAmount <= 0) {
      throw new Error("Payment amount must be greater than zero.");
    }

    await this.ensureSufficientFunds(paymentAmount, data.bankAccountId, "purchase payment");

    // LEDGER-DRIVEN: Calculate invoice outstanding from payment records
    const invoiceOutstanding = await this.getPurchaseOutstanding(data.purchaseId);

    if (invoiceOutstanding.outstandingAmount <= 0.001) {
      throw new Error("This invoice is already fully paid. No payment can be recorded.");
    }

    if (paymentAmount > invoiceOutstanding.outstandingAmount + 0.001) {
      throw new Error(`Payment amount (${paymentAmount.toFixed(3)} RO) exceeds invoice outstanding balance (${invoiceOutstanding.outstandingAmount.toFixed(3)} RO)`);
    }

    return await db.transaction(async (tx) => {
      const [purchase] = await tx.select().from(purchases).where(eq(purchases.id, data.purchaseId));
      if (!purchase) throw new Error("Purchase not found");

      // Get supplierId from the purchase record - never trust client-supplied supplierId
      const supplierId = purchase.supplierId;
      if (!supplierId) throw new Error("Purchase has no associated supplier");

      // VALIDATION: Check supplier total outstanding to prevent overpayment
      const supplierLedger = await this.getSupplierLedgerSummary(supplierId);
      if (supplierLedger.outstandingPayable <= 0) {
        throw new Error("Supplier has no outstanding payable balance. Payment cannot be processed.");
      }

      if (paymentAmount > supplierLedger.outstandingPayable + 0.001) {
        throw new Error(`Payment amount (${paymentAmount.toFixed(3)} RO) exceeds supplier outstanding balance (${supplierLedger.outstandingPayable.toFixed(3)} RO)`);
      }

      const actualPayment = Math.min(paymentAmount, invoiceOutstanding.outstandingAmount);

      // Calculate new totals from ledger after this payment
      const newTotalPaid = invoiceOutstanding.totalPaid + actualPayment;
      const newPaymentStatus = newTotalPaid >= invoiceOutstanding.invoiceTotal - 0.001 ? "paid" : "partial";

      // Update purchase record to reflect ledger-calculated values
      await tx.update(purchases).set({
        paidAmount: newTotalPaid.toFixed(3),
        paymentStatus: newPaymentStatus,
        updateDate: new Date(),
      }).where(eq(purchases.id, data.purchaseId));

      const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
      if (account) {
        const currentBalance = parseFloat(account.currentBalance || "0");
        const newBalance = currentBalance - actualPayment;
        await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

        await tx.insert(bankTransactions).values({
          bankAccountId: data.bankAccountId,
          shopId: account.shopId,
          branchId: account.branchId,
          type: "withdrawal",
          amount: actualPayment.toFixed(3),
          reference: purchase.purchaseNumber,
          description: `Payment for purchase ${purchase.purchaseNumber}`,
          relatedType: "purchase_payment",
          relatedId: data.purchaseId,
        });
      }

      // Update supplier balance (reduce payable)
      const [supplier] = await tx.select().from(suppliers).where(eq(suppliers.id, supplierId));
      if (supplier) {
        const currentSupplierBalance = parseFloat(supplier.currentBalance || "0");
        const newSupplierBalance = currentSupplierBalance - actualPayment;
        await tx.update(suppliers).set({ currentBalance: newSupplierBalance.toFixed(3) }).where(eq(suppliers.id, supplierId));
      }

      const [payment] = await tx.insert(purchasePayments).values({
        purchaseId: data.purchaseId,
        supplierId: supplierId,
        amount: actualPayment.toFixed(3),
        paymentMethod: data.paymentMethod,
        bankAccountId: data.bankAccountId,
        notes: data.notes,
        reference: purchase.purchaseNumber,
      }).returning();

      const paymentRef = await this.getNextNumber("PP");
      await this.createJournalEntryInTx(tx, {
        sourceType: "purchase_payment",
        sourceId: payment.id,
        shopId: account.shopId,
        branchId: account.branchId,
        reference: paymentRef,
        description: `Payment for purchase ${purchase.purchaseNumber}`,
        lines: [
          { accountCode: "2000", debit: actualPayment, description: "Reduce accounts payable" },
          { accountCode: "1000", credit: actualPayment, description: "Cash payment to supplier" },
        ],
      });

      return payment;
    });
  }

  // Sales
  async getSales(scope?: { companyId?: string | null; shopId?: string | null; branchId?: string | null } | null): Promise<Sale[]> {
    const conditions = [];

    // SECURITY: If scope is provided but has no valid company or shop, return empty to prevent data leakage
    if (scope && !scope.companyId && !scope.shopId) {
      return [];
    }

    // If companyId is provided but shopId is not, get shops for that company and filter by those
    if (scope?.companyId && !scope?.shopId) {
      const companyShops = await db.select({ id: shops.id }).from(shops).where(eq(shops.companyId, scope.companyId));
      const shopIds = companyShops.map(s => s.id);
      if (shopIds.length > 0) {
        conditions.push(or(inArray(sales.shopId, shopIds), sql`${sales.shopId} IS NULL`));
      } else {
        return [];
      }
    } else if (scope?.shopId) {
      conditions.push(or(eq(sales.shopId, scope.shopId), sql`${sales.shopId} IS NULL`));
    }
    if (scope?.branchId) {
      conditions.push(or(eq(sales.branchId, scope.branchId), sql`${sales.branchId} IS NULL`));
    }
    if (conditions.length > 0) {
      return db.select().from(sales).where(and(...conditions)).orderBy(desc(sales.saleDate));
    }
    return db.select().from(sales).orderBy(desc(sales.saleDate));
  }

  async getSale(id: string): Promise<Sale | undefined> {
    const [sale] = await db.select().from(sales).where(eq(sales.id, id));
    return sale || undefined;
  }

  
  async updateSaleMetadata(id: string, data: { lpoNumber?: string; paymentStatus?: string; notes?: string }): Promise<any> {
    const updateData: any = {};
    if (data.lpoNumber !== undefined) updateData.lpoNumber = data.lpoNumber;
    if (data.paymentStatus !== undefined) updateData.paymentStatus = data.paymentStatus;
    if (data.notes !== undefined) updateData.notes = data.notes;

    const [updated] = await db.update(sales)
      .set(updateData)
      .where(eq(sales.id, id))
      .returning();
    return updated;
  }

  async deleteSale(id: string): Promise<void> {
    await db.transaction(async (tx) => {
      // 1. Get the sale
      const [sale] = await tx.select().from(sales).where(eq(sales.id, id));
      if (!sale) return;

      const items = await tx.select().from(saleItems).where(eq(saleItems.saleId, id));

      // 2. ─── ACCOUNTING REVERSALS ─────────────────────────────────────────
      const totalAmount    = parseFloat(sale.total        || "0");
      const vatAmount      = parseFloat(sale.vatAmount    || "0");
      const cashAmount     = parseFloat(sale.cashAmount   || "0");
      const cardAmount     = parseFloat(sale.cardAmount   || "0");
      const creditAmount   = parseFloat(sale.creditAmount || "0");
      const receivedAmount = cashAmount + cardAmount;
      const netRevenue     = totalAmount - vatAmount;

      // 2a. Reverse bank account balance (reduce what was added on sale)
      if (receivedAmount > 0 && sale.bankAccountId) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, sale.bankAccountId));
        if (account) {
          const newBalance = parseFloat(account.currentBalance || "0") - receivedAmount;
          await tx.update(bankAccounts)
            .set({ currentBalance: newBalance.toFixed(3) })
            .where(eq(bankAccounts.id, sale.bankAccountId));

          // Record reversal bank transaction
          await tx.insert(bankTransactions).values({
            bankAccountId: sale.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId || account.shopId,
            type: "withdrawal",
            amount: receivedAmount.toFixed(3),
            reference: sale.saleNumber,
            description: `Reversal: Sale deleted ${sale.saleNumber}`,
            relatedType: "sale_deletion",
            relatedId: sale.id,
          });
        }
      }

      // 2b. Reverse customer balance if credit sale
      if (sale.customerId && creditAmount > 0) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, sale.customerId));
        if (customer) {
          const newBalance = parseFloat(customer.currentBalance || "0") - creditAmount;
          await tx.update(customers)
            .set({ currentBalance: newBalance.toFixed(3) })
            .where(eq(customers.id, sale.customerId));
        }
      }

      // 2c. Calculate COGS for reversal
      let totalCOGS = 0;
      for (const item of items) {
        const [product] = await tx.select().from(products).where(eq(products.id, item.productId));
        if (product) {
          totalCOGS += parseFloat(product.purchasePrice || "0") * item.quantity;
        }
      }

      // 2d. Create reversal journal entry (opposite signs of original)
      const reversalLines: Array<{ accountCode: string; debit?: number; credit?: number; description?: string }> = [];

      if (receivedAmount > 0) {
        reversalLines.push({ accountCode: "1000", credit: receivedAmount, description: "Reverse: Cash/card received on deleted sale" });
      }
      if (creditAmount > 0) {
        reversalLines.push({ accountCode: "1100", credit: creditAmount, description: "Reverse: Accounts receivable on deleted sale" });
      }
      if (netRevenue > 0) {
        reversalLines.push({ accountCode: "4000", debit: netRevenue, description: "Reverse: Sales revenue on deleted sale" });
      }
      if (vatAmount > 0) {
        reversalLines.push({ accountCode: "2150", debit: vatAmount, description: "Reverse: VAT payable on deleted sale" });
      }
      if (totalCOGS > 0) {
        reversalLines.push({ accountCode: "5000", credit: totalCOGS, description: "Reverse: COGS on deleted sale" });
        reversalLines.push({ accountCode: "1200", debit: totalCOGS, description: "Reverse: Inventory restored on deleted sale" });
      }

      if (reversalLines.length > 0) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "sale_deletion",
          sourceId: sale.id,
          shopId: sale.shopId,
          branchId: sale.branchId || sale.shopId,
          reference: sale.saleNumber,
          description: `Reversal: Sale deleted ${sale.saleNumber}`,
          lines: reversalLines,
        });
      }

      // 3. Return inventory
      for (const item of items) {
        if (item.inventoryId) {
          const [inv] = await tx.select().from(inventory).where(eq(inventory.id, item.inventoryId));
          if (inv) {
            await tx.update(inventory)
              .set({ quantity: inv.quantity + item.quantity })
              .where(eq(inventory.id, inv.id));
          }
        }

        // Return serial numbers to available
        if (item.serialIds && Array.isArray(item.serialIds)) {
          for (const serialId of item.serialIds) {
            if (serialId && !serialId.startsWith("manual-") && !serialId.startsWith("temp-")) {
              await tx.update(serialNumbers)
                .set({ status: "available", soldAt: null, saleId: null })
                .where(eq(serialNumbers.serialNumber, serialId));
            }
          }
        }
      }

      // 4. Delete supporting records
      await tx.delete(saleItems).where(eq(saleItems.saleId, id));
      await tx.delete(salePayments).where(eq(salePayments.saleId, id));

      // 5. Delete original journal entries for this sale (the original + the new reversal are now both recorded)
      await tx.delete(journalEntries).where(and(eq(journalEntries.sourceType, "sale"), eq(journalEntries.sourceId, id)));

      // 6. Delete sale record
      await tx.delete(sales).where(eq(sales.id, id));
    });
  }


  async createSale(data: any, items: any[]): Promise<Sale> {
    const saleNumber = await this.getNextNumber("SL");
    const cashAmount = parseFloat(data.cashAmount || "0");
    const cardAmount = parseFloat(data.cardAmount || "0");
    const receivedPayment = cashAmount + cardAmount;

    // Enforce bankAccountId when receiving payment
    if (receivedPayment > 0 && !data.bankAccountId) {
      throw new Error("Bank account is required when receiving payment. Please select a bank account.");
    }

    return await db.transaction(async (tx) => {
      const saleData = {
        saleNumber,
        customerId: (data.customerId && data.customerId !== "walkin") ? data.customerId : null,
        shopId: data.shopId,
        branchId: data.branchId || null,
        paymentStatus: data.creditAmount > 0 ? "partial" : "paid",
        paymentMethod: data.paymentMethod,
        bankAccountId: data.bankAccountId || null,
        cashAmount: data.cashAmount?.toString() || "0.000",
        cardAmount: data.cardAmount?.toString() || "0.000",
        creditAmount: data.creditAmount?.toString() || "0.000",
        subtotal: data.subtotal?.toString() || "0.000",
        vatAmount: data.vatAmount?.toString() || "0.000",
        discount: data.discount?.toString() || "0.000",
        total: data.total?.toString() || "0.000",
      };

      const [sale] = await tx.insert(sales).values(saleData).returning();

      // Insert sale items and reduce inventory using FIFO
      for (const item of items) {
        await tx.insert(saleItems).values({
          saleId: sale.id,
          productId: item.productId,
          quantity: item.quantity,
          unitPrice: item.unitPrice?.toString() || "0.000",
          vatRate: item.vatRate?.toString() || "5.00",
          discount: item.discount?.toString() || "0.000",
          total: item.total?.toString() || "0.000",
          serialNumber: item.serialNumber || null,
        });

        // Reduce inventory using FIFO (First In First Out)
        // Order by receivedDate ascending to get oldest batches first
        const inventoryItems = await tx.select().from(inventory)
          .where(eq(inventory.productId, item.productId))
          .orderBy(asc(inventory.receivedDate));

        let remainingQty = item.quantity;
        for (const inv of inventoryItems) {
          if (remainingQty <= 0) break;
          const available = inv.quantity;
          if (available <= remainingQty) {
            // Use entire batch - delete the inventory record
            await tx.delete(inventory).where(eq(inventory.id, inv.id));
            remainingQty -= available;
          } else {
            // Partial use - reduce quantity in this batch
            await tx.update(inventory).set({ quantity: available - remainingQty }).where(eq(inventory.id, inv.id));
            remainingQty = 0;
          }
        }
      }

      // Update customer balance if credit sale
      if (data.customerId && data.customerId !== "walkin" && data.creditAmount > 0) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, data.customerId));
        if (customer) {
          const newBalance = parseFloat(customer.currentBalance || "0") + parseFloat(data.creditAmount || "0");
          await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, data.customerId));
        }
      }

      // Handle applied store credit (reduces what customer owes, and uses their credit balance)
      // Store credit = negative customer balance (shop owes customer)
      const appliedStoreCredit = parseFloat(data.appliedStoreCredit || "0");
      if (data.customerId && data.customerId !== "walkin" && appliedStoreCredit > 0) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, data.customerId));
        if (customer) {
          // Customer had negative balance (shop owed them), applying credit brings it closer to 0 or positive
          // currentBalance is negative for store credit, so adding the applied amount increases it (makes it less negative)
          const currentBalance = parseFloat(customer.currentBalance || "0");
          const newBalance = currentBalance + appliedStoreCredit;
          await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, data.customerId));
        }
      }

      // Update bank account balance when receiving payment
      const receivedPayment = parseFloat(data.cashAmount || "0") + parseFloat(data.cardAmount || "0");
      if (receivedPayment > 0 && data.bankAccountId) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          const currentBalance = parseFloat(account.currentBalance || "0");
          const newBalance = currentBalance + receivedPayment;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

          // Record bank transaction
          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "deposit",
            amount: receivedPayment.toFixed(3),
            reference: saleNumber,
            description: `Payment received for sale ${saleNumber}`,
            relatedType: "sale",
            relatedId: sale.id,
          });

          // Record initial payment in salePayments table for payment history
          const paymentRef = await this.getNextNumber("PAY");

          // Record cash payment if any
          if (parseFloat(data.cashAmount || "0") > 0) {
            await tx.insert(salePayments).values({
              saleId: sale.id,
              customerId: (data.customerId && data.customerId !== "walkin") ? data.customerId : null,
              paymentMethod: "cash",
              bankAccountId: data.bankAccountId,
              amount: parseFloat(data.cashAmount).toFixed(3),
              reference: paymentRef,
              notes: `Initial cash payment at sale time`,
            });
          }

          // Record card payment if any
          if (parseFloat(data.cardAmount || "0") > 0) {
            await tx.insert(salePayments).values({
              saleId: sale.id,
              customerId: (data.customerId && data.customerId !== "walkin") ? data.customerId : null,
              paymentMethod: "card",
              bankAccountId: data.bankAccountId,
              amount: parseFloat(data.cardAmount).toFixed(3),
              reference: paymentRef,
              notes: `Initial card payment at sale time`,
            });
          }
        }
      }

      // Create accounting journal entry for sale
      // For balanced entries: Total Debits = Total Credits
      const subtotal = parseFloat(data.subtotal || "0");
      const vatAmount = parseFloat(data.vatAmount || "0");
      const discount = parseFloat(data.discount || "0");
      const totalAmount = parseFloat(data.total || "0");
      const cashAmount = parseFloat(data.cashAmount || "0");
      const cardAmount = parseFloat(data.cardAmount || "0");
      const creditAmount = parseFloat(data.creditAmount || "0");

      // Net revenue = total - VAT (since total already has all discounts applied)
      // Note: subtotal from client already includes item discounts, and discount field includes BOTH
      // item discounts and overall discount, so we can't subtract discount from subtotal (double-counting)
      const netRevenue = totalAmount - vatAmount;

      // Calculate cost of goods sold from inventory
      let totalCOGS = 0;
      for (const item of items) {
        const [product] = await tx.select().from(products).where(eq(products.id, item.productId));
        if (product) {
          const unitCost = parseFloat(product.purchasePrice || "0");
          totalCOGS += unitCost * item.quantity;
        }
      }

      const saleJournalLines: Array<{ accountCode: string; debit?: number; credit?: number; description?: string }> = [];
      const appliedStoreCreditAmount = parseFloat(data.appliedStoreCredit || "0");

      // Debit Cash (1000) for cash + card received
      const receivedAmount = cashAmount + cardAmount;
      if (receivedAmount > 0) {
        saleJournalLines.push({ accountCode: "1000", debit: receivedAmount, description: "Cash/card received from sale" });
      }

      // Debit Customer Deposits/Liability (2000) when using customer store credit
      // Store credit was created as a liability to the customer, now we're reducing it
      if (appliedStoreCreditAmount > 0) {
        saleJournalLines.push({ accountCode: "2000", debit: appliedStoreCreditAmount, description: "Store credit applied from customer" });
      }

      // Debit Accounts Receivable (1100) for credit amount
      if (creditAmount > 0) {
        saleJournalLines.push({ accountCode: "1100", debit: creditAmount, description: "Amount owed by customer" });
      }

      // Credit Sales Revenue (4000) for net revenue (subtotal minus discount)
      if (netRevenue > 0) {
        saleJournalLines.push({ accountCode: "4000", credit: netRevenue, description: "Sales revenue (net of discounts)" });
      }

      // Credit VAT Payable (2150) for VAT collected
      if (vatAmount > 0) {
        saleJournalLines.push({ accountCode: "2150", credit: vatAmount, description: "VAT on sale (output)" });
      }

      // Debit Cost of Goods Sold (5000) and Credit Inventory (1200)
      if (totalCOGS > 0) {
        saleJournalLines.push({ accountCode: "5000", debit: totalCOGS, description: "Cost of goods sold" });
        saleJournalLines.push({ accountCode: "1200", credit: totalCOGS, description: "Inventory reduction" });
      }

      if (saleJournalLines.length > 0) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "sale",
          sourceId: sale.id,
          shopId: sale.shopId,
          branchId: sale.branchId || sale.shopId,
          reference: saleNumber,
          description: `Sale to customer - ${saleNumber}`,
          lines: saleJournalLines,
        });
      }

      return sale;
    });
  }

  // Get sale items by sale ID - returns only current (active) sale line items
  async getSaleItems(saleId: string): Promise<any[]> {
    const items = await db.select({
      id: saleItems.id,
      productId: saleItems.productId,
      quantity: saleItems.quantity,
      unitPrice: saleItems.unitPrice,
      vatRate: saleItems.vatRate,
      discount: saleItems.discount,
      total: saleItems.total,
      serialNumber: saleItems.serialNumber,
      productName: products.name,
      productSku: products.sku,
      warrantyDays: products.warrantyDays,
    })
      .from(saleItems)
      .leftJoin(products, eq(saleItems.productId, products.id))
      .where(eq(saleItems.saleId, saleId));

    return items;
  }

  // Get sale items with replacement info - returns { currentItems, replacementHistory }
  async getSaleItemsWithReplacementHistory(saleId: string): Promise<{ currentItems: any[], replacementHistory: any[] }> {
    // Get current sale items
    const items = await db.select({
      id: saleItems.id,
      productId: saleItems.productId,
      quantity: saleItems.quantity,
      unitPrice: saleItems.unitPrice,
      vatRate: saleItems.vatRate,
      discount: saleItems.discount,
      total: saleItems.total,
      serialNumber: saleItems.serialNumber,
      productName: products.name,
      productSku: products.sku,
      warrantyDays: products.warrantyDays,
    })
      .from(saleItems)
      .leftJoin(products, eq(saleItems.productId, products.id))
      .where(eq(saleItems.saleId, saleId));

    // Get replacement history for this sale
    const replacements = await db.select().from(saleReplacements).where(eq(saleReplacements.saleId, saleId));

    // Mark current items that are replacements
    const currentItems = items.map(item => {
      const replacement = replacements.find(r => r.saleItemId === item.id);
      if (replacement) {
        return {
          ...item,
          isReplacement: true,
          replacementNumber: replacement.replacementNumber,
          originalProductId: replacement.originalProductId,
          originalSerialNumber: replacement.originalSerialNumber,
          originalPrice: replacement.originalPrice,
          replacementDate: replacement.replacementDate,
          priceDifference: replacement.priceDifference,
        };
      }
      return { ...item, isReplacement: false };
    });

    // Build replacement history (original items that were replaced) - for display only
    const replacementHistory = await Promise.all(
      replacements.map(async (r) => {
        const [originalProduct] = await db.select().from(products).where(eq(products.id, r.originalProductId || ''));
        return {
          id: `history-${r.id}`,
          productId: r.originalProductId,
          quantity: r.originalQuantity || 1,
          unitPrice: r.originalPrice,
          serialNumber: r.originalSerialNumber,
          productName: originalProduct?.name || 'Unknown Product',
          productSku: originalProduct?.sku || '',
          replacementNumber: r.replacementNumber,
          replacedWithProductId: r.replacementProductId,
          replacedWithSerialNumber: r.replacementSerialNumber,
          replacementDate: r.replacementDate,
          replacedWithProductName: currentItems.find(i => i.id === r.saleItemId)?.productName || 'Unknown',
        };
      })
    );

    return { currentItems, replacementHistory };
  }

  // Get sale replacements by sale ID
  async getSaleReplacementsBySaleId(saleId: string): Promise<any[]> {
    const replacementsList = await db.select().from(saleReplacements).where(eq(saleReplacements.saleId, saleId));

    // Enrich with product names
    const enrichedReplacements = await Promise.all(
      replacementsList.map(async (r) => {
        const [originalProduct] = await db.select().from(products).where(eq(products.id, r.originalProductId || ''));
        const [replacementProduct] = await db.select().from(products).where(eq(products.id, r.replacementProductId || ''));
        return {
          ...r,
          originalProductName: originalProduct?.name || 'Unknown',
          replacementProductName: replacementProduct?.name || 'Unknown',
        };
      })
    );

    return enrichedReplacements;
  }

  // Get customer sales with items (includes remaining returnable quantities)
  async getCustomerSalesWithItems(customerId: string): Promise<any[]> {
    const customerSales = await db.select().from(sales)
      .where(customerId === "walkin" ? isNull(sales.customerId) : eq(sales.customerId, customerId))
      .orderBy(desc(sales.saleDate));

    const salesWithItems = await Promise.all(
      customerSales.map(async (sale) => {
        const items = await db.select({
          id: saleItems.id,
          productId: saleItems.productId,
          quantity: saleItems.quantity,
          unitPrice: saleItems.unitPrice,
          vatRate: saleItems.vatRate,
          discount: saleItems.discount,
          total: saleItems.total,
          serialNumber: saleItems.serialNumber,
          productName: products.name,
          productSku: products.sku,
          warrantyDays: products.warrantyDays,
        })
          .from(saleItems)
          .leftJoin(products, eq(saleItems.productId, products.id))
          .where(eq(saleItems.saleId, sale.id));

        // Get already returned quantities for each item
        const itemsWithReturnable = await Promise.all(
          items.map(async (item) => {
            const previousReturns = await db.select({
              totalReturned: sql<number>`COALESCE(SUM(${saleReturnItems.quantity}), 0)`
            }).from(saleReturnItems).where(eq(saleReturnItems.saleItemId, item.id));

            const alreadyReturned = Number(previousReturns[0]?.totalReturned || 0);
            const remainingReturnable = item.quantity - alreadyReturned;

            return { ...item, alreadyReturned, remainingReturnable };
          })
        );

        return { ...sale, items: itemsWithReturnable };
      })
    );

    return salesWithItems;
  }

  // Sale Returns
  async getSaleReturns(): Promise<any[]> {
    return db.select().from(saleReturns).orderBy(desc(saleReturns.returnDate));
  }

  async getSaleReturnItems(returnId: string): Promise<any[]> {
    return db.select().from(saleReturnItems).where(eq(saleReturnItems.returnId, returnId));
  }

  async createSaleReturn(data: any, items: any[]): Promise<any> {
    const returnNumber = await this.getNextNumber("RET");
    const refundAmount = parseFloat(data.refundAmount || "0");
    const creditAmount = parseFloat(data.creditAmount || "0");

    // Smart refund: Frontend calculates net refund after offsetting customer debt
    // refundAmount = cash to refund (after debt offset)
    // creditAmount = amount applied to reduce customer debt

    // STRICT FINANCIAL CONTROL: Validate sufficient funds before cash refund
    if (refundAmount > 0 && data.bankAccountId) {
      await this.ensureSufficientFunds(refundAmount, data.bankAccountId, "sales return refund");
    } else if (refundAmount > 0) {
      // Even without specific bank account, validate overall available balance
      await this.ensureSufficientFunds(refundAmount, null, "sales return refund");
    }

    return await db.transaction(async (tx) => {
      // Validate that we're not returning more than was sold (accounting for previous returns)
      for (const item of items) {
        // Get the original sale item
        const [originalSaleItem] = await tx.select().from(saleItems).where(eq(saleItems.id, item.saleItemId));
        if (!originalSaleItem) {
          throw new Error(`Sale item not found: ${item.saleItemId}`);
        }

        // Get previously returned quantities for this sale item
        const previousReturns = await tx.select({
          totalReturned: sql<number>`COALESCE(SUM(${saleReturnItems.quantity}), 0)`
        }).from(saleReturnItems).where(eq(saleReturnItems.saleItemId, item.saleItemId));

        const alreadyReturned = Number(previousReturns[0]?.totalReturned || 0);
        const remainingReturnable = originalSaleItem.quantity - alreadyReturned;

        if (item.quantity > remainingReturnable) {
          const [product] = await tx.select({ name: products.name }).from(products).where(eq(products.id, item.productId));
          throw new Error(`Cannot return ${item.quantity} units of "${product?.name || 'product'}". Only ${remainingReturnable} remaining (${originalSaleItem.quantity} sold, ${alreadyReturned} already returned).`);
        }
      }

      // Get branchId from the original sale if not provided
      let branchId = data.branchId;
      if (!branchId && data.saleId) {
        const [originalSale] = await tx.select({ branchId: sales.branchId }).from(sales).where(eq(sales.id, data.saleId));
        branchId = originalSale?.branchId;
      }
      // Fallback: get first branch for the shop
      if (!branchId && data.shopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, data.shopId)).limit(1);
        branchId = branch?.id;
      }

      const returnData = {
        returnNumber,
        saleId: data.saleId,
        customerId: (data.customerId && data.customerId !== "walkin") ? data.customerId : null,
        shopId: data.shopId || null,
        branchId: branchId || null,
        returnType: data.returnType || "refund",
        refundMethod: data.refundMethod || null,
        refundAmount: data.refundAmount?.toString() || "0.000",
        creditAmount: data.creditAmount?.toString() || "0.000",
        reason: data.reason || null,
        status: "completed",
      };

      const [saleReturn] = await tx.insert(saleReturns).values(returnData).returning();

      let totalCOGS = 0;
      for (const item of items) {
        const [product] = await tx.select({ purchasePrice: products.purchasePrice }).from(products).where(eq(products.id, item.productId));
        const itemCostPrice = parseFloat(product?.purchasePrice || "0");
        const itemCOGS = itemCostPrice * (item.quantity || 1);
        totalCOGS += itemCOGS;

        await tx.insert(saleReturnItems).values({
          returnId: saleReturn.id,
          saleItemId: item.saleItemId,
          productId: item.productId,
          quantity: item.quantity,
          unitPrice: item.unitPrice?.toString() || "0.000",
          total: item.total?.toString() || "0.000",
          reason: item.reason || null,
          warrantyStatus: item.warrantyStatus || null,
          serialNumber: item.serialNumber || null,
        });

        // Update serial number status if this item has a serial number
        if (item.serialNumber) {
          await tx.update(serialNumbers)
            .set({ status: "available", returnedAt: new Date(), saleId: null, saleItemId: null })
            .where(eq(serialNumbers.serialNumber, item.serialNumber));
        }

        // Add inventory back - find a warehouse for this shop
        const [warehouse] = await tx.select().from(warehouses)
          .where(eq(warehouses.shopId, data.shopId))
          .limit(1);

        if (warehouse) {
          await tx.insert(inventory).values({
            productId: item.productId,
            warehouseId: warehouse.id,
            quantity: item.quantity,
            costPrice: itemCostPrice.toFixed(3),
          });
        }
      }

      // Update customer balance if credit return (store credit means store owes customer)
      // creditAmount here is the store credit portion - reduces customer balance (negative = store owes them)
      if (data.customerId && data.customerId !== "walkin" && creditAmount > 0) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, data.customerId));
        if (customer) {
          // Subtract credit amount from customer balance
          // Positive balance = customer owes store, Negative = store owes customer (store credit)
          const currentBal = parseFloat(customer.currentBalance || "0");
          const newBalance = currentBal - creditAmount;
          await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, data.customerId));
        }
      }

      // Calculate total return values from actual items (using their real VAT)
      const totalReturnItemValue = items.reduce((sum: number, item: any) => sum + parseFloat(item.total || "0"), 0);
      const totalReturnVat = items.reduce((sum: number, item: any) => sum + parseFloat(item.vatAmount || "0"), 0);
      const totalReturnSubtotal = items.reduce((sum: number, item: any) => {
        const itemTotal = parseFloat(item.total || "0");
        const itemVat = parseFloat(item.vatAmount || "0");
        return sum + (itemTotal - itemVat);
      }, 0);

      // LEDGER INTEGRITY: Do NOT modify original sale amounts on return
      // The sale record is historical fact - returns are separate transactions
      // Only update payment status and credit amount (customer debt offset), NOT the invoice totals
      if (data.saleId) {
        const [originalSale] = await tx.select().from(sales).where(eq(sales.id, data.saleId));
        if (originalSale) {
          const originalTotal = parseFloat(originalSale.total || "0");
          const originalCredit = parseFloat(originalSale.creditAmount || "0");
          const cashPaid = parseFloat(originalSale.cashAmount || "0");
          const cardPaid = parseFloat(originalSale.cardAmount || "0");

          // Reduce credit by creditAmount (debt offset from return) - this is the only financial field we update
          const creditReduction = parseFloat(data.creditAmount || "0");
          const newCreditAmount = Math.max(0, originalCredit - creditReduction);

          // Calculate effective remaining after accounting for returns
          const effectiveRemaining = originalTotal - totalReturnItemValue;
          const totalPaid = cashPaid + cardPaid;
          let newPaymentStatus = originalSale.paymentStatus;

          // Check if ALL items have been fully returned
          const [originalSaleItems] = await tx.select({ count: sql<number>`COUNT(*)`, totalQty: sql<number>`COALESCE(SUM(${saleItems.quantity}), 0)` })
            .from(saleItems)
            .where(eq(saleItems.saleId, data.saleId));

          const [allReturnedItems] = await tx.select({ totalReturned: sql<number>`COALESCE(SUM(${saleReturnItems.quantity}), 0)` })
            .from(saleReturnItems)
            .innerJoin(saleItems, eq(saleReturnItems.saleItemId, saleItems.id))
            .where(eq(saleItems.saleId, data.saleId));

          const totalSoldQty = Number(originalSaleItems?.totalQty || 0);
          const totalReturnedQty = Number(allReturnedItems?.totalReturned || 0);
          const isFullyReturned = totalSoldQty > 0 && totalReturnedQty >= totalSoldQty;

          if (isFullyReturned) {
            newPaymentStatus = "returned"; // All items have been returned
          } else if (effectiveRemaining <= 0) {
            newPaymentStatus = "paid"; // Nothing left to pay after return
          } else if (totalPaid >= effectiveRemaining) {
            newPaymentStatus = "paid";
          } else if (totalPaid > 0) {
            newPaymentStatus = "partial";
          } else {
            newPaymentStatus = "pending";
          }

          // Only update credit amount and payment status - preserve original invoice totals
          await tx.update(sales).set({
            creditAmount: newCreditAmount.toFixed(3),
            paymentStatus: newPaymentStatus
          }).where(eq(sales.id, data.saleId));
        }
      }

      // Create bank transaction for cash refund
      if (refundAmount > 0 && data.bankAccountId) {
        // Update bank account balance
        const [bankAccount] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (bankAccount) {
          const currentBalance = parseFloat(bankAccount.currentBalance?.toString() || "0");
          const newBalance = currentBalance - refundAmount;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));

          // Get shopId and branchId from bank account or sale return
          const txShopId = bankAccount.shopId || saleReturn.shopId || data.shopId;
          const txBranchId = bankAccount.branchId || saleReturn.branchId;

          if (!txShopId || !txBranchId) {
            throw new Error("Shop and branch are required for bank transaction");
          }

          // Create bank transaction record
          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: txShopId,
            branchId: txBranchId,
            type: "withdrawal",
            amount: refundAmount.toFixed(3),
            description: `Refund for sale return ${returnNumber}`,
            reference: returnNumber,
            relatedType: "sale_return",
            relatedId: saleReturn.customerId,
            // relatedId: saleReturn.id,
          });
        }
      }

      const totalReturnAmount = parseFloat(data.refundAmount || "0") + parseFloat(data.creditAmount || "0");

      if (totalReturnAmount > 0) {
        const journalLines = [];

        const returnSubtotal = totalReturnSubtotal;
        const returnVatAmount = totalReturnVat;

        // Get the original sale to determine how much was on credit (AR) vs paid
        const [originalSale] = await tx.select().from(sales).where(eq(sales.id, data.saleId));
        const originalTotal = originalSale ? parseFloat(originalSale.total || "0") + totalReturnItemValue : totalReturnItemValue; // Add back return to get original
        const originalCashPaid = originalSale ? parseFloat(originalSale.cashAmount || "0") : 0;
        const originalCardPaid = originalSale ? parseFloat(originalSale.cardAmount || "0") : 0;
        const originalPaidAmount = originalCashPaid + originalCardPaid;
        const originalCreditPortion = originalTotal - originalPaidAmount; // What was on AR

        // Calculate how much of the return should reduce AR vs become store credit/refund
        // If return value <= what was on AR, it all reduces AR
        // If return value > what was on AR, the excess is what customer paid, which becomes refund/store credit
        const arReductionAmount = Math.min(totalReturnItemValue, Math.max(0, originalCreditPortion));
        const paidPortionReturn = totalReturnItemValue - arReductionAmount; // What customer paid that's being returned

        if (returnSubtotal > 0) {
          journalLines.push(
            { accountCode: "4000", debit: returnSubtotal, description: "Reverse revenue for sale return" }
          );
        }

        if (returnVatAmount > 0) {
          journalLines.push(
            { accountCode: "2150", debit: returnVatAmount, description: "Reverse VAT for sale return" }
          );
        }

        // Handle cash refund if any
        if (parseFloat(data.refundAmount || "0") > 0) {
          journalLines.push(
            { accountCode: "1000", credit: parseFloat(data.refundAmount || "0"), description: "Cash refund to customer" }
          );
        }

        // For returns: properly split between AR reduction and store credit
        // 1. Reduce AR for the portion that was originally on credit
        if (arReductionAmount > 0) {
          journalLines.push(
            { accountCode: "1100", credit: arReductionAmount, description: "Reduce AR for credit portion of return" }
          );
        }

        // 2. For the paid portion: either cash refund (already handled above) or store credit
        if (data.returnType === "credit" && paidPortionReturn > 0) {
          // Store credit for the portion customer actually paid
          journalLines.push(
            { accountCode: "2000", credit: paidPortionReturn, description: "Store credit payable to customer" }
          );
        }

        if (totalCOGS > 0) {
          journalLines.push(
            { accountCode: "1200", debit: totalCOGS, description: "Return inventory to stock" },
            { accountCode: "5000", credit: totalCOGS, description: "Reverse COGS for returned items" }
          );
        }

        // Get shopId and branchId from the sale return or original sale
        const shopId = saleReturn.shopId || data.shopId;
        let branchId = shopId;
        if (shopId) {
          const [branch] = await tx.select().from(branches).where(eq(branches.shopId, shopId)).limit(1);
          branchId = branch?.id || shopId;
        }

        await this.createJournalEntryInTx(tx, {
          sourceType: "sale_return",
          sourceId: saleReturn.id,
          shopId: shopId,
          branchId: branchId,
          reference: returnNumber,
          description: `Sale return - ${returnNumber}`,
          lines: journalLines,
        });
      }

      return saleReturn;
    });
  }

  // Sale Replacements
  async getSaleReplacements(): Promise<any[]> {
    return db.select().from(saleReplacements).orderBy(desc(saleReplacements.replacementDate));
  }

  async createSaleReplacement(data: any): Promise<any> {
    const replacementNumber = await this.getNextNumber("RPL");

    return await db.transaction(async (tx) => {
      const replacementData = {
        replacementNumber,
        saleId: data.saleId,
        customerId: (data.customerId && data.customerId !== "walkin") ? data.customerId : null,
        shopId: data.shopId || null,
        originalProductId: data.originalProductId,
        replacementProductId: data.replacementProductId,
        originalQuantity: data.originalQuantity,
        replacementQuantity: data.replacementQuantity,
        priceDifference: data.priceDifference?.toString() || "0.000",
        reason: data.reason || null,
        warrantyStatus: data.warrantyStatus || null,
        status: "completed",
      };

      const [replacement] = await tx.insert(saleReplacements).values(replacementData).returning();

      // Find a warehouse for this shop
      const [warehouse] = await tx.select().from(warehouses)
        .where(eq(warehouses.shopId, data.shopId))
        .limit(1);

      // Add back original product to inventory
      if (warehouse) {
        await tx.insert(inventory).values({
          productId: data.originalProductId,
          warehouseId: warehouse.id,
          quantity: data.originalQuantity,
          costPrice: "0.000",
        });
      }

      // Reduce replacement product from inventory
      const inventoryItems = await tx.select().from(inventory)
        .where(eq(inventory.productId, data.replacementProductId))
        .orderBy(asc(inventory.receivedDate));

      let remainingQty = data.replacementQuantity;
      for (const inv of inventoryItems) {
        if (remainingQty <= 0) break;
        const available = inv.quantity;
        if (available <= remainingQty) {
          await tx.delete(inventory).where(eq(inventory.id, inv.id));
          remainingQty -= available;
        } else {
          await tx.update(inventory).set({ quantity: available - remainingQty }).where(eq(inventory.id, inv.id));
          remainingQty = 0;
        }
      }

      // Update customer balance if price difference
      if (data.customerId && data.priceDifference !== 0) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, data.customerId));
        if (customer) {
          const diff = parseFloat(data.priceDifference || "0");
          const newBalance = parseFloat(customer.currentBalance || "0") + diff;
          await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, data.customerId));
        }
      }

      return replacement;
    });
  }

  async replaceSaleItem(data: {
    saleId: string;
    saleItemId: string;
    originalSerialNumberId: string;
    replacementProductId: string;
    replacementSerialNumberId: string;
    paymentMethod?: string;
    bankAccountId?: string;
    reason?: string;
    shopId?: string;
    branchId?: string;
  }): Promise<any> {
    const replacementNumber = await this.getNextNumber("RPL");

    return await db.transaction(async (tx) => {
      // 1. Get the original sale item
      const [saleItem] = await tx.select().from(saleItems).where(eq(saleItems.id, data.saleItemId));
      if (!saleItem) throw new Error("Sale item not found");

      // 2. Get the sale
      const [sale] = await tx.select().from(sales).where(eq(sales.id, data.saleId));
      if (!sale) throw new Error("Sale not found");

      // 3. Get original serial number
      const [originalSerial] = await tx.select().from(serialNumbers).where(eq(serialNumbers.id, data.originalSerialNumberId));
      if (!originalSerial) throw new Error("Original serial number not found");

      // 4. Get replacement serial number
      const [replacementSerial] = await tx.select().from(serialNumbers).where(eq(serialNumbers.id, data.replacementSerialNumberId));
      if (!replacementSerial) throw new Error("Replacement serial number not found");
      if (replacementSerial.status !== "available") throw new Error("Replacement serial number is not available");

      // 5. Get original product
      const [originalProduct] = await tx.select().from(products).where(eq(products.id, saleItem.productId));
      if (!originalProduct) throw new Error("Original product not found");

      // 6. Get replacement product
      const [replacementProduct] = await tx.select().from(products).where(eq(products.id, data.replacementProductId));
      if (!replacementProduct) throw new Error("Replacement product not found");

      const originalPrice = parseFloat(saleItem.unitPrice || "0");
      const replacementPrice = parseFloat(replacementProduct.sellingPrice || "0");
      const priceDifference = replacementPrice - originalPrice;

      // Determine replacement type
      let replacementType = "same_item";
      if (saleItem.productId !== data.replacementProductId) {
        replacementType = priceDifference > 0 ? "higher_price" : (priceDifference < 0 ? "lower_price" : "same_price");
      }

      // 7. Update original serial number status back to "available"
      await tx.update(serialNumbers).set({
        status: "available",
        saleId: null,
        saleItemId: null,
        soldAt: null,
        replacedAt: new Date(),
        updatedAt: new Date(),
      }).where(eq(serialNumbers.id, data.originalSerialNumberId));

      // 9. Handle partial replacement when saleItem has qty > 1
      let replacementSaleItemId = data.saleItemId;
      const originalQuantity = saleItem.quantity;

      if (originalQuantity > 1) {
        // Partial replacement: reduce original item qty by 1 and create new item for replacement
        const remainingQty = originalQuantity - 1;
        const originalDiscountTotal = parseFloat(saleItem.discount || "0");
        const originalDiscountPerUnit = originalDiscountTotal / originalQuantity;

        // Calculate remaining item's values
        const remainingItemSubtotal = parseFloat(saleItem.unitPrice || "0") * remainingQty;
        const remainingDiscount = originalDiscountPerUnit * remainingQty;
        const remainingItemTotal = remainingItemSubtotal - remainingDiscount;

        // Update original saleItem to have qty-1 (keeping original product)
        await tx.update(saleItems).set({
          quantity: remainingQty,
          discount: remainingDiscount.toFixed(3),
          total: remainingItemTotal.toFixed(3),
        }).where(eq(saleItems.id, data.saleItemId));

        // Create new saleItem for the replacement (qty=1)
        // Replacement item gets no discount (replacement is at full price)
        const newReplacementTotal = replacementPrice * 1;
        const [newSaleItem] = await tx.insert(saleItems).values({
          saleId: data.saleId,
          productId: data.replacementProductId,
          quantity: 1,
          unitPrice: replacementPrice.toFixed(3),
          vatRate: saleItem.vatRate || "5",
          discount: "0",
          total: newReplacementTotal.toFixed(3),
          serialNumber: replacementSerial.serialNumber,
        }).returning();

        replacementSaleItemId = newSaleItem.id;

        // Update replacement serial number to point to new sale item
        await tx.update(serialNumbers).set({
          status: "sold",
          saleId: data.saleId,
          saleItemId: newSaleItem.id,
          soldAt: new Date(),
          updatedAt: new Date(),
        }).where(eq(serialNumbers.id, data.replacementSerialNumberId));

        // Recalculate sale totals from all items
        const allItems = await tx.select().from(saleItems).where(eq(saleItems.saleId, data.saleId));
        const newSubtotal = allItems.reduce((sum, item) => sum + parseFloat(item.total || "0"), 0);

        // Calculate weighted average VAT from all items
        let totalVat = 0;
        for (const item of allItems) {
          const itemSubtotal = parseFloat(item.unitPrice || "0") * item.quantity - parseFloat(item.discount || "0");
          const itemVatRate = parseFloat(item.vatRate || "5") / 100;
          totalVat += itemSubtotal * itemVatRate;
        }

        const newTotal = newSubtotal + totalVat - parseFloat(sale.discount || "0");

        await tx.update(sales).set({
          subtotal: newSubtotal.toFixed(3),
          vatAmount: totalVat.toFixed(3),
          total: newTotal.toFixed(3),
        }).where(eq(sales.id, data.saleId));

      } else {
        // Single item replacement (qty=1): update existing saleItem

        // Update replacement serial number status to "sold"
        await tx.update(serialNumbers).set({
          status: "sold",
          saleId: data.saleId,
          saleItemId: data.saleItemId,
          soldAt: new Date(),
          updatedAt: new Date(),
        }).where(eq(serialNumbers.id, data.replacementSerialNumberId));

        if (saleItem.productId !== data.replacementProductId) {
          const newItemTotal = replacementPrice * 1;
          await tx.update(saleItems).set({
            productId: data.replacementProductId,
            unitPrice: replacementPrice.toFixed(3),
            total: newItemTotal.toFixed(3),
            serialNumber: replacementSerial.serialNumber,
          }).where(eq(saleItems.id, data.saleItemId));

          // Update sale totals
          const oldSubtotal = parseFloat(sale.subtotal || "0");
          const oldItemTotal = parseFloat(saleItem.total || "0");
          const newSubtotal = oldSubtotal - oldItemTotal + newItemTotal;
          const vatRate = parseFloat(saleItem.vatRate || "5") / 100;
          const newVat = newSubtotal * vatRate;
          const newTotal = newSubtotal + newVat - parseFloat(sale.discount || "0");

          await tx.update(sales).set({
            subtotal: newSubtotal.toFixed(3),
            vatAmount: newVat.toFixed(3),
            total: newTotal.toFixed(3),
          }).where(eq(sales.id, data.saleId));
        } else {
          // Just update the serial number reference on the sale item
          await tx.update(saleItems).set({
            serialNumber: replacementSerial.serialNumber,
          }).where(eq(saleItems.id, data.saleItemId));
        }
      }

      // 10. Handle accounting based on price difference
      const shopId = data.shopId || sale.shopId || null;
      let branchId = data.branchId || sale.branchId || null;
      if (!branchId && shopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, shopId)).limit(1);
        branchId = branch?.id || null;
      }

      // Handle price difference accounting (for any price difference, regardless of bankAccountId)
      if (priceDifference !== 0) {
        // Get bank account only if provided (required for cash/card payments)
        let bankAccount = null;
        if (data.bankAccountId) {
          const [acct] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
          bankAccount = acct;
        }

        if (priceDifference > 0) {
          // Higher price - customer pays extra
          if ((data.paymentMethod === "cash" || data.paymentMethod === "card") && data.bankAccountId && bankAccount) {
            // Receive payment via bank
            await tx.update(bankAccounts).set({
              currentBalance: sql`CAST(current_balance AS NUMERIC) + ${priceDifference}`
            }).where(eq(bankAccounts.id, data.bankAccountId));

            await tx.insert(bankTransactions).values({
              bankAccountId: data.bankAccountId,
              shopId: shopId,
              branchId: branchId,
              type: "deposit",
              amount: priceDifference.toFixed(3),
              reference: replacementNumber,
              description: `Replacement price difference payment - ${replacementNumber}`,
              relatedType: "sale_replacement",
              relatedId: data.saleId,
            });

            // Journal: Debit Bank, Credit Sales Revenue
            await this.createJournalEntryInTx(tx, {
              sourceType: "sale_replacement",
              sourceId: data.saleId,
              shopId: shopId,
              branchId: branchId,
              reference: replacementNumber,
              description: `Replacement price difference received - ${replacementNumber}`,
              lines: [
                { accountCode: "1000", debit: priceDifference, description: "Cash/Bank deposit for replacement difference" },
                { accountCode: "4000", credit: priceDifference, description: "Additional sales revenue from replacement" },
              ],
            });
          } else if (data.paymentMethod === "credit") {
            // Add to customer balance (accounts receivable)
            if (sale.customerId) {
              const [customer] = await tx.select().from(customers).where(eq(customers.id, sale.customerId));
              if (customer) {
                const newBalance = parseFloat(customer.currentBalance || "0") + priceDifference;
                await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, sale.customerId));
              }
            }

            // Journal: Debit Accounts Receivable, Credit Sales Revenue
            await this.createJournalEntryInTx(tx, {
              sourceType: "sale_replacement",
              sourceId: data.saleId,
              shopId: shopId,
              branchId: branchId,
              reference: replacementNumber,
              description: `Replacement price difference on credit - ${replacementNumber}`,
              lines: [
                { accountCode: "1100", debit: priceDifference, description: "Accounts receivable for replacement difference" },
                { accountCode: "4000", credit: priceDifference, description: "Additional sales revenue from replacement" },
              ],
            });
          }
        } else if (priceDifference < 0) {
          // Lower price - refund to customer
          const refundAmount = Math.abs(priceDifference);

          if ((data.paymentMethod === "cash" || data.paymentMethod === "card") && data.bankAccountId && bankAccount) {
            // Issue refund via bank
            const currentBalance = parseFloat(bankAccount?.currentBalance?.toString() || "0");
            if (currentBalance < refundAmount) {
              throw new Error(`Insufficient funds in bank account. Available: ${currentBalance.toFixed(3)} RO, Required: ${refundAmount.toFixed(3)} RO`);
            }

            await tx.update(bankAccounts).set({
              currentBalance: sql`CAST(current_balance AS NUMERIC) - ${refundAmount}`
            }).where(eq(bankAccounts.id, data.bankAccountId));

            await tx.insert(bankTransactions).values({
              bankAccountId: data.bankAccountId,
              shopId: shopId,
              branchId: branchId,
              type: "withdrawal",
              amount: refundAmount.toFixed(3),
              reference: replacementNumber,
              description: `Replacement refund - ${replacementNumber}`,
              relatedType: "sale_replacement",
              relatedId: data.saleId,
            });

            // Journal: Debit Sales Returns, Credit Bank
            await this.createJournalEntryInTx(tx, {
              sourceType: "sale_replacement",
              sourceId: data.saleId,
              shopId: shopId,
              branchId: branchId,
              reference: replacementNumber,
              description: `Replacement refund issued - ${replacementNumber}`,
              lines: [
                { accountCode: "4100", debit: refundAmount, description: "Sales returns for replacement difference" },
                { accountCode: "1000", credit: refundAmount, description: "Cash/Bank withdrawal for replacement refund" },
              ],
            });
          } else if (data.paymentMethod === "store_credit") {
            // Add to customer store credit (reduce their balance = negative receivable)
            if (sale.customerId) {
              const [customer] = await tx.select().from(customers).where(eq(customers.id, sale.customerId));
              if (customer) {
                const newBalance = parseFloat(customer.currentBalance || "0") - refundAmount;
                await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, sale.customerId));
              }
            }

            // Journal: Debit Sales Returns, Credit Customer Liability
            await this.createJournalEntryInTx(tx, {
              sourceType: "sale_replacement",
              sourceId: data.saleId,
              shopId: shopId,
              branchId: branchId,
              reference: replacementNumber,
              description: `Replacement store credit issued - ${replacementNumber}`,
              lines: [
                { accountCode: "4100", debit: refundAmount, description: "Sales returns for replacement difference" },
                { accountCode: "2100", credit: refundAmount, description: "Store credit liability" },
              ],
            });
          }
        }
      }

      // 11. Create replacement record (always 1 unit per replacement)
      const [replacement] = await tx.insert(saleReplacements).values({
        replacementNumber,
        saleId: data.saleId,
        saleItemId: replacementSaleItemId,
        customerId: sale.customerId,
        shopId: shopId,
        branchId: branchId,
        originalProductId: saleItem.productId,
        replacementProductId: data.replacementProductId,
        originalSerialNumberId: data.originalSerialNumberId,
        replacementSerialNumberId: data.replacementSerialNumberId,
        originalSerialNumber: originalSerial.serialNumber,
        replacementSerialNumber: replacementSerial.serialNumber,
        originalQuantity: 1,
        replacementQuantity: 1,
        originalPrice: originalPrice.toFixed(3),
        replacementPrice: replacementPrice.toFixed(3),
        priceDifference: priceDifference.toFixed(3),
        replacementType,
        paymentMethod: data.paymentMethod,
        bankAccountId: data.bankAccountId,
        reason: data.reason,
        status: "completed",
      }).returning();

      return replacement;
    });
  }

  // Sale Payments (Payment History)
  async getSalePayments(saleId?: string): Promise<any[]> {
    if (saleId) {
      return db.select().from(salePayments)
        .where(eq(salePayments.saleId, saleId))
        .orderBy(desc(salePayments.paymentDate));
    }
    return db.select().from(salePayments).orderBy(desc(salePayments.paymentDate));
  }

  async createSalePayment(data: any): Promise<any> {
    const amount = parseFloat(data.amount?.toString() || "0");

    if (amount <= 0) {
      throw new Error("Payment amount must be greater than zero.");
    }

    // LEDGER-DRIVEN: Get invoice summary to check outstanding balance
    const invoiceSummary = await this.getSaleInvoiceSummary(data.saleId);
    if (!invoiceSummary) {
      throw new Error("Sale invoice not found.");
    }

    const balanceRemaining = parseFloat(invoiceSummary.summary.balanceRemaining);

    // OVERPAYMENT PREVENTION: Cannot pay more than outstanding balance
    if (invoiceSummary.summary.storeOwesCustomer) {
      throw new Error("This invoice is fully paid. Customer is owed a refund.");
    }

    if (balanceRemaining <= 0.001) {
      throw new Error("This invoice is already fully paid. No payment can be recorded.");
    }

    if (amount > balanceRemaining + 0.001) {
      throw new Error(`Payment amount (${amount.toFixed(3)} RO) exceeds invoice outstanding balance (${balanceRemaining.toFixed(3)} RO). Overpayment is not allowed.`);
    }

    return await db.transaction(async (tx) => {
      // Create payment record
      const paymentData = {
        saleId: data.saleId,
        customerId: data.customerId || null,
        paymentMethod: data.paymentMethod,
        bankAccountId: data.bankAccountId || null,
        amount: amount.toFixed(3),
        reference: data.reference || null,
        notes: data.notes || null,
      };

      const [payment] = await tx.insert(salePayments).values(paymentData).returning();

      // Update bank account balance if cash/bank payment
      if (data.bankAccountId && data.paymentMethod !== "credit") {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          const newBalance = parseFloat(account.currentBalance || "0") + amount;
          await tx.update(bankAccounts).set({ currentBalance: newBalance.toFixed(3) }).where(eq(bankAccounts.id, data.bankAccountId));
        }
      }

      // Update customer balance if applicable
      if (data.customerId) {
        const [customer] = await tx.select().from(customers).where(eq(customers.id, data.customerId));
        if (customer) {
          const newBalance = parseFloat(customer.currentBalance || "0") - amount;
          await tx.update(customers).set({ currentBalance: newBalance.toFixed(3) }).where(eq(customers.id, data.customerId));
        }
      }

      // Create accounting entry: Debit Bank/Cash, Credit AR
      const journalLines = [];
      if (data.bankAccountId) {
        journalLines.push({ accountCode: "1000", debit: amount, description: `Payment received - Sale ${data.saleId}` });
      }
      journalLines.push({ accountCode: "1100", credit: amount, description: `Reduce AR for payment` });

      // Get shopId/branchId from the original sale first, then fallback to bank account
      const [sale] = await tx.select().from(sales).where(eq(sales.id, data.saleId));
      let journalShopId = sale?.shopId;
      let journalBranchId = sale?.branchId;

      // If sale doesn't have scope, try to get from bank account
      if ((!journalShopId || !journalBranchId) && data.bankAccountId) {
        const [bankAccount] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (bankAccount) {
          journalShopId = journalShopId || bankAccount.shopId;
          journalBranchId = journalBranchId || bankAccount.branchId;
        }
      }
      if (!journalShopId) throw new Error("shopId is required for sale payment journal entry");
      if (!journalBranchId) journalBranchId = journalShopId;

      await this.createJournalEntryInTx(tx, {
        sourceType: "sale_payment",
        sourceId: payment.id,
        shopId: journalShopId,
        branchId: journalBranchId,
        reference: `PMT-${payment.id.slice(0, 8)}`,
        description: `Payment for sale ${data.saleId}`,
        lines: journalLines,
      });

      // Auto-update payment status on the sale based on total payments vs total amount
      const [updatedSale] = await tx.select().from(sales).where(eq(sales.id, data.saleId));
      if (updatedSale) {
        const allPayments = await tx.select({ amount: salePayments.amount })
          .from(salePayments)
          .where(eq(salePayments.saleId, data.saleId));
        const totalPaid = allPayments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);
        const saleTotal = parseFloat(updatedSale.total || "0");
        let newStatus: string;
        if (totalPaid <= 0) {
          newStatus = "unpaid";
        } else if (totalPaid >= saleTotal - 0.001) {
          newStatus = "paid";
        } else {
          newStatus = "partial";
        }
        await tx.update(sales).set({ paymentStatus: newStatus }).where(eq(sales.id, data.saleId));
      }

      return payment;
    });
  }

  async getSaleInvoiceSummary(saleId: string): Promise<any> {
    // Get the sale
    const [sale] = await db.select().from(sales).where(eq(sales.id, saleId));
    if (!sale) return null;

    // Get sale items
    const items = await db.select().from(saleItems).where(eq(saleItems.saleId, saleId));

    // Get returns for this sale
    const returns = await db.select().from(saleReturns).where(eq(saleReturns.saleId, saleId));
    const returnIds = returns.map(r => r.id);
    let returnItems: any[] = [];
    for (const returnId of returnIds) {
      const retItems = await db.select().from(saleReturnItems).where(eq(saleReturnItems.returnId, returnId));
      returnItems = returnItems.concat(retItems);
    }

    // Get replacements for this sale
    const replacements = await db.select().from(saleReplacements).where(eq(saleReplacements.saleId, saleId));

    // Get payments for this sale
    const payments = await db.select().from(salePayments)
      .where(eq(salePayments.saleId, saleId))
      .orderBy(desc(salePayments.paymentDate));

    // Calculate totals - sale total = subtotal + VAT - discount
    const subtotal = parseFloat(sale.subtotal || "0");
    const vat = parseFloat(sale.vatAmount || "0");
    const discount = parseFloat(sale.discount || "0");
    const originalTotal = subtotal + vat - discount;

    // Returns reduce invoice value - track refunds (cash given back) and credits (applied to customer account)
    const totalRefunds = returns.reduce((sum, r) => sum + parseFloat(r.refundAmount || "0"), 0);
    const totalCreditsApplied = returns.reduce((sum, r) => sum + parseFloat(r.creditAmount || "0"), 0);
    const totalReturns = totalRefunds + totalCreditsApplied;
    const replacementAdjustments = replacements.reduce((sum, r) => sum + parseFloat(r.priceDifference || "0"), 0);
    const totalPayments = payments.reduce((sum, p) => sum + parseFloat(p.amount || "0"), 0);

    // Net amount = what customer should have paid after returns/replacements
    const netAmount = originalTotal - totalReturns + replacementAdjustments;

    // Balance = netAmount - totalPayments
    // Positive = customer owes store
    // Negative = store owes customer (overpayment scenario)
    const balanceRemaining = netAmount - totalPayments;

    // Determine invoice status
    let status = "pending";
    if (balanceRemaining <= 0) {
      status = "paid";
    } else if (totalPayments > 0) {
      status = "partial";
    }

    // Check for overpayment/refund due scenario
    const refundDue = balanceRemaining < 0 ? Math.abs(balanceRemaining) : 0;
    const storeOwesCustomer = refundDue > 0;

    return {
      sale,
      items,
      returns,
      returnItems,
      replacements,
      payments,
      summary: {
        originalTotal: originalTotal.toFixed(3),
        totalReturns: totalReturns.toFixed(3),
        totalRefunds: totalRefunds.toFixed(3),
        totalCreditsApplied: totalCreditsApplied.toFixed(3),
        replacementAdjustments: replacementAdjustments.toFixed(3),
        netAmount: netAmount.toFixed(3),
        totalPayments: totalPayments.toFixed(3),
        balanceRemaining: balanceRemaining.toFixed(3),
        refundDue: refundDue.toFixed(3),
        storeOwesCustomer,
        status,
      },
    };
  }

  // Bank Accounts
  async getBankAccounts(scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<BankAccount[]> {
    const conditions: SQL[] = [];
    if (scope?.shopId) {
      conditions.push(eq(bankAccounts.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      conditions.push(eq(bankAccounts.branchId, scope.branchId));
    }
    if (conditions.length > 0) {
      return db.select().from(bankAccounts).where(and(...conditions));
    }
    return db.select().from(bankAccounts);
  }

  async getBankAccount(id: string): Promise<BankAccount | undefined> {
    const [account] = await db.select().from(bankAccounts).where(eq(bankAccounts.id, id));
    return account || undefined;
  }

  async createBankAccount(data: InsertBankAccount): Promise<BankAccount> {
    const accountData = {
      ...data,
      currentBalance: data.openingBalance || "0.000",
    };
    const [account] = await db.insert(bankAccounts).values(accountData).returning();
    return account;
  }

  async updateBankAccount(id: string, data: Partial<InsertBankAccount>): Promise<BankAccount | undefined> {
