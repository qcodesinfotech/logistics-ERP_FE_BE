  async getInventoryByWarehouse(warehouseId: string): Promise<any[]> {
    try {
      console.log(`DEBUG: Fetching inventory for warehouse: ${warehouseId}`);
      const inventoryItems = await db.select().from(inventory).where(eq(inventory.warehouseId, warehouseId));
      console.log(`DEBUG: Found ${inventoryItems.length} items in inventory table`);
      
      const itemsWithProduct = await Promise.all(inventoryItems.map(async (inv) => {
        const [product] = await db.select().from(products).where(eq(products.id, inv.productId));
        return { ...inv, product };
      }));
      
      const filteredItems = itemsWithProduct.filter(item => item.quantity > 0);
      console.log(`DEBUG: Returning ${filteredItems.length} items with quantity > 0`);
      return filteredItems;
    } catch (error) {
      console.error("ERROR in getInventoryByWarehouse:", error);
      throw error;
    }
  }

  async createInventory(data: InsertInventory): Promise<Inventory> {
    const [inv] = await db.insert(inventory).values(data).returning();
    return inv;
