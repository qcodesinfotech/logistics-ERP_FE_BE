  async getProjectBudgetSummary(projectId: string): Promise<{ budget: number; spent: number; remaining: number }> {
    const [project] = await db.select().from(projects).where(eq(projects.id, projectId));
    const baseBudget = parseFloat(project?.totalCost?.toString() || project?.budget?.toString() || "0");

    const [expenseResult] = await db.select({
      total: sql<string>`COALESCE(SUM(CAST(${projectExpenses.amount} AS NUMERIC)), 0)`
    }).from(projectExpenses).where(eq(projectExpenses.projectId, projectId));
    const projectExpensesTotal = parseFloat(expenseResult?.total || "0");

    const projectHourlyRate = parseFloat(project?.hourlyRate?.toString() || "0");
    const [timesheetResult] = await db.select({
      totalHours: sql<string>`COALESCE(SUM(CAST(${timesheets.hours} AS NUMERIC)), 0)`
    })
    .from(timesheets)
    .innerJoin(tasks, eq(timesheets.taskId, tasks.id))
    .where(and(eq(timesheets.projectId, projectId), eq(tasks.billable, true)));
    const timesheetCost = parseFloat(timesheetResult?.totalHours || "0") * projectHourlyRate;

    const [incomeResult] = await db.select({
      total: sql<string>`COALESCE(SUM(CAST(${projectIncome.amount} AS NUMERIC)), 0)`
    }).from(projectIncome).where(eq(projectIncome.projectId, projectId));
    const totalIncome = parseFloat(incomeResult?.total || "0");

    const spent = projectExpensesTotal + timesheetCost;
    const currentBudget = baseBudget + totalIncome;

    return { budget: currentBudget, spent, remaining: currentBudget - spent };
  }

  // Project Income (Client Payments)
  async getProjectIncome(projectId?: string): Promise<ProjectIncome[]> {
    if (projectId) {
      return db.select().from(projectIncome).where(eq(projectIncome.projectId, projectId)).orderBy(desc(projectIncome.paymentDate));
    }
    return db.select().from(projectIncome).orderBy(desc(projectIncome.paymentDate));
  }

  async createProjectIncome(data: InsertProjectIncome): Promise<ProjectIncome> {
    return await db.transaction(async (tx) => {
      const amount = parseFloat(data.amount?.toString() || "0");
      const { companyId, shopId, branchId, ...validData } = data as any;
      if (validData.paymentDate && typeof validData.paymentDate === 'string') validData.paymentDate = new Date(validData.paymentDate);
      if (validData.fromDate && typeof validData.fromDate === 'string') validData.fromDate = new Date(validData.fromDate);
      if (validData.toDate && typeof validData.toDate === 'string') validData.toDate = new Date(validData.toDate);

      // Auto-generate invoice number
      const invoiceNo = await this.getNextProjectInvoiceNumber();

      const [income] = await tx.insert(projectIncome).values({
        ...validData,
        companyId,
        shopId,
        branchId,
        invoiceNo,
      }).returning();

      // Get project for client info
      const [project] = await tx.select().from(projects).where(eq(projects.id, data.projectId));


      // ONLY process financial logic (bank updates + journal entries) if status is 'paid'
      if (data.paymentStatus === 'paid' && amount > 0) {
        // Update bank balance if bank account specified
        if (data.bankAccountId) {
          const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
          if (account) {
            await tx.update(bankAccounts)
              .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${amount}` })
              .where(eq(bankAccounts.id, data.bankAccountId));

            await tx.insert(bankTransactions).values({
              bankAccountId: data.bankAccountId,
              shopId: account.shopId,
              branchId: account.branchId,
              type: "deposit",
              amount: amount.toString(),
              reference: income.invoiceNo ? `INV-${income.invoiceNo}` : `PINC-${income.id.slice(0, 8)}`,
              description: `Project income: ${project?.name || 'Unknown'}`,
              relatedType: "project_income",
              relatedId: income.id,
            });
          }
        }

        // Create journal entry: Debit Cash/Bank, Credit Project Service Income (4100)
        let incomeShopId = project?.shopId || shopId;
        let incomeBranchId = project?.branchId || branchId;

        if ((!incomeShopId || !incomeBranchId) && data.bankAccountId) {
          const [bankAccount] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
          if (bankAccount) {
            incomeShopId = incomeShopId || bankAccount.shopId;
            incomeBranchId = incomeBranchId || bankAccount.branchId;
          }
        }
        
        incomeShopId = incomeShopId || shopId;
        incomeBranchId = incomeBranchId || branchId;

        if (!incomeShopId && project?.companyId) {
          const [anyShop] = await tx.select().from(shops).where(eq(shops.companyId, project.companyId)).limit(1);
          if (anyShop) incomeShopId = anyShop.id;
        }

        if (!incomeShopId) {
          const [fallbackShop] = await tx.select().from(shops).limit(1);
          if (fallbackShop) incomeShopId = fallbackShop.id;
        }

        if (incomeShopId) {
          if (!incomeBranchId) {
            const [branch] = await tx.select().from(branches).where(eq(branches.shopId, incomeShopId)).limit(1);
            incomeBranchId = branch?.id || incomeShopId;
          }

          await this.createJournalEntryInTx(tx, {
            sourceType: "project_income",
            sourceId: income.id,
            shopId: incomeShopId,
            branchId: incomeBranchId,
            reference: income.invoiceNo ? `INV-${income.invoiceNo}` : `PINC-${income.id.slice(0, 8)}`,
            description: `Project payment: ${data.description || project?.name || 'Client payment'}`,
            projectId: data.projectId,
            clientId: data.clientId || project?.clientId || undefined,
            lines: [
              { accountCode: "1000", debit: amount, description: "Cash/Bank received" },
              { accountCode: "4100", credit: amount, description: "Project service income" },
            ],
          });
        }
      }

      return income;
    });
  }

  async confirmProjectIncomePayment(
    id: string,
    paymentData: {
      payments: Array<{ bankAccountId: string; amount: number }>;
      paymentDate: Date;
      paymentMethod: string;
      reference: string;
    }
  ): Promise<ProjectIncome> {
    return await db.transaction(async (tx) => {
      const [income] = await tx.select().from(projectIncome).where(eq(projectIncome.id, id));
      if (!income) throw new Error("Transaction not found");
      if (income.paymentStatus === 'paid') return income;

      const [project] = await tx.select().from(projects).where(eq(projects.id, income.projectId));
      const totalAmount = parseFloat(income.amount.toString());

      // Use first bank account as primary for record-keeping
      const primaryAccountId = paymentData.payments[0]?.bankAccountId;

      // Update income record — determine if partial or full payment
      const newPaymentTotal = paymentData.payments.reduce((s, p) => s + Number(p.amount), 0);
      const updatedPaidAmount = Number(income.paidAmount || 0) + newPaymentTotal;
      const isFullPayment = Math.abs(updatedPaidAmount - totalAmount) < 0.001 || updatedPaidAmount > totalAmount;
      const newStatus = isFullPayment ? 'paid' : 'partial';

      // Update income record
      const [updatedIncome] = await tx.update(projectIncome).set({
        paymentStatus: newStatus,
        paidAmount: updatedPaidAmount.toString(),
        bankAccountId: primaryAccountId,
        paymentDate: paymentData.paymentDate,
        paymentMethod: paymentData.paymentMethod,
        reference: paymentData.reference,
      }).where(eq(projectIncome.id, id)).returning();

      const invoiceRef = updatedIncome.invoiceNo ?? `PINC-${updatedIncome.id.slice(0, 8)}`;
      let firstAccountForJournal: typeof bankAccounts.$inferSelect | null = null;

      // Process each split payment
      for (const split of paymentData.payments) {
        if (!split.bankAccountId || split.amount <= 0) continue;

        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, split.bankAccountId));
        if (!account) continue;

        if (!firstAccountForJournal) firstAccountForJournal = account;

        await tx.update(bankAccounts)
          .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) + ${split.amount}` })
          .where(eq(bankAccounts.id, split.bankAccountId));

        await tx.insert(bankTransactions).values({
          bankAccountId: split.bankAccountId,
          shopId: account.shopId,
          branchId: account.branchId,
          type: "deposit",
          amount: split.amount.toString(),
          reference: invoiceRef,
          description: `Project payment [${account.bankName}]: ${project?.name || 'Unknown'}`,
          relatedType: "project_income",
          relatedId: updatedIncome.id,
        });
      }

      // Create a single journal entry for the full amount using first account's scope
      if (firstAccountForJournal) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "project_income",
          sourceId: updatedIncome.id,
          shopId: firstAccountForJournal.shopId,
          branchId: firstAccountForJournal.branchId,
          reference: invoiceRef,
          description: `Project payment: ${updatedIncome.description || project?.name || 'Client payment'}`,
          projectId: updatedIncome.projectId,
          clientId: updatedIncome.clientId || project?.clientId || undefined,
          lines: [
            { accountCode: "1000", debit: newPaymentTotal, description: "Cash/Bank received" },
            { accountCode: "4100", credit: newPaymentTotal, description: "Project service income" },
          ],
        });
      }

      return updatedIncome;
    });
  }

  async updateProjectIncome(id: string, data: any): Promise<ProjectIncome> {
    const { companyId, shopId, branchId, ...validData } = data;
    if (validData.paymentDate && typeof validData.paymentDate === 'string') validData.paymentDate = new Date(validData.paymentDate);
    if (validData.fromDate && typeof validData.fromDate === 'string') validData.fromDate = new Date(validData.fromDate);
    if (validData.toDate && typeof validData.toDate === 'string') validData.toDate = new Date(validData.toDate);
    const [income] = await db.update(projectIncome).set({
      ...validData,
      companyId,
      shopId,
      branchId
    }).where(eq(projectIncome.id, id)).returning();
    return income;
  }

  async deleteProjectIncome(id: string): Promise<void> {
    await db.delete(projectIncome).where(eq(projectIncome.id, id));
  }

  // Complete task - OPERATIONAL ONLY, no accounting entries
  // Tasks are for progress tracking, time tracking, and billable classification
  // Accounting entries are ONLY created through Project Expenses or Payroll
  async completeTask(taskId: string, actualHours: number): Promise<Task> {
    const [task] = await db.select().from(tasks).where(eq(tasks.id, taskId));
    if (!task) throw new Error("Task not found");

    // Update task status and actual hours - NO accounting entries
    const [updatedTask] = await db.update(tasks)
      .set({
        status: "completed",
        actualHours: actualHours.toString(),
        completedAt: new Date(),
      })
      .where(eq(tasks.id, taskId))
      .returning();

    return updatedTask;
  }

  // Create project expense with proper accounting
  async createProjectExpenseWithAccounting(data: InsertProjectExpense): Promise<any> {
    const amount = parseFloat(data.amount?.toString() || "0");

    // VALIDATION: Branch is required for proper accounting
    if (!data.branchId) {
      throw new Error("Branch is required for project expenses. Please select a branch.");
    }

    // VALIDATION: Bank account is required for cash outflow
    if (amount > 0 && !data.bankAccountId) {
      throw new Error("Bank account is required for project expenses with cost.");
    }

    // STRICT FINANCIAL CONTROL: Validate sufficient funds before project expense
    if (amount > 0 && data.bankAccountId) {
      await this.ensureSufficientFunds(amount, data.bankAccountId, "project expense");
    }

    return await db.transaction(async (tx) => {
      const [expense] = await tx.insert(projectExpenses).values(data).returning();

      // Get project info for tagging
      let project = null;
      if (data.projectId) {
        [project] = await tx.select().from(projects).where(eq(projects.id, data.projectId));
      }

      // Update bank balance if specified
      if (data.bankAccountId && amount > 0) {
        const [account] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (account) {
          await tx.update(bankAccounts)
            .set({ currentBalance: sql`CAST(current_balance AS NUMERIC) - ${amount}` })
            .where(eq(bankAccounts.id, data.bankAccountId));

          await tx.insert(bankTransactions).values({
            bankAccountId: data.bankAccountId,
            shopId: account.shopId,
            branchId: account.branchId,
            type: "withdrawal",
            amount: amount.toString(),
            reference: `PEXP-${expense.id.slice(0, 8)}`,
            description: `Project expense: ${data.description || data.category}`,
            relatedType: "project_expense",
            relatedId: expense.id,
          });
        }
      }

      // Map category to expense account
      const expenseAccountCode = this.getExpenseAccountCode(data.category || "other");

      // Create journal entry: Debit Expense Account, Credit Cash/Bank
      // Get shopId from data (enforced by scope middleware), project, or bank account as fallback
      let expenseShopId = data.shopId || project?.shopId;
      let expenseBranchId = data.branchId || project?.branchId;

      // If still missing, try to get from bank account
      if ((!expenseShopId || !expenseBranchId) && data.bankAccountId) {
        const [bankAccount] = await tx.select().from(bankAccounts).where(eq(bankAccounts.id, data.bankAccountId));
        if (bankAccount) {
          expenseShopId = expenseShopId || bankAccount.shopId;
          expenseBranchId = expenseBranchId || bankAccount.branchId;
        }
      }
      if (!expenseShopId) throw new Error("shopId is required for project expense journal entry");
      if (!expenseBranchId && expenseShopId) {
        const [branch] = await tx.select().from(branches).where(eq(branches.shopId, expenseShopId)).limit(1);
        expenseBranchId = branch?.id || expenseShopId;
      }

      await this.createJournalEntryInTx(tx, {
        sourceType: "project_expense",
        sourceId: expense.id,
        shopId: expenseShopId!,
        branchId: expenseBranchId!,
        reference: `PEXP-${expense.id.slice(0, 8)}`,
        description: `Project expense: ${data.description || data.category}`,
        projectId: data.projectId || undefined,
        taskId: data.taskId || undefined,
        lines: [
          { accountCode: expenseAccountCode, debit: amount, description: data.description || data.category || "Project expense" },
          { accountCode: "1000", credit: amount, description: "Cash/Bank payment" },
        ],
      });

      return expense;
    });
  }

  private getExpenseAccountCode(category: string): string {
    const categoryToAccount: Record<string, string> = {
      materials: "6400",  // Office Supplies & Materials
      labor: "6100",      // Salary & Labor Expense
      equipment: "6600",  // Equipment & Maintenance (Repairs & Maintenance)
      travel: "6200",     // Travel Expense
      utilities: "6300",  // Utilities Expense
      other: "6900",      // Other Expense
    };
    return categoryToAccount[category] || "6900";
  }

  // Get Project P&L derived from accounting entries
  async getProjectProfitLoss(projectId: string): Promise<{
    income: number;
    expenses: number;
    profit: number;
    incomeDetails: any[];
    expenseDetails: any[];
  }> {
    // Get all journal lines tagged with this project
    const lines = await db.select({
      debit: journalLines.debit,
      credit: journalLines.credit,
      description: journalLines.description,
      accountId: journalLines.accountId,
    }).from(journalLines).where(eq(journalLines.projectId, projectId));

    // Get account types for each line
    let totalIncome = 0;
    let totalExpenses = 0;
    const incomeDetails: any[] = [];
    const expenseDetails: any[] = [];

    for (const line of lines) {
      const [account] = await db.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, line.accountId));
      if (!account) continue;

      const debit = parseFloat(line.debit?.toString() || "0");
      const credit = parseFloat(line.credit?.toString() || "0");

      if (account.accountType === "revenue") {
        // Revenue accounts increase with credits
        totalIncome += credit - debit;
        if (credit > 0) {
          incomeDetails.push({
            accountName: account.name,
            amount: credit,
            description: line.description,
          });
        }
      } else if (account.accountType === "expense") {
        // Expense accounts increase with debits
        totalExpenses += debit - credit;
        if (debit > 0) {
          expenseDetails.push({
            accountName: account.name,
            amount: debit,
            description: line.description,
          });
        }
      }
    }

    return {
      income: totalIncome,
      expenses: totalExpenses,
      profit: totalIncome - totalExpenses,
      incomeDetails,
      expenseDetails,
    };
  }

  // Get project timeline status
  getProjectTimelineStatus(project: Project): string {
    if (!project.endDate) return "no_deadline";

    const today = new Date();
    const endDate = new Date(project.endDate);
    const completedDate = project.completedDate ? new Date(project.completedDate) : null;

    if (project.status === "completed" && completedDate) {
      if (completedDate < endDate) return "early";
      if (completedDate.toDateString() === endDate.toDateString()) return "on_time";
      return "delayed";
    }

    if (project.status !== "completed") {
      if (today > endDate) return "delayed_running";
      return "in_progress";
    }

    return "unknown";
  }

  // Stock Transfers
  async getStockTransfers(): Promise<StockTransfer[]> {
    return db.select().from(stockTransfers).orderBy(desc(stockTransfers.transferDate));
  }

  async getStockTransfer(id: string): Promise<StockTransfer | undefined> {
    const [transfer] = await db.select().from(stockTransfers).where(eq(stockTransfers.id, id));
    return transfer;
  }

  async getStockTransferItems(transferId: string): Promise<any[]> {
    const items = await db.select().from(stockTransferItems).where(eq(stockTransferItems.stockTransferId, transferId));
    const itemsWithProduct = await Promise.all(items.map(async (item) => {
      const [product] = await db.select().from(products).where(eq(products.id, item.productId));
      return { ...item, product };
    }));
    return itemsWithProduct;
  }

  async createStockTransfer(data: any): Promise<StockTransfer> {
    return db.transaction(async (tx) => {
      const transferNumber = await this.getNextNumber("TR");
      const items = data.items || [];

      const [transfer] = await tx.insert(stockTransfers).values({
        transferNumber,
        fromWarehouseId: data.fromWarehouseId,
        toWarehouseId: data.toWarehouseId,
        companyId: data.companyId || null,
        shopId: data.shopId || null,
        fromBranchId: data.fromBranchId || null,
        toBranchId: data.toBranchId || null,
        notes: data.notes || null,
        status: items.length > 0 ? "completed" : "pending",
      }).returning();

      let totalTransferValue = 0;

      for (const item of items) {
        const [sourceInv] = await tx.select().from(inventory)
          .where(and(
            eq(inventory.productId, item.productId),
            eq(inventory.warehouseId, data.fromWarehouseId)
          ));

        if (!sourceInv || sourceInv.quantity < item.quantity) {
          const [product] = await tx.select({ name: products.name }).from(products).where(eq(products.id, item.productId));
          throw new Error(`Insufficient stock for ${product?.name || 'product'}. Available: ${sourceInv?.quantity || 0}, Requested: ${item.quantity}`);
        }
        
        totalTransferValue += (Number(sourceInv.costPrice || 0) * item.quantity);

        await tx.insert(stockTransferItems).values({
          stockTransferId: transfer.id,
          productId: item.productId,
          inventoryId: sourceInv.id,
          quantity: item.quantity,
          serialNumbers: item.serialNumbers || null,
        });

        const newSourceQty = Math.max(0, sourceInv.quantity - item.quantity);
        await tx.update(inventory).set({ quantity: newSourceQty }).where(eq(inventory.id, sourceInv.id));

        const [destInv] = await tx.select().from(inventory)
          .where(and(
            eq(inventory.productId, item.productId),
            eq(inventory.warehouseId, data.toWarehouseId)
          ));

        if (destInv) {
          await tx.update(inventory).set({ quantity: destInv.quantity + item.quantity }).where(eq(inventory.id, destInv.id));
        } else {
          await tx.insert(inventory).values({
            productId: item.productId,
            warehouseId: data.toWarehouseId,
            quantity: item.quantity,
            costPrice: sourceInv.costPrice || "0.000",
          });
        }

        if (item.serialNumbers) {
          const serials = item.serialNumbers.split(',').map((s: string) => s.trim()).filter((s: string) => s);
          for (const serialNum of serials) {
            await tx.update(serialNumbers)
              .set({ warehouseId: data.toWarehouseId })
              .where(eq(serialNumbers.serialNumber, serialNum));
          }
        }
      }

      if (data.bankAccountId && totalTransferValue > 0) {
        await this.createJournalEntryInTx(tx, {
          sourceType: "stock_transfer",
          sourceId: transfer.id,
          reference: `TR-${transferNumber}`,
          description: `Stock Transfer - ${transferNumber}`,
          shopId: data.shopId!,
          branchId: data.fromBranchId!,
          lines: [
            { accountCode: "1001", credit: totalTransferValue, description: "Bank account reduction for transfer" },
            { accountCode: "1200", credit: totalTransferValue, description: "Inventory asset reduction" },
            { accountCode: "5000", debit: totalTransferValue * 2, description: "Stock Transfer Cost" }
          ]
        });
      }

      return transfer;
    });
  }

  // Dashboard Stats - Filtered by scope (shop/branch/warehouse)
  async getDashboardStats(scope?: { shopId?: string | null; branchId?: string | null; warehouseId?: string | null } | null): Promise<any> {
    // Build scope conditions for each table
    const salesConditions = [];
    const purchaseConditions = [];
    const inventoryConditions = [];
    const customerConditions = [];
    const supplierConditions = [];
    const productConditions = [];
    const employeeConditions = [];

    if (scope?.shopId) {
      salesConditions.push(eq(sales.shopId, scope.shopId));
      purchaseConditions.push(eq(purchases.shopId, scope.shopId));
      customerConditions.push(eq(customers.shopId, scope.shopId));
      supplierConditions.push(eq(suppliers.shopId, scope.shopId));
      productConditions.push(eq(products.shopId, scope.shopId));
      employeeConditions.push(eq(employees.shopId, scope.shopId));
    }

    if (scope?.branchId) {
      salesConditions.push(eq(sales.branchId, scope.branchId));
      purchaseConditions.push(eq(purchases.branchId, scope.branchId));
      customerConditions.push(eq(customers.branchId, scope.branchId));
      supplierConditions.push(eq(suppliers.branchId, scope.branchId));
      productConditions.push(eq(products.branchId, scope.branchId));
      employeeConditions.push(eq(employees.branchId, scope.branchId));
    }

    if (scope?.warehouseId) {
      inventoryConditions.push(eq(inventory.warehouseId, scope.warehouseId));
    }

    // Sales aggregation with scope
    const salesQuery = db.select({
      total: sql<string>`COALESCE(SUM(CAST(total AS NUMERIC)), 0)`,
      count: sql<number>`count(*)`
    }).from(sales);
    const [salesResult] = salesConditions.length > 0
      ? await salesQuery.where(and(...salesConditions))
      : await salesQuery;

    // Purchases aggregation with scope
    const purchaseQuery = db.select({
      total: sql<string>`COALESCE(SUM(CAST(total AS NUMERIC)), 0)`,
      count: sql<number>`count(*)`
    }).from(purchases);
    const [purchasesResult] = purchaseConditions.length > 0
      ? await purchaseQuery.where(and(...purchaseConditions))
      : await purchaseQuery;

    // Inventory aggregation with scope
    const inventoryQuery = db.select({
      count: sql<number>`count(*)`,
      totalValue: sql<string>`COALESCE(SUM(CAST(cost_price AS NUMERIC) * quantity), 0)`
    }).from(inventory);
    const [inventoryResult] = inventoryConditions.length > 0
      ? await inventoryQuery.where(and(...inventoryConditions))
      : await inventoryQuery;

    // Customers count with scope
    const customersQuery = db.select({ count: sql<number>`count(*)` }).from(customers);
    const [customersResult] = customerConditions.length > 0
      ? await customersQuery.where(and(...customerConditions))
      : await customersQuery;

    // Suppliers count with scope
    const suppliersQuery = db.select({ count: sql<number>`count(*)` }).from(suppliers);
    const [suppliersResult] = supplierConditions.length > 0
      ? await suppliersQuery.where(and(...supplierConditions))
      : await suppliersQuery;

    // Products count with scope
    const productsQuery = db.select({ count: sql<number>`count(*)` }).from(products);
    const [productsResult] = productConditions.length > 0
      ? await productsQuery.where(and(...productConditions))
      : await productsQuery;

    // Employees count with scope
    const employeesQuery = db.select({ count: sql<number>`count(*)` }).from(employees);
    const [employeesResult] = employeeConditions.length > 0
      ? await employeesQuery.where(and(...employeeConditions))
      : await employeesQuery;

    // Pending leave requests count with scope
    const pendingLeaveConditions = [eq(leaveRequests.status, "pending")];
    if (scope?.shopId) {
      // Need to join with employees to scope by shop
      pendingLeaveConditions.push(
        sql`${leaveRequests.employeeId} IN (SELECT id FROM employees WHERE shop_id = ${scope.shopId})`
      );
    }
    if (scope?.branchId) {
      pendingLeaveConditions.push(
        sql`${leaveRequests.employeeId} IN (SELECT id FROM employees WHERE branch_id = ${scope.branchId})`
      );
    }
    
    const pendingLeaveQuery = db.select({ count: sql<number>`count(*)` }).from(leaveRequests);
    const [pendingLeaveResult] = pendingLeaveConditions.length > 0
      ? await pendingLeaveQuery.where(and(...pendingLeaveConditions))
      : await pendingLeaveQuery;

    // Recent sales with scope
    const recentSalesQuery = db.select().from(sales).orderBy(desc(sales.saleDate)).limit(5);
    const recentSales = salesConditions.length > 0
      ? await recentSalesQuery.where(and(...salesConditions))
      : await recentSalesQuery;

    // Bank balance - sum of all bank accounts (scope-filtered if applicable)
    const bankAccountConditions = [];
    if (scope?.shopId) {
      bankAccountConditions.push(eq(bankAccounts.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      bankAccountConditions.push(eq(bankAccounts.branchId, scope.branchId));
    }
    const bankAccountsQuery = db.select({
      total: sql<string>`COALESCE(SUM(CAST(current_balance AS NUMERIC)), 0)`
    }).from(bankAccounts);
    const [bankBalanceResult] = bankAccountConditions.length > 0
      ? await bankAccountsQuery.where(and(...bankAccountConditions))
      : await bankAccountsQuery;

    // Pending receivables - actual outstanding balance of unpaid/partial sales
    // Uses raw SQL to avoid Drizzle ORM correlated subquery rendering issues
    const receivablesWhereClause: string[] = [`sales.payment_status IN ('unpaid', 'partial')`];
    const receivablesParams: string[] = [];
    if (scope?.shopId) {
      receivablesParams.push(scope.shopId);
      receivablesWhereClause.push(`sales.shop_id = $${receivablesParams.length}`);
    }
    if (scope?.branchId) {
      receivablesParams.push(scope.branchId);
      receivablesWhereClause.push(`sales.branch_id = $${receivablesParams.length}`);
    }
    const receivablesRawSql = `
      SELECT COALESCE(SUM(
        CAST(sales.total AS NUMERIC) -
        COALESCE((SELECT SUM(CAST(sp.amount AS NUMERIC)) FROM sale_payments sp WHERE sp.sale_id = sales.id), 0)
      ), 0) as total
      FROM sales
      WHERE ${receivablesWhereClause.join(' AND ')}
    `;
    const receivablesRawResult = await db.execute(sql.raw(
      receivablesParams.length > 0
        ? receivablesRawSql.replace(/\$(\d+)/g, (_, i) => `'${receivablesParams[parseInt(i) - 1]}'`)
        : receivablesRawSql
    ));
    const receivablesResult = { total: (receivablesRawResult.rows?.[0] as any)?.total ?? "0" };

    // Low stock products (quantity <= reorder point)
    const lowStockQuery = db.select({
      id: products.id,
      name: products.name,
      quantity: products.productQty,
    }).from(products)
      .where(
        and(
          sql`CAST(${products.productQty} AS INTEGER) <= CAST(COALESCE(${products.reorderPoint}, '0') AS INTEGER)`,
          sql`CAST(COALESCE(${products.reorderPoint}, '0') AS INTEGER) > 0`,
          ...(productConditions.length > 0 ? productConditions : [])
        )
      ).limit(5);
    const lowStockProducts = await lowStockQuery;

    // Expiring products (within 30 days)
    const thirtyDaysFromNow = new Date();
    thirtyDaysFromNow.setDate(thirtyDaysFromNow.getDate() + 30);
    const expiringQuery = db.select({
      id: products.id,
      name: products.name,
      expiryDate: products.expiryDate,
    }).from(products)
      .where(
        and(
          sql`${products.expiryDate} IS NOT NULL`,
          sql`${products.expiryDate} <= ${thirtyDaysFromNow.toISOString().split('T')[0]}`,
          sql`${products.expiryDate} >= CURRENT_DATE`,
          ...(productConditions.length > 0 ? productConditions : [])
        )
      ).limit(5);
    const expiringProducts = await expiringQuery;

    return {
      totalSales: salesResult?.total || "0.000",
      salesCount: Number(salesResult?.count || 0),
      totalPurchases: purchasesResult?.total || "0.000",
      purchasesCount: Number(purchasesResult?.count || 0),
      inventoryValue: inventoryResult?.totalValue || "0.000",
      inventoryCount: Number(inventoryResult?.count || 0),
      customersCount: Number(customersResult?.count || 0),
      suppliersCount: Number(suppliersResult?.count || 0),
      productsCount: Number(productsResult?.count || 0),
      employeesCount: Number(employeesResult?.count || 0),
      recentSales,
      bankBalance: bankBalanceResult?.total || "0.000",
      pendingReceivables: receivablesResult?.total || "0.000",
      lowStockProducts: lowStockProducts.map(p => ({
        id: p.id,
        name: p.name,
        quantity: Number(p.quantity || 0)
      })),
      expiringProducts: expiringProducts.map(p => ({
        id: p.id,
        name: p.name,
        expiryDate: p.expiryDate
      })),
      pendingLeaveRequests: Number(pendingLeaveResult?.count || 0),
    };
  }

  // Chart of Accounts - Shop-scoped (each shop has its own accounts with same codes)
  async getChartOfAccounts(companyId?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<ChartOfAccount[]> {
    const conditions = [];
    if (companyId) {
      conditions.push(eq(chartOfAccounts.companyId, companyId));
    }
    // Always filter by shop_id to ensure data isolation
    if (scope?.shopId) {
      conditions.push(eq(chartOfAccounts.shopId, scope.shopId));
    }
    if (conditions.length > 0) {
      return db.select().from(chartOfAccounts).where(and(...conditions)).orderBy(asc(chartOfAccounts.accountCode));
    }
    return db.select().from(chartOfAccounts).orderBy(asc(chartOfAccounts.accountCode));
  }

  async getChartOfAccount(id: string): Promise<ChartOfAccount | undefined> {
    const [account] = await db.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, id));
    return account || undefined;
  }

  async getChartOfAccountByCodeAndBranch(accountCode: string, branchId: string): Promise<ChartOfAccount | undefined> {
    const [account] = await db.select().from(chartOfAccounts)
      .where(and(
        eq(chartOfAccounts.accountCode, accountCode),
        eq(chartOfAccounts.branchId, branchId)
      ));
    return account || undefined;
  }

  async createChartOfAccount(data: InsertChartOfAccounts): Promise<ChartOfAccount> {
    const [account] = await db.insert(chartOfAccounts).values(data).returning();
    return account;
  }

  async updateChartOfAccount(id: string, data: Partial<InsertChartOfAccounts>): Promise<ChartOfAccount | undefined> {
    const [account] = await db.update(chartOfAccounts).set(data).where(eq(chartOfAccounts.id, id)).returning();
    return account || undefined;
  }

  async deleteChartOfAccount(id: string): Promise<void> {
    await db.delete(chartOfAccounts).where(eq(chartOfAccounts.id, id));
  }

  async seedChartOfAccountsForBranch(branchId: string): Promise<{ created: number; existing: number }> {
    const defaultAccounts = [
      { accountCode: "1000", name: "Cash and Bank", accountType: "asset" },
      { accountCode: "1100", name: "Accounts Receivable", accountType: "asset" },
      { accountCode: "1110", name: "Supplier Receivable", accountType: "asset" },
      { accountCode: "1200", name: "Inventory", accountType: "asset" },
      { accountCode: "1300", name: "Employee Advances", accountType: "asset" },
      { accountCode: "1400", name: "Prepaid Expenses", accountType: "asset" },
      { accountCode: "1500", name: "Fixed Assets", accountType: "asset" },
      { accountCode: "2000", name: "Accounts Payable", accountType: "liability" },
      { accountCode: "2010", name: "Supplier Credit", accountType: "liability" },
      { accountCode: "2100", name: "Accrued Salary Payable", accountType: "liability" },
      { accountCode: "2150", name: "VAT Payable", accountType: "liability" },
      { accountCode: "2200", name: "Accrued Expenses", accountType: "liability" },
      { accountCode: "2300", name: "Loans Payable", accountType: "liability" },
      { accountCode: "3000", name: "Owner's Capital", accountType: "equity" },
      { accountCode: "3100", name: "Owner's Drawings", accountType: "equity" },
      { accountCode: "3200", name: "Retained Earnings", accountType: "equity" },
      { accountCode: "4000", name: "Sales Revenue", accountType: "revenue" },
      { accountCode: "4100", name: "Service Revenue", accountType: "revenue" },
      { accountCode: "4200", name: "Other Income", accountType: "revenue" },
      { accountCode: "5000", name: "Cost of Goods Sold", accountType: "expense" },
      { accountCode: "5100", name: "Freight & Handling Expense", accountType: "expense" },
      { accountCode: "5150", name: "Other Charges Expense", accountType: "expense" },
      { accountCode: "5200", name: "Purchase Discounts", accountType: "revenue" },
      { accountCode: "6000", name: "General Expenses", accountType: "expense" },
      { accountCode: "6100", name: "Salary & Labor Expense", accountType: "expense" },
      { accountCode: "6200", name: "Travel Expense", accountType: "expense" },
      { accountCode: "6300", name: "Utilities Expense", accountType: "expense" },
      { accountCode: "6400", name: "Office Supplies", accountType: "expense" },
      { accountCode: "6500", name: "Rent Expense", accountType: "expense" },
      { accountCode: "6600", name: "Repairs & Maintenance", accountType: "expense" },
      { accountCode: "6700", name: "Marketing Expense", accountType: "expense" },
      { accountCode: "6900", name: "Other Expense", accountType: "expense" },
    ];

    let created = 0;
    let existing = 0;

    for (const account of defaultAccounts) {
      const existingAccount = await this.getChartOfAccountByCodeAndBranch(account.accountCode, branchId);
      if (!existingAccount) {
        await db.insert(chartOfAccounts).values({
          ...account,
          branchId,
        });
        created++;
      } else {
        existing++;
      }
    }

    return { created, existing };
  }

  async seedChartOfAccountsForShop(shopId: string, branchId: string): Promise<{
    return { created: 0, existing: 0 };
  }

  // Journal Entries
  async getJournalEntries(companyId?: string, sourceType?: string, sourceId?: string, shopId?: string, branchId?: string): Promise<JournalEntry[]> {
    const conditions = [];
    if (companyId) {
      conditions.push(eq(journalEntries.companyId, companyId));
    }
    if (shopId) {
      conditions.push(eq(journalEntries.shopId, shopId));
    }
    if (branchId) {
      conditions.push(eq(journalEntries.branchId, branchId));
    }
    if (sourceType) {
      conditions.push(eq(journalEntries.sourceType, sourceType));
    }
    if (sourceId) {
      conditions.push(eq(journalEntries.sourceId, sourceId));
    }

    if (conditions.length > 0) {
      return db.select().from(journalEntries).where(and(...conditions)).orderBy(desc(journalEntries.entryDate));
    }
    return db.select().from(journalEntries).orderBy(desc(journalEntries.entryDate));
  }

  async getJournalEntry(id: string): Promise<JournalEntry | undefined> {
    const [entry] = await db.select().from(journalEntries).where(eq(journalEntries.id, id));
    return entry || undefined;
  }

  async createJournalEntry(data: any, lines: any[]): Promise<JournalEntry> {
    const entryNumber = await this.getNextJournalNumber();

    return await db.transaction(async (tx) => {
      const [entry] = await tx.insert(journalEntries).values({
        entryNumber,
        entryDate: data.entryDate || new Date(),
        companyId: data.companyId,
        reference: data.reference,
        description: data.description,
        sourceType: data.sourceType || "manual",
        sourceId: data.sourceId,
        status: data.status || "posted",
      }).returning();

      for (const line of lines) {
        await tx.insert(journalLines).values({
          journalEntryId: entry.id,
          accountId: line.accountId,
          debit: line.debit?.toString() || "0.000",
          credit: line.credit?.toString() || "0.000",
          description: line.description,
        });

        // Update account balance
        const [account] = await tx.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, line.accountId));
        if (account) {
          const currentBalance = parseFloat(account.balance || "0");
          const debitAmount = parseFloat(line.debit || "0");
          const creditAmount = parseFloat(line.credit || "0");
          // For assets/expenses: debit increases, credit decreases
          // For liabilities/equity/revenue: credit increases, debit decreases
          let newBalance = currentBalance;
          if (["asset", "expense"].includes(account.accountType)) {
            newBalance = currentBalance + debitAmount - creditAmount;
          } else {
            newBalance = currentBalance - debitAmount + creditAmount;
          }
          await tx.update(chartOfAccounts).set({ balance: newBalance.toFixed(3) }).where(eq(chartOfAccounts.id, line.accountId));
        }
      }

      return entry;
    });
  }

  private async getNextJournalNumber(): Promise<string> {
    const result = await db.select({ count: sql<number>`count(*)` }).from(journalEntries);
    const count = Number(result[0]?.count || 0);
    return `JE-${(count + 1).toString().padStart(6, "0")}`;
  }

  async getJournalLines(journalEntryId: string): Promise<JournalLine[]> {
    return db.select().from(journalLines).where(eq(journalLines.journalEntryId, journalEntryId));
  }

  // Get customer's Accounts Receivable statement from journal entries only
  async getCustomerARStatement(customerId: string): Promise<{ entries: any[]; openingBalance: number }> {
    // Get customer's opening balance
    const customer = await db.select().from(customers).where(eq(customers.id, customerId)).limit(1);
    const openingBalance = customer.length > 0 ? parseFloat(customer[0].openingBalance || "0") : 0;

    // Get all sales for this customer
    const customerSales = await db.select().from(sales).where(eq(sales.customerId, customerId));
    const saleIds = customerSales.map(s => s.id);
    const saleMap = new Map(customerSales.map(s => [s.id, s]));

    // Get all sale returns for this customer's sales
    const customerReturns = saleIds.length > 0
      ? await db.select().from(saleReturns).where(inArray(saleReturns.saleId, saleIds))
      : [];
    const returnIds = customerReturns.map(r => r.id);
    const returnMap = new Map(customerReturns.map(r => [r.id, r]));

    // Get all journal entries related to this customer
    // 1. Sale journal entries (sourceType = 'sale')
    // 2. Sale return journal entries (sourceType = 'sale_return')
    // 3. Customer payment entries (sourceType = 'customer_payment')
    // 4. Customer refund entries (sourceType = 'customer_refund')
    // 5. Opening balance clearing entries (sourceType = 'opening_balance_clear')
    const allJournalEntries = await db.select().from(journalEntries);

    const relevantEntries = allJournalEntries.filter(e => {
      if (e.sourceType === 'sale' && saleIds.includes(e.sourceId || '')) return true;
      if (e.sourceType === 'sale_return' && returnIds.includes(e.sourceId || '')) return true;
      if (e.sourceType === 'sale_replacement' && saleIds.includes(e.sourceId || '')) return true;
      if (e.sourceType === 'customer_payment' && e.sourceId === customerId) return true;
      if (e.sourceType === 'customer_refund' && e.sourceId === customerId) return true;
      if (e.sourceType === 'opening_balance_clear' && e.sourceId === customerId) return true;
      return false;
    });

    // Get AR account ID (code 1100)
    const arAccounts = await db.select().from(chartOfAccounts).where(eq(chartOfAccounts.accountCode, "1100"));
    const arAccountIds = arAccounts.map(a => a.id);

    // Get all journal lines for relevant entries that affect AR
    const arEntries: any[] = [];

    for (const entry of relevantEntries) {
      const lines = await db.select().from(journalLines).where(eq(journalLines.journalEntryId, entry.id));
      const arLines = lines.filter(l => arAccountIds.includes(l.accountId));

      if (arLines.length > 0) {
        // Sum debits and credits for this entry's AR lines
        const totalDebit = arLines.reduce((sum, l) => sum + parseFloat(l.debit || "0"), 0);
        const totalCredit = arLines.reduce((sum, l) => sum + parseFloat(l.credit || "0"), 0);

        // Determine entry type and reference
        let type = entry.sourceType || 'manual';
        let reference = entry.reference || entry.entryNumber;
        let saleNumber = null;
        let returnNumber = null;

        if (entry.sourceType === 'sale') {
          const sale = saleMap.get(entry.sourceId || '');
          if (sale) {
            saleNumber = sale.saleNumber;
            reference = sale.saleNumber || reference;
          }
        } else if (entry.sourceType === 'sale_return') {
          const ret = returnMap.get(entry.sourceId || '');
          if (ret) {
            returnNumber = ret.returnNumber;
            reference = ret.returnNumber || reference;
            const sale = saleMap.get(ret.saleId);
            if (sale) saleNumber = sale.saleNumber;
          }
        }

        arEntries.push({
          id: entry.id,
          date: entry.entryDate,
          type,
          reference,
          description: entry.description || arLines[0]?.description || '',
          debit: totalDebit,
          credit: totalCredit,
          saleNumber,
          returnNumber,
          entryNumber: entry.entryNumber,
        });
      }
    }

    // Sort by date
    arEntries.sort((a, b) => {
      const dateA = a.date ? new Date(a.date).getTime() : 0;
      const dateB = b.date ? new Date(b.date).getTime() : 0;
      return dateA - dateB;
    });

    return { entries: arEntries, openingBalance };
  }

  // Get comprehensive customer payment statement (all invoices with payment details)
  // Get comprehensive customer payment statement (all invoices with payment details)
  async getCustomerPaymentStatement(customerId: string): Promise<any> {
    // Get customer's opening balance
    const customer = await db.select().from(customers).where(eq(customers.id, customerId)).limit(1);
    const openingBalance = customer.length > 0 ? parseFloat(customer[0].openingBalance || "0") : 0;
    const currentBalance = customer.length > 0 ? parseFloat(customer[0].currentBalance || "0") : 0;

    // Get all sales for this customer
    const customerSales = await db.select().from(sales)
      .where(eq(sales.customerId, customerId));

    // Get all sale returns for this customer
    const customerReturns = await db.select().from(saleReturns)
      .where(eq(saleReturns.customerId, customerId));

    // Get all payments for this customer (from sale_payments table which is the source of truth)
    const customerPayments = await db.select().from(salePayments)
      .where(eq(salePayments.customerId, customerId));

    // Get credit refunds (when store credit is paid back to customer as cash)
    // These are recorded in bank_transactions with relatedType = "customer_refund" and relatedId = customerId
    // Get credit refunds (when store credit is paid back to customer as cash)
    // These are recorded in bank_transactions with relatedType = "customer_refund" and relatedId = customerId
    // OR relatedType = "sale_return" and type = "withdrawal" and relatedId = customerId
    const creditRefundEntries = await db.select().from(bankTransactions)
      .where(or(
        and(
          eq(bankTransactions.relatedType, "customer_refund"),
          eq(bankTransactions.relatedId, customerId)
        ),
        and(
          eq(bankTransactions.relatedType, "sale_return"),
          eq(bankTransactions.type, "withdrawal"),
          eq(bankTransactions.relatedId, customerId)
        )
      ));

    // Get service tickets for this customer (as invoices)
    const customerServiceTickets = await db.select().from(serviceTickets)
      .where(eq(serviceTickets.customerId, customerId));

    // Get service ticket payments for this customer
    const customerServicePayments = await db.select().from(serviceTicketPayments)
      .where(eq(serviceTicketPayments.customerId, customerId));

    // Build statement entries
    const entries: any[] = [];
    let runningBalance = openingBalance;

    // Add opening balance entry if non-zero
    if (openingBalance !== 0) {
      entries.push({
        id: "opening",
        date: null,
        type: "opening",
        reference: "Opening Balance",
        description: "Opening Balance",
        invoiceTotal: openingBalance > 0 ? openingBalance : 0,
        amountPaid: 0,
        creditBalance: openingBalance,
        balance: openingBalance,
      });
    }

    // Process all sales (INV)
    for (const sale of customerSales) {
      const saleTotal = parseFloat(sale.total || "0");
      // For statement, sale is a DEBIT event (increases what customer owes)
      // We do NOT count payment here. Payments are separate events.

      runningBalance += saleTotal;

      entries.push({
        id: sale.id,
        date: sale.saleDate,
        type: "invoice",
        reference: sale.saleNumber,
        description: `Invoice ${sale.saleNumber}`,
        invoiceTotal: saleTotal,
        amountPaid: 0, // Will be shown in separate payment entries
        creditBalance: saleTotal, // Impact on balance
        balance: runningBalance,
        saleNumber: sale.saleNumber,
      });
    }

    // Process all payments (PAY)
    for (const payment of customerPayments) {
      const amount = parseFloat(payment.amount || "0");
      runningBalance -= amount; // Payment reduces balance

      entries.push({
        id: payment.id,
        date: payment.paymentDate,
        type: "payment",
        reference: payment.reference || "PAY",
        description: `Payment (${payment.paymentMethod})${payment.notes ? ` - ${payment.notes}` : ""}`,
        invoiceTotal: 0,
        amountPaid: amount,
        creditBalance: -amount, // Reduces balance
        balance: runningBalance,
        saleNumber: "", // Could link to sale if needed, but statement is customer-centric
      });
    }

    // Process all returns (RET)
    for (const ret of customerReturns) {
      const refundAmount = parseFloat(ret.refundAmount || "0");
      const creditAmount = parseFloat(ret.creditAmount || "0");
      const totalReturnValue = refundAmount + creditAmount;

      // Returns reduce balance (Customer owes less)
      runningBalance -= totalReturnValue;

      entries.push({
        id: ret.id,
        date: ret.returnDate,
        type: "return",
        reference: ret.returnNumber,
        description: `Return ${ret.returnNumber}${ret.reason ? ` - ${ret.reason}` : ""}`,
        invoiceTotal: 0,
        amountPaid: 0,
        returnValue: totalReturnValue,
        // For report display logic to work (it expects arReduction/storeCredit but we simplify for chronological view)
        arReduction: totalReturnValue,
        storeCreditPayable: 0,
        creditBalance: -totalReturnValue,
        balance: runningBalance,
        returnNumber: ret.returnNumber,
      });
    }

    // Process credit refunds (when store credit is paid back to customer as cash)
    // These increase the balance (customer owes more after receiving cash back for their credit)
    for (const refund of creditRefundEntries) {
      // Amount from bank transaction is the refund amount
      const refundAmount = parseFloat(refund.amount || "0");

      if (refundAmount > 0) {
        // Credit refund increases balance (customer received cash for their negative balance/credit)
        runningBalance += refundAmount;

        entries.push({
          id: refund.id,
          date: refund.transactionDate,
          type: "credit_refund",
          reference: refund.reference || "REF",
          description: refund.description || "Store credit refund",
          invoiceTotal: refundAmount, // Shows as debit (increases receivable)
          amountPaid: 0,
          returnValue: 0,
          creditBalance: refundAmount, // Positive = increases balance
          balance: runningBalance,
        });
      }
    }

    // Process service tickets for this customer (as invoices — increases balance)
    for (const ticket of customerServiceTickets) {
      const ticketTotal = parseFloat(ticket.totalAmount?.toString() || "0");
      if (ticketTotal <= 0) continue;
      runningBalance += ticketTotal;
      entries.push({
        id: `svc-${ticket.id}`,
        date: ticket.receivedDate || ticket.createdAt,
        type: "service_invoice",
        reference: ticket.ticketNumber,
        description: `Service ${ticket.ticketNumber} - ${ticket.deviceType}${ticket.deviceBrand ? ` ${ticket.deviceBrand}` : ""}`,
        invoiceTotal: ticketTotal,
        amountPaid: 0,
        creditBalance: ticketTotal,
        balance: runningBalance,
      });
    }

    // Process service ticket payments (reduce balance)
    for (const pmt of customerServicePayments) {
      const amount = parseFloat(pmt.amount?.toString() || "0");
      if (amount <= 0) continue;
      runningBalance -= amount;
      entries.push({
        id: `svc-pmt-${pmt.id}`,
        date: pmt.paymentDate,
        type: "service_payment",
        reference: pmt.reference || "SVC-PAY",
        description: `Service payment (${pmt.paymentMethod})${pmt.notes ? ` - ${pmt.notes}` : ""}`,
        invoiceTotal: 0,
        amountPaid: amount,
        creditBalance: -amount,
        balance: runningBalance,
      });
    }

    // Sort by date
    entries.sort((a, b) => {
      // Opening balance always first
      if (a.type === "opening") return -1;
      if (b.type === "opening") return 1;

      if (!a.date) return -1;
      if (!b.date) return 1;
      const dateA = new Date(a.date).getTime();
      const dateB = new Date(b.date).getTime();
      return dateA - dateB;
    });

    // Recalculate running balance strictly based on sorted order
    // This fixes any out-of-order balance calculations from the loop
    let calculatedBalance = 0;
    const finalEntries = entries.map(entry => {
      if (entry.type === "opening") {
        calculatedBalance = entry.balance; // Set to opening balance
      } else {
        // Add (Debit) or Subtract (Credit) based on entry type logic
        // In loop above:
        // Invoice: creditBalance = +Total
        // Payment: creditBalance = -Amount
        // Return: creditBalance = -TotalReturn
        calculatedBalance += (entry.creditBalance || 0);
      }
      return { ...entry, balance: calculatedBalance };
    });

    // Calculate totals
    let totalInvoiced = 0;
    let totalPaid = 0;
    let totalReturns = 0;
    let totalCreditRefunds = 0;

    for (const entry of finalEntries) {
      if (entry.type === "invoice") {
        totalInvoiced += entry.invoiceTotal;
      } else if (entry.type === "payment") {
        totalPaid += entry.amountPaid;
      } else if (entry.type === "return") {
        totalReturns += entry.returnValue || 0;
      } else if (entry.type === "credit_refund") {
        totalCreditRefunds += entry.invoiceTotal || 0;
      } else if (entry.type === "service_invoice") {
        totalInvoiced += entry.invoiceTotal || 0;
      } else if (entry.type === "service_payment") {
        totalPaid += entry.amountPaid || 0;
      }
    }

    return {
      entries: finalEntries,
      openingBalance,
      currentBalance, // From DB
      totals: {
        totalInvoiced,
        totalPaid,
        totalReturns,
        totalCreditRefunds,
        closingBalance: calculatedBalance, // Calculated from ledger
      }
    };
  }

  // Financial Reports - Shop-scoped (each shop has isolated balances)
  async getTrialBalance(companyId?: string, startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    const conditions = [];
    if (companyId) {
      conditions.push(eq(chartOfAccounts.companyId, companyId));
    }
    // Always filter by shop_id to ensure data isolation
    if (scope?.shopId) {
      conditions.push(eq(chartOfAccounts.shopId, scope.shopId));
    }
    // Optionally filter by branch_id for branch-level isolation
    if (scope?.branchId) {
      conditions.push(eq(chartOfAccounts.branchId, scope.branchId));
    }

    let query = db.select({
      id: chartOfAccounts.id,
      accountCode: chartOfAccounts.accountCode,
      name: chartOfAccounts.name,
      accountType: chartOfAccounts.accountType,
      balance: chartOfAccounts.balance,
    }).from(chartOfAccounts);

    if (conditions.length > 0) {
      query = query.where(and(...conditions)) as any;
    }

    const accounts = await query;

    let totalDebits = 0;
    let totalCredits = 0;
    const trialBalanceData = accounts.map(account => {
      const balance = parseFloat(account.balance || "0");
      const isDebitNormal = ["asset", "expense"].includes(account.accountType);
      const debit = balance > 0 && isDebitNormal ? balance : (balance < 0 && !isDebitNormal ? Math.abs(balance) : 0);
      const credit = balance > 0 && !isDebitNormal ? balance : (balance < 0 && isDebitNormal ? Math.abs(balance) : 0);
      totalDebits += debit;
      totalCredits += credit;
      return { ...account, debit: debit.toFixed(3), credit: credit.toFixed(3) };
    });

    // Get cash receipts breakdown by source type
    const cashAccount = accounts.find(a => a.accountCode === "1000");
    let cashBreakdown: { source: string; amount: number }[] = [];

    if (cashAccount && scope?.shopId) {
      // Build conditions for cash receipts query - respects both shop and branch scope
      const cashConditions = [
        eq(journalLines.accountId, cashAccount.id),
        eq(journalEntries.shopId, scope.shopId)
      ];

      // Add branch-level filtering if specified for proper data isolation
      if (scope?.branchId) {
        cashConditions.push(eq(journalEntries.branchId, scope.branchId));
      }

      // Query journal lines for Cash and Bank (1000) grouped by source type
      const cashReceipts = await db.select({
        sourceType: journalEntries.sourceType,
        totalDebit: sql<string>`COALESCE(SUM(CAST(${journalLines.debit} AS NUMERIC)), 0)`,
      })
        .from(journalLines)
        .innerJoin(journalEntries, eq(journalLines.journalEntryId, journalEntries.id))
        .where(and(...cashConditions))
        .groupBy(journalEntries.sourceType);

      cashBreakdown = cashReceipts.map(r => ({
        source: r.sourceType || "Other",
        amount: parseFloat(r.totalDebit || "0"),
      })).filter(r => r.amount > 0);
    }

    return {
      accounts: trialBalanceData,
      totalDebits: totalDebits.toFixed(3),
      totalCredits: totalCredits.toFixed(3),
      isBalanced: Math.abs(totalDebits - totalCredits) < 0.01,
      cashBreakdown,
    };
  }

  async getGeneralLedger(accountId: string, startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    const [account] = await db.select().from(chartOfAccounts).where(eq(chartOfAccounts.id, accountId));

    const conditions = [eq(journalLines.accountId, accountId)];
    if (scope?.shopId) {
      conditions.push(eq(journalEntries.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      conditions.push(eq(journalEntries.branchId, scope.branchId));
    }

    const lines = await db.select({
      id: journalLines.id,
      debit: journalLines.debit,
      credit: journalLines.credit,
      description: journalLines.description,
      journalEntryId: journalLines.journalEntryId,
      entryDate: journalEntries.entryDate,
      entryNumber: journalEntries.entryNumber,
      reference: journalEntries.reference,
    }).from(journalLines)
      .innerJoin(journalEntries, eq(journalLines.journalEntryId, journalEntries.id))
      .where(and(...conditions))
      .orderBy(asc(journalEntries.entryDate));

    return { account, entries: lines };
  }

  async getProfitAndLoss(companyId?: string, startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    // Shop-scoped - filter by shop_id to ensure data isolation
    const revenueConditions = [eq(chartOfAccounts.accountType, "revenue")];
    const expenseConditions = [eq(chartOfAccounts.accountType, "expense")];

    if (scope?.shopId) {
      revenueConditions.push(eq(chartOfAccounts.shopId, scope.shopId));
      expenseConditions.push(eq(chartOfAccounts.shopId, scope.shopId));
    }

    const revenueAccounts = await db.select().from(chartOfAccounts).where(and(...revenueConditions));
    const expenseAccounts = await db.select().from(chartOfAccounts).where(and(...expenseConditions));

    // Create maps to accumulate dynamic balances from journal entries
    const revMap = new Map(revenueAccounts.map(a => [a.id, { ...a, calculatedBalance: 0 }]));
    const expMap = new Map(expenseAccounts.map(a => [a.id, { ...a, calculatedBalance: 0 }]));

    const accountIds = [...revMap.keys(), ...expMap.keys()];

    if (accountIds.length > 0) {
      const jeConditions = [];
      if (startDate) {
        jeConditions.push(sql`${journalEntries.entryDate} >= ${new Date(startDate)}`);
      }
      if (endDate) {
        // Handle end date up to end of day
        let endD = new Date(endDate);
        endD.setHours(23, 59, 59, 999);
        jeConditions.push(sql`${journalEntries.entryDate} <= ${endD}`);
      }
      if (scope?.shopId) {
        jeConditions.push(eq(journalEntries.shopId, scope.shopId));
      }
      if (scope?.branchId) {
        jeConditions.push(eq(journalEntries.branchId, scope.branchId));
      }

      const lines = await db.select({
        accountId: journalLines.accountId,
        debit: journalLines.debit,
        credit: journalLines.credit,
      })
        .from(journalLines)
        .innerJoin(journalEntries, eq(journalLines.journalEntryId, journalEntries.id))
        .where(and(
          inArray(journalLines.accountId, accountIds),
          ...(jeConditions.length > 0 ? jeConditions : [])
        ));

      for (const line of lines) {
        const debit = parseFloat(String(line.debit || 0));
        const credit = parseFloat(String(line.credit || 0));

        if (revMap.has(line.accountId)) {
          // Revenue accounts increase with Credit and decrease with Debit
          const acc = revMap.get(line.accountId)!;
          acc.calculatedBalance += (credit - debit);
        } else if (expMap.has(line.accountId)) {
          // Expense accounts increase with Debit and decrease with Credit
          const acc = expMap.get(line.accountId)!;
          acc.calculatedBalance += (debit - credit);
        }
      }
    }

    const totalRevenue = Array.from(revMap.values()).reduce((sum, acc) => sum + acc.calculatedBalance, 0);
    const totalExpenses = Array.from(expMap.values()).reduce((sum, acc) => sum + acc.calculatedBalance, 0);

    return {
      revenue: Array.from(revMap.values()).map(a => ({ name: a.name, accountCode: a.accountCode, amount: a.calculatedBalance.toFixed(3) })),
      expenses: Array.from(expMap.values()).map(a => ({ name: a.name, accountCode: a.accountCode, amount: a.calculatedBalance.toFixed(3) })),
      totalRevenue: totalRevenue.toFixed(3),
      totalExpenses: totalExpenses.toFixed(3),
      netIncome: (totalRevenue - totalExpenses).toFixed(3),
    };
  }

  async getBalanceSheet(companyId?: string, asOfDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    // Shop-scoped - filter by shop_id to ensure data isolation
    const assetConditions = [eq(chartOfAccounts.accountType, "asset")];
    const liabilityConditions = [eq(chartOfAccounts.accountType, "liability")];
    const equityConditions = [eq(chartOfAccounts.accountType, "equity")];

    if (scope?.shopId) {
      assetConditions.push(eq(chartOfAccounts.shopId, scope.shopId));
      liabilityConditions.push(eq(chartOfAccounts.shopId, scope.shopId));
      equityConditions.push(eq(chartOfAccounts.shopId, scope.shopId));
    }

    const assetAccounts = await db.select().from(chartOfAccounts).where(and(...assetConditions));
    const liabilityAccounts = await db.select().from(chartOfAccounts).where(and(...liabilityConditions));
    const equityAccounts = await db.select().from(chartOfAccounts).where(and(...equityConditions));

    const totalAssets = assetAccounts.reduce((sum, acc) => sum + parseFloat(acc.balance || "0"), 0);
    const totalLiabilities = liabilityAccounts.reduce((sum, acc) => sum + parseFloat(acc.balance || "0"), 0);
    const totalEquity = equityAccounts.reduce((sum, acc) => sum + parseFloat(acc.balance || "0"), 0);

    return {
      assets: assetAccounts.map(a => ({ name: a.name, amount: a.balance })),
      liabilities: liabilityAccounts.map(a => ({ name: a.name, amount: a.balance })),
      equity: equityAccounts.map(a => ({ name: a.name, amount: a.balance })),
      totalAssets: totalAssets.toFixed(3),
      totalLiabilities: totalLiabilities.toFixed(3),
      totalEquity: totalEquity.toFixed(3),
    };
  }

  // Salary Report
  async getSalaryReport(employeeId?: string, startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    const conditions = [];

    if (employeeId) {
      conditions.push(eq(salaryPayments.employeeId, employeeId));
    }
    if (startDate) {
      conditions.push(sql`${salaryPayments.paymentDate} >= ${startDate}`);
    }
    if (endDate) {
      conditions.push(sql`${salaryPayments.paymentDate} <= ${endDate}`);
    }
    if (scope?.shopId) {
      conditions.push(or(eq(salaryPayments.shopId, scope.shopId), sql`${salaryPayments.shopId} IS NULL`));
    }
    if (scope?.branchId) {
      conditions.push(or(eq(salaryPayments.branchId, scope.branchId), sql`${salaryPayments.branchId} IS NULL`));
    }

    const payments = conditions.length > 0
      ? await db.select().from(salaryPayments).where(and(...conditions)).orderBy(desc(salaryPayments.paymentDate))
      : await db.select().from(salaryPayments).orderBy(desc(salaryPayments.paymentDate));

    // Get all employees for name lookup
    const employeeList = await db.select().from(employees);
    const employeeMap = new Map(employeeList.map(e => [e.id, e]));

    // Group by employee
    const byEmployee: Record<string, { employee: any; payments: any[]; total: number }> = {};

    for (const payment of payments) {
      const emp = employeeMap.get(payment.employeeId);
      if (!byEmployee[payment.employeeId]) {
        byEmployee[payment.employeeId] = {
          employee: emp || { id: payment.employeeId, name: "Unknown" },
          payments: [],
          total: 0,
        };
      }
      byEmployee[payment.employeeId].payments.push(payment);
      byEmployee[payment.employeeId].total += parseFloat(payment.netSalary?.toString() || "0");
    }

    const totalGross = payments.reduce((sum, p) => sum + parseFloat(p.grossSalary?.toString() || "0"), 0);
    const totalDeductions = payments.reduce((sum, p) => sum + parseFloat(p.deductions?.toString() || "0"), 0);
    const totalNet = payments.reduce((sum, p) => sum + parseFloat(p.netSalary?.toString() || "0"), 0);

    return {
      payments,
      byEmployee: Object.values(byEmployee),
      summary: {
        totalGross: totalGross.toFixed(3),
        totalDeductions: totalDeductions.toFixed(3),
        totalNet: totalNet.toFixed(3),
        paymentCount: payments.length,
        employeeCount: Object.keys(byEmployee).length,
      },
    };
  }

  async getPettyCashReport(startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    try {
      const conditions = [];
      if (startDate) conditions.push(sql`${pettyCashTransactions.transactionDate} >= ${startDate}`);
      if (endDate) conditions.push(sql`${pettyCashTransactions.transactionDate} <= ${endDate}`);

      if (scope?.shopId) conditions.push(eq(pettyCashTransactions.shopId, scope.shopId));
      if (scope?.branchId) conditions.push(eq(pettyCashTransactions.branchId, scope.branchId));

      const transactions = await db.select()
        .from(pettyCashTransactions)
        .where(conditions.length > 0 ? and(...conditions) : undefined)
        .orderBy(desc(pettyCashTransactions.transactionDate));

      let totalIncome = 0;
      let totalExpense = 0;
      let totalReturns = 0;

      transactions.forEach(t => {
        const amt = parseFloat(t.amount?.toString() || "0");
        if (t.type === "deposit") totalIncome += amt;
        else if (t.type === "return") totalReturns += amt;
        else totalExpense += amt;
      });

      return {
        totalIncome: totalIncome.toFixed(3),
        totalExpense: totalExpense.toFixed(3),
        totalReturns: totalReturns.toFixed(3),
        netCash: (totalIncome - totalExpense - totalReturns).toFixed(3),
        transactions
      };
    } catch (error) {
      console.error("Error in getPettyCashReport:", error);
      throw error;
    }
  }

  // Project Report
  async getProjectReport(projectId?: string, employeeId?: string, startDate?: string, endDate?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    // Get project income
    const incomeConditions = [];
    if (projectId) {
      incomeConditions.push(eq(projectIncome.projectId, projectId));
    }
    if (startDate) {
      incomeConditions.push(sql`${projectIncome.paymentDate} >= ${startDate}`);
    }
    if (endDate) {
      incomeConditions.push(sql`${projectIncome.paymentDate} <= ${endDate}`);
    }

    const incomeList = incomeConditions.length > 0
      ? await db.select().from(projectIncome).where(and(...incomeConditions)).orderBy(desc(projectIncome.paymentDate))
      : await db.select().from(projectIncome).orderBy(desc(projectIncome.paymentDate));

    // Get project expenses
    const expenseConditions = [];
    if (projectId) {
      expenseConditions.push(eq(projectExpenses.projectId, projectId));
    }
    if (employeeId) {
      expenseConditions.push(eq(projectExpenses.employeeId, employeeId));
    }
    if (startDate) {
      expenseConditions.push(sql`${projectExpenses.expenseDate} >= ${startDate}`);
    }
    if (endDate) {
      expenseConditions.push(sql`${projectExpenses.expenseDate} <= ${endDate}`);
    }
    if (scope?.branchId) {
      expenseConditions.push(or(eq(projectExpenses.branchId, scope.branchId), sql`${projectExpenses.branchId} IS NULL`));
    }

    const expenseList = expenseConditions.length > 0
      ? await db.select().from(projectExpenses).where(and(...expenseConditions)).orderBy(desc(projectExpenses.expenseDate))
      : await db.select().from(projectExpenses).orderBy(desc(projectExpenses.expenseDate));

    // Get tasks
    const taskConditions = [];
    if (projectId) {
      taskConditions.push(eq(tasks.projectId, projectId));
    }
    if (employeeId) {
      taskConditions.push(eq(tasks.assignedTo, employeeId));
    }

    const taskList = taskConditions.length > 0
      ? await db.select().from(tasks).where(and(...taskConditions)).orderBy(desc(tasks.createdAt))
      : await db.select().from(tasks).orderBy(desc(tasks.createdAt));

    // Get projects and employees for name lookup
    const projectList = await db.select().from(projects);
    const projectMap = new Map(projectList.map(p => [p.id, p]));
    const employeeList = await db.select().from(employees);
    const employeeMap = new Map(employeeList.map(e => [e.id, e]));

    // Calculate totals
    const totalIncome = incomeList.reduce((sum, i) => sum + parseFloat(i.amount?.toString() || "0"), 0);
    const totalExpenses = expenseList.reduce((sum, e) => sum + parseFloat(e.amount?.toString() || "0"), 0);
    const netProfit = totalIncome - totalExpenses;

    // Group expenses by category
    const expensesByCategory: Record<string, number> = {};
    for (const exp of expenseList) {
      const cat = exp.category || "other";
      expensesByCategory[cat] = (expensesByCategory[cat] || 0) + parseFloat(exp.amount?.toString() || "0");
    }

    // Group tasks by status
    const tasksByStatus = {
      pending: taskList.filter(t => t.status === "pending").length,
      in_progress: taskList.filter(t => t.status === "in_progress").length,
      completed: taskList.filter(t => t.status === "completed").length,
    };

    return {
      income: incomeList.map(i => ({
        ...i,
        projectName: projectMap.get(i.projectId)?.name || "Unknown",
      })),
      expenses: expenseList.map(e => ({
        ...e,
        projectName: projectMap.get(e.projectId)?.name || "Unknown",
        employeeName: e.employeeId ? employeeMap.get(e.employeeId)?.name : null,
      })),
      tasks: taskList.map(t => ({
        ...t,
        projectName: projectMap.get(t.projectId)?.name || "Unknown",
        assigneeName: t.assignedTo ? employeeMap.get(t.assignedTo)?.name : null,
      })),
      summary: {
        totalIncome: totalIncome.toFixed(3),
        totalExpenses: totalExpenses.toFixed(3),
        netProfit: netProfit.toFixed(3),
        expensesByCategory,
        tasksByStatus,
        incomeCount: incomeList.length,
        expenseCount: expenseList.length,
        taskCount: taskList.length,
      },
    };
  }

  async getOverallReport(startDate?: string, endDate?: string, warehouseId?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<any> {
    const startD = startDate ? new Date(startDate) : new Date(0);
    const endD = endDate ? new Date(endDate) : new Date();
    endD.setHours(23, 59, 59, 999);

    const filterByScopeAndDate = (table: any, dateField: any) => {
      const conds = [
        sql`${dateField} >= ${startD}`,
        sql`${dateField} <= ${endD}`
      ];
      if (scope?.shopId) conds.push(eq(table.shopId, scope.shopId));
      if (scope?.branchId) conds.push(eq(table.branchId, scope.branchId));
      return conds;
    };

    // 1. Income aggregation
    // Sales
    const salesConds = filterByScopeAndDate(sales, sales.saleDate);
    // Note: Sales in this schema don't have a direct warehouseId at top level, 
    // but usually linked via branch or inventory. If warehouseId is provided, 
    // we'd need more complex joins. For "Overall", we'll stick to shop/branch level 
    // for incomes that aren't strictly warehouse-bound.
    const salesList = await db.select().from(sales).where(and(...salesConds));
    
    // Project Income
    const pIncomeConds = filterByScopeAndDate(projectIncome, projectIncome.paymentDate);
    const pIncomeList = await db.select().from(projectIncome).where(and(...pIncomeConds));

    // Service Tickets
    const serviceConds = filterByScopeAndDate(serviceTickets, serviceTickets.receivedDate);
    const serviceList = await db.select().from(serviceTickets).where(and(...serviceConds));

    // 2. Expense aggregation
    // Purchases
    const purchaseConds = filterByScopeAndDate(purchases, purchases.purchaseDate);
    if (warehouseId && warehouseId !== "all") {
      purchaseConds.push(eq(purchases.warehouseId, warehouseId));
    }
    const purchaseList = await db.select().from(purchases).where(and(...purchaseConds));

    // Project Expenses
    const pExpenseConds = filterByScopeAndDate(projectExpenses, projectExpenses.expenseDate);
    const pExpenseList = await db.select().from(projectExpenses).where(and(...pExpenseConds));

    // Salaries
    const salaryConds = filterByScopeAndDate(salaryPayments, salaryPayments.paymentDate);
    const salaryList = await db.select().from(salaryPayments).where(and(...salaryConds));

    // Petty Cash
    const pettyConds = filterByScopeAndDate(pettyCashTransactions, pettyCashTransactions.transactionDate);
    const pettyList = await db.select().from(pettyCashTransactions).where(and(...pettyConds));

    // Format transactions for the UI
    const transactions = [
      ...salesList.map(s => ({ id: s.id, date: s.saleDate, category: "Sale", type: "income", description: `Sale #${s.saleNumber}`, amount: s.total, reference: s.saleNumber })),
      ...pIncomeList.map(i => ({ id: i.id, date: i.paymentDate, category: "Project", type: "income", description: i.title || "Project Income", amount: i.amount, reference: i.invoiceNo })),
      ...serviceList.map(t => ({ id: t.id, date: t.receivedDate, category: "Service", type: "income", description: `Service Ticket #${t.ticketNumber}`, amount: t.totalAmount, reference: t.ticketNumber })),
      ...purchaseList.map(p => ({ id: p.id, date: p.purchaseDate, category: "Purchase", type: "expense", description: `Purchase #${p.purchaseNumber}`, amount: p.total, reference: p.purchaseNumber })),
      ...pExpenseList.map(e => ({ id: e.id, date: e.expenseDate, category: "Project", type: "expense", description: e.title || "Project Expense", amount: e.amount, reference: e.category })),
      ...salaryList.map(s => ({ id: s.id, date: s.paymentDate, category: "Salary", type: "expense", description: `Salary - ${s.month}/${s.year}`, amount: s.netSalary, reference: s.employeeId })),
      ...pettyList.map(t => ({ id: t.id, date: t.transactionDate, category: "Petty Cash", type: t.type === "deposit" ? "income" : "expense", description: t.description, amount: t.amount, reference: t.reference }))
    ].sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime());

    // If warehouseId is specified, we filter the combined list. 
    // Transactions without a warehouse link will be filtered out unless warehouseId is "all" or null.
    // NOTE: For now, Income is mostly shop/branch-led.
    let filteredTransactions = transactions;
    if (warehouseId && warehouseId !== "all") {
        // Purchases already filtered. For others, we might want to check shop/branch.
        // Actually, for "Overall" report requested by user, we'll keep the direct filters applied above.
        // If it's a warehouse-specific request, only warehouse-linked transactions (like Purchases) 
        // will show if we add strict filtering here.
    }

    const totalIncome = transactions.filter(t => t.type === "income").reduce((sum, t) => sum + parseFloat(t.amount?.toString() || "0"), 0);
    const totalExpense = transactions.filter(t => t.type === "expense").reduce((sum, t) => sum + parseFloat(t.amount?.toString() || "0"), 0);

    return {
      summary: {
        totalIncome: totalIncome.toFixed(3),
        totalExpense: totalExpense.toFixed(3),
        netProfit: (totalIncome - totalExpense).toFixed(3),
        transactionCount: transactions.length
      },
      transactions
    };
  }

  // Quotations
  async getQuotations(scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<Quotation[]> {
    let conditions = [];
    if (scope?.shopId) {
      conditions.push(eq(quotations.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      conditions.push(eq(quotations.branchId, scope.branchId));
    }
    if (conditions.length > 0) {
      return db.select().from(quotations).where(and(...conditions)).orderBy(desc(quotations.quotationDate));
    }
    return db.select().from(quotations).orderBy(desc(quotations.quotationDate));
  }

  async getQuotation(id: string): Promise<Quotation | undefined> {
    const [quotation] = await db.select().from(quotations).where(eq(quotations.id, id));
    return quotation || undefined;
  }

  async getQuotationWithItems(id: string): Promise<{ quotation: Quotation; items: QuotationItem[] } | undefined> {
    const quotation = await this.getQuotation(id);
    if (!quotation) return undefined;
    const items = await db.select().from(quotationItems).where(eq(quotationItems.quotationId, id));
    return { quotation, items };
  }

  async getApprovedQuotationsForCustomer(customerId: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<Quotation[]> {
    const now = new Date().toISOString().split("T")[0];
    let conditions = [
      eq(quotations.status, "approved"),
      customerId ? eq(quotations.customerId, customerId) : sql`1=1`
    ];
    if (scope?.shopId) {
      conditions.push(eq(quotations.shopId, scope.shopId));
    }
    if (scope?.branchId) {
      conditions.push(eq(quotations.branchId, scope.branchId));
    }
    let result = await db.select().from(quotations)
      .where(and(...conditions))
      .orderBy(desc(quotations.quotationDate));

    // Filter out expired quotations
    return result.filter(q => !q.validUntil || q.validUntil >= now);
  }

  private async getNextQuotationNumber(): Promise<string> {
    const result = await db.select({ count: sql<number>`count(*)` }).from(quotations);
    const count = Number(result[0]?.count || 0);
    return `QT-${(count + 1).toString().padStart(6, "0")}`;
  }

  async createQuotation(data: any, items: any[]): Promise<Quotation> {
    const quotationNumber = await this.getNextQuotationNumber();

    return await db.transaction(async (tx) => {
      const [quotation] = await tx.insert(quotations).values({
        quotationNumber,
        customerId: data.customerId,
        shopId: data.shopId,
        branchId: data.branchId,
        warehouseId: data.warehouseId,
        validUntil: data.validUntil,
        status: data.status || "pending",
        financeCode: data.financeCode,
        requestNo: data.requestNo,
        discountPercent: data.discountPercent?.toString() || "0.00",
        taxType: data.taxType || "VAT",
        currency: data.currency || "OMR",
        salesPerson: data.salesPerson,
        companyName: data.companyName,
        contactPerson: data.contactPerson,
        salesContact: data.salesContact,
        subtotal: data.subtotal?.toString() || "0.000",
        vatAmount: data.vatAmount?.toString() || "0.000",
        discount: data.discount?.toString() || "0.000",
        total: data.total?.toString() || "0.000",
        notes: data.notes,
      }).returning();

      for (const item of items) {
        await tx.insert(quotationItems).values({
          quotationId: quotation.id,
          productId: item.productId,
          productName: item.productName,
          productDesc: item.productDesc,
          warehouseId: item.warehouseId,
          quantity: item.quantity,
          unitPrice: item.unitPrice?.toString() || "0.000",
          vatRate: item.vatRate?.toString() || "5.00",
          discount: item.discount?.toString() || "0.000",
          total: item.total?.toString() || "0.000",
          salesType: item.salesType || "single",
          deliveryDate: item.deliveryDate,
        });
      }

      return quotation;
    });
  }

  async updateQuotation(id: string, data: Partial<InsertQuotation>): Promise<Quotation | undefined> {
    const [quotation] = await db.update(quotations).set(data).where(eq(quotations.id, id)).returning();
    return quotation || undefined;
  }

  async convertQuotationToSale(id: string): Promise<Sale> {
    const quotation = await this.getQuotation(id);
    if (!quotation) throw new Error("Quotation not found");

    const items = await db.select().from(quotationItems).where(eq(quotationItems.quotationId, id));

    const saleItems = items.map(item => ({
      productId: item.productId,
      quantity: item.quantity,
      unitPrice: parseFloat(item.unitPrice),
      vatRate: parseFloat(item.vatRate || "5"),
      discount: parseFloat(item.discount || "0"),
      total: parseFloat(item.total || "0"),
    }));

    const sale = await this.createSale({
      customerId: quotation.customerId,
      shopId: quotation.shopId,
      branchId: quotation.branchId,
      paymentMethod: "cash",
      cashAmount: quotation.total,
      subtotal: quotation.subtotal,
      vatAmount: quotation.vatAmount,
      discount: quotation.discount,
      total: quotation.total,
    } as any, saleItems);

    await db.update(quotations).set({ status: "converted", convertedSaleId: sale.id }).where(eq(quotations.id, id));

    return sale;
  }

  // Employee Documents
  async getEmployeeDocuments(employeeId?: string): Promise<EmployeeDocument[]> {
    if (employeeId) {
      return db.select().from(employeeDocuments).where(eq(employeeDocuments.employeeId, employeeId));
    }
    return db.select().from(employeeDocuments);
  }

  async createEmployeeDocument(data: InsertEmployeeDocument): Promise<EmployeeDocument> {
    const [doc] = await db.insert(employeeDocuments).values(data).returning();
    return doc;
  }

  async updateEmployeeDocument(id: string, data: Partial<InsertEmployeeDocument>): Promise<EmployeeDocument | undefined> {
    const [doc] = await db.update(employeeDocuments).set(data).where(eq(employeeDocuments.id, id)).returning();
    return doc || undefined;
  }

  async deleteEmployeeDocument(id: string): Promise<void> {
    await db.delete(employeeDocuments).where(eq(employeeDocuments.id, id));
  }

  async getExpiringDocuments(days: number = 30): Promise<EmployeeDocument[]> {
    const futureDate = new Date();
    futureDate.setDate(futureDate.getDate() + days);
    return db.select().from(employeeDocuments)
      .where(sql`${employeeDocuments.expiryDate} <= ${futureDate.toISOString().split('T')[0]} AND ${employeeDocuments.expiryDate} >= CURRENT_DATE`);
  }

  // Leave Types
  async getLeaveTypes(): Promise<LeaveType[]> {
    return db.select().from(leaveTypes);
  }

  async createLeaveType(data: InsertLeaveType): Promise<LeaveType> {
    const [type] = await db.insert(leaveTypes).values(data).returning();
    return type;
  }

  async updateLeaveType(id: string, data: Partial<InsertLeaveType>): Promise<LeaveType | undefined> {
    const [type] = await db.update(leaveTypes).set(data).where(eq(leaveTypes.id, id)).returning();
    return type || undefined;
  }

  async deleteLeaveType(id: string): Promise<void> {
    await db.delete(leaveTypes).where(eq(leaveTypes.id, id));
  }

  // Leave Requests
  async getLeaveRequests(employeeId?: string, scope?: { shopId?: string | null; branchId?: string | null } | null): Promise<LeaveRequest[]> {
    // Leave requests are scoped via the employee's shop/branch
    // Join with employees to filter by scope
    if (scope?.shopId || scope?.branchId) {
      const conditions = [];
      if (employeeId) {
        conditions.push(eq(leaveRequests.employeeId, employeeId));
      }
      if (scope?.shopId) {
        conditions.push(eq(employees.shopId, scope.shopId));
      }
      if (scope?.branchId) {
        conditions.push(eq(employees.branchId, scope.branchId));
      }

      return db.select({
        id: leaveRequests.id,
        employeeId: leaveRequests.employeeId,
        leaveTypeId: leaveRequests.leaveTypeId,
        startDate: leaveRequests.startDate,
        endDate: leaveRequests.endDate,
        totalDays: leaveRequests.totalDays,
        reason: leaveRequests.reason,
        status: leaveRequests.status,
        approvedById: leaveRequests.approvedById,
        approvedAt: leaveRequests.approvedAt,
        comments: leaveRequests.comments,
        createdAt: leaveRequests.createdAt,
      })
        .from(leaveRequests)
        .innerJoin(employees, eq(leaveRequests.employeeId, employees.id))
        .where(and(...conditions))
        .orderBy(desc(leaveRequests.createdAt));
    }

    if (employeeId) {
      return db.select().from(leaveRequests).where(eq(leaveRequests.employeeId, employeeId)).orderBy(desc(leaveRequests.createdAt));
    }
    return db.select().from(leaveRequests).orderBy(desc(leaveRequests.createdAt));
  }

  async getAccruedLeave(employeeId: string): Promise<{ accruedDays: number; usedPaidDays: number; balance: number }> {
    const employee = await this.getEmployee(employeeId);
    if (!employee || !employee.joiningDate) {
      return { accruedDays: 0, usedPaidDays: 0, balance: 0 };
    }

    const joiningDate = new Date(employee.joiningDate);
    const today = new Date();
    
    // Calculate months difference
    const monthsSinceJoining = (today.getFullYear() - joiningDate.getFullYear()) * 12 + (today.getMonth() - joiningDate.getMonth());
    
    // Accrual rate: 30 days per 12 months (2.5 days per month)
    const accruedDays = Math.max(0, parseFloat((monthsSinceJoining * 2.5).toFixed(2)));

    // Get all approved leaves for this employee
    const approvedLeaves = await db.select().from(leaveRequests)
      .where(and(
        eq(leaveRequests.employeeId, employeeId),
        eq(leaveRequests.status, "approved")
      ));

    // By default all approved days might be considered "paid" unless we start explicitly tracking unpaid.
    // For now, if approvedPaidDays is tracked, we use it; otherwise fallback to totalDays.
    let usedPaidDays = 0;
    for (const leave of approvedLeaves) {
      if (leave.approvedPaidDays && parseFloat(leave.approvedPaidDays.toString()) > 0) {
        usedPaidDays += parseFloat(leave.approvedPaidDays.toString());
      } else {
        // Fallback or old data assumption
        usedPaidDays += parseFloat(leave.totalDays?.toString() || "0");
      }
    }

    const balance = Math.max(0, accruedDays - usedPaidDays);

    return {
      accruedDays,
      usedPaidDays,
      balance: parseFloat(balance.toFixed(2))
    };
  }

  async getUnapprovedLeaveDeduction(employeeId: string, month: number, year: number): Promise<{ unapprovedDays: number; leaveDeduction: number; dailyRate: number; leaveIds: string[] }> {
    const employee = await this.getEmployee(employeeId);
    if (!employee) {
      return { unapprovedDays: 0, leaveDeduction: 0, dailyRate: 0, leaveIds: [] };
    }

    const basicSalary = parseFloat(employee.basicSalary || "0");
    const workingDaysPerMonth = 30;
    const dailyRate = basicSalary / workingDaysPerMonth;

    const startOfMonth = `${year}-${String(month).padStart(2, '0')}-01`;
    const endOfMonth = new Date(year, month, 0);
    const endOfMonthStr = `${year}-${String(month).padStart(2, '0')}-${String(endOfMonth.getDate()).padStart(2, '0')}`;

    const allLeaveRequests = await db.select().from(leaveRequests)
      .where(and(
        eq(leaveRequests.employeeId, employeeId),
        or(
          eq(leaveRequests.status, "rejected"),
          eq(leaveRequests.status, "pending"),
          // Also include approved requests that have unpaid days
          and(
            eq(leaveRequests.status, "approved"),
            sql`CAST(${leaveRequests.approvedUnpaidDays} AS DECIMAL) > 0`
          )
        )
      ));

    let unapprovedDays = 0;
    const leaveIds: string[] = [];

    for (const leave of allLeaveRequests) {
      const leaveStart = new Date(leave.startDate);
      const leaveEnd = new Date(leave.endDate);
      const monthStart = new Date(startOfMonth);
      const monthEnd = new Date(endOfMonthStr);

      if (leaveEnd < monthStart || leaveStart > monthEnd) {
        continue;
      }

      const overlapStart = leaveStart > monthStart ? leaveStart : monthStart;
      const overlapEnd = leaveEnd < monthEnd ? leaveEnd : monthEnd;
      const overlapDays = Math.ceil((overlapEnd.getTime() - overlapStart.getTime()) / (1000 * 60 * 60 * 24)) + 1;

      if (overlapDays > 0) {
        if (leave.status === "approved") {
           // For approved leave, we only deduct the proportion that is unpaid
           // If the entire leave overlaps, deduct all unpaid days.
           // If it's partial, we approximate by capping at the approvedUnpaidDays limit
           const unpaidDaysTotal = parseFloat(leave.approvedUnpaidDays || "0");
           const daysToDeduct = Math.min(overlapDays, unpaidDaysTotal);
           if (daysToDeduct > 0) {
             unapprovedDays += daysToDeduct;
             leaveIds.push(leave.id);
           }
        } else {
           unapprovedDays += overlapDays;
           leaveIds.push(leave.id);
        }
      }
    }

    const leaveDeduction = unapprovedDays * dailyRate;

    return {
      unapprovedDays,
      leaveDeduction: parseFloat(leaveDeduction.toFixed(3)),
      dailyRate: parseFloat(dailyRate.toFixed(3)),
      leaveIds,
    };
  }

  async createLeaveRequest(data: InsertLeaveRequest): Promise<LeaveRequest> {
    const [request] = await db.insert(leaveRequests).values(data).returning();
    
    // Trigger notification
    if (request) {
      try {
        const employee = await this.getEmployee(request.employeeId);
        
        // Find recipient emails: Manager, Super Admin, and Covering Employee
        // 1. Covering Employee
        let coveringEmployeeName = "";
        const recipientEmails: string[] = [];
        
        if (request.coveringEmployeeId) {
          const coveringEmployee = await this.getEmployee(request.coveringEmployeeId);
          if (coveringEmployee) {
            coveringEmployeeName = coveringEmployee.name;
            if (coveringEmployee.email) recipientEmails.push(coveringEmployee.email);
          }
        }
        
        // 2. Managers and Super Admins
        const admins = await db.select().from(users).where(
          or(
            eq(users.role, "admin"),
            eq(users.role, "super_admin")
          )
        );
        
        admins.forEach(admin => {
          if (admin.email) recipientEmails.push(admin.email);
        });
        
        // Remove duplicates and call notification service
        const uniqueEmails = Array.from(new Set(recipientEmails));
        
        if (uniqueEmails.length > 0 && employee) {
          await sendLeaveRequestNotification({
            employeeName: employee.name,
            startDate: request.startDate.toString(),
            endDate: request.endDate.toString(),
            totalDays: request.totalDays,
            reason: request.reason || "Not specified",
            coveringEmployeeName,
            recipientEmails: uniqueEmails
          });
        }
      } catch (err) {
        console.error("Failed to send leave request notification:", err);
      }
    }
    
    return request;
  }


  async updateLeaveRequest(id: string, data: Partial<InsertLeaveRequest>): Promise<LeaveRequest | undefined> {
    const [request] = await db.update(leaveRequests).set(data).where(eq(leaveRequests.id, id)).returning();
    return request || undefined;
  }

  async approveLeaveRequest(id: string, approvedById: string, approvedPaidDays?: number, approvedUnpaidDays?: number, comments?: string): Promise<LeaveRequest | undefined> {
    const [request] = await db.update(leaveRequests).set({
      status: "approved",
      approvedById,
      approvedPaidDays: approvedPaidDays?.toString() || "0",
      approvedUnpaidDays: approvedUnpaidDays?.toString() || "0",
      comments: comments || null,
      approvedAt: new Date(),
    }).where(eq(leaveRequests.id, id)).returning();

    // Update leave balance only for paid days
    if (request) {
      const year = new Date().getFullYear();
      const [balance] = await db.select().from(leaveBalances)
        .where(and(
          eq(leaveBalances.employeeId, request.employeeId),
          eq(leaveBalances.leaveTypeId, request.leaveTypeId),
          eq(leaveBalances.year, year)
        ));

      if (balance) {
        // Only deduct approvedPaidDays from the leave balance
        const daysToDeduct = approvedPaidDays || 0;
        
        if (daysToDeduct > 0) {
          const used = parseFloat(balance.used || "0") + daysToDeduct;
          const newBalance = parseFloat(balance.entitlement || "0") + parseFloat(balance.carriedForward || "0") - used;
          await db.update(leaveBalances).set({
            used: used.toString(),
            balance: newBalance.toString(),
          }).where(eq(leaveBalances.id, balance.id));
        }
      }
    }

    return request || undefined;
  }


  async rejectLeaveRequest(id: string, comments: string): Promise<LeaveRequest | undefined> {
    const [request] = await db.update(leaveRequests).set({
      status: "rejected",
      comments,
    }).where(eq(leaveRequests.id, id)).returning();
    return request || undefined;
  }

  // Leave Balances
  async getLeaveBalances(employeeId: string, year?: number): Promise<LeaveBalance[]> {
    const currentYear = year || new Date().getFullYear();
    return db.select().from(leaveBalances)
      .where(and(eq(leaveBalances.employeeId, employeeId), eq(leaveBalances.year, currentYear)));
  }

  async updateLeaveBalance(employeeId: string, leaveTypeId: string, year: number, data: Partial<InsertLeaveBalance>): Promise<LeaveBalance | undefined> {
    const [existing] = await db.select().from(leaveBalances)
      .where(and(
        eq(leaveBalances.employeeId, employeeId),
        eq(leaveBalances.leaveTypeId, leaveTypeId),
        eq(leaveBalances.year, year)
      ));

    if (existing) {
      const [balance] = await db.update(leaveBalances).set(data).where(eq(leaveBalances.id, existing.id)).returning();
      return balance || undefined;
    } else {
      const [balance] = await db.insert(leaveBalances).values({
        employeeId,
        leaveTypeId,
        year,
        ...data,
      }).returning();
      return balance;
    }
  }

